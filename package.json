{
  "name": "meshboard",
  "private": true,
  "scripts": {
    "tailwind:build": "tailwindcss -i ./src/MeshBoard.Client/Styles/app.css -o ./src/MeshBoard.Client/wwwroot/css/app.css --minify",
    "tailwind:watch": "tailwindcss -i ./src/MeshBoard.Client/Styles/app.css -o ./src/MeshBoard.Client/wwwroot/css/app.css --watch",
    "tailwind:build:client": "npm run tailwind:build",
    "tailwind:watch:client": "npm run tailwind:watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "tailwindcss": "^4.1.13"
  },
  "dependencies": {
    "mqtt": "^5.15.0"
  }
}
