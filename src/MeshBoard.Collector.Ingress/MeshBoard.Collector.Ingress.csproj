<Project Sdk="Microsoft.NET.Sdk.Worker">
  <PropertyGroup>
    <AssemblyName>MeshBoard.Collector.Ingress</AssemblyName>
    <OutputType>Exe</OutputType>
    <RootNamespace>MeshBoard.Collector.Ingress</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <MSBuildEnableWorkloadResolver>false</MSBuildEnableWorkloadResolver>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\MeshBoard.Application\MeshBoard.Application.csproj" />
    <ProjectReference Include="..\MeshBoard.Contracts\MeshBoard.Contracts.csproj" />
    <ProjectReference Include="..\MeshBoard.Infrastructure.Eventing\MeshBoard.Infrastructure.Eventing.csproj" />
    <ProjectReference Include="..\MeshBoard.Infrastructure.Meshtastic\MeshBoard.Infrastructure.Meshtastic.csproj" />
  </ItemGroup>
</Project>
