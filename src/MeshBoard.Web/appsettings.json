{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Persistence": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=meshboard.db",
    "MessageRetentionDays": 30,
    "SeedLegacyDefaultWorkspace": false
  },
  "AllowedHosts": "*"
}
