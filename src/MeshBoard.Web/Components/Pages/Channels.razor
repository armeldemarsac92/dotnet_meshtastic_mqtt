@page "/channels"

<PageTitle>Channels</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Cutover</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Legacy channels landing page retired</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            Channel exploration and drill-down are moving to the browser-first client. This server route remains only as
            a cutover placeholder for old deep links.
        </p>
    </header>

    <section class="liquid-panel rounded-[1.6rem] p-6">
        <p class="text-cinder-800/84">
            The old server-rendered topics, messages, nodes, and channel detail flows have been retired.
        </p>
    </section>
</div>
