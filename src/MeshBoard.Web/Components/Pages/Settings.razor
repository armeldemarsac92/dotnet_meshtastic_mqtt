@page "/settings"
@inject IMessageRetentionService MessageRetentionService
@inject IOptions<PersistenceOptions> PersistenceConfiguration

<PageTitle>Settings</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Maintenance</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Server maintenance</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            The legacy server-rendered settings page is being retired. Runtime visibility and live operations are moving
            to the browser-first client and realtime stack.
        </p>
    </header>

    <section class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
        <article class="liquid-panel rounded-[1.6rem] p-6">
            <h2 class="font-display text-3xl text-cinder-950">Cutover status</h2>
            <ul class="mt-5 list-disc space-y-2 pl-5 text-cinder-800/84">
                <li>Legacy runtime visibility is no longer exposed from this server page.</li>
                <li>Broker profiles, presets, favorites, channels, and live traffic now belong to the browser-first path.</li>
                <li>Only maintenance tasks that still require direct server access remain here during cutover.</li>
            </ul>
        </article>

        <article class="liquid-panel rounded-[1.6rem] p-6">
            <h2 class="font-display text-3xl text-cinder-950">Persistence</h2>
            <dl class="mt-5 grid gap-3 sm:grid-cols-[11rem_1fr]">
                <dt class="text-cinder-800/70">Provider</dt>
                <dd class="font-medium text-cinder-950">@PersistenceConfiguration.Value.Provider</dd>
                <dt class="text-cinder-800/70">Connection</dt>
                <dd class="font-medium text-cinder-950"><code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@PersistenceConfiguration.Value.ConnectionString</code></dd>
                <dt class="text-cinder-800/70">Retention days</dt>
                <dd class="font-medium text-cinder-950">@PersistenceConfiguration.Value.MessageRetentionDays</dd>
            </dl>
            <div class="mt-6 border-t border-sand-200/80 pt-4">
                <button type="button"
                        class="liquid-button liquid-button-accent inline-flex items-center rounded-full px-4 py-2 text-sm font-medium disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="PruneMessageHistory"
                        disabled="@_isPruningMessages">
                    @(_isPruningMessages ? "Pruning..." : "Prune expired messages")
                </button>
                @if (!string.IsNullOrWhiteSpace(_pruneStatusMessage))
                {
                    <p class="mt-3 text-xs leading-6 text-cinder-800/78">@_pruneStatusMessage</p>
                }
            </div>
        </article>
    </section>
</div>

@code {
    private bool _isPruningMessages;
    private string? _pruneStatusMessage;

    private async Task PruneMessageHistory()
    {
        if (_isPruningMessages)
        {
            return;
        }

        _isPruningMessages = true;
        _pruneStatusMessage = null;

        try
        {
            var deletedCount = await MessageRetentionService.PruneExpiredMessages();
            var noun = deletedCount == 1 ? "message" : "messages";
            var timestamp = DateTimeOffset.UtcNow.ToString("u");
            _pruneStatusMessage = $"Pruned {deletedCount} expired {noun} at {timestamp}.";
        }
        catch (Exception exception)
        {
            _pruneStatusMessage = $"Prune failed: {exception.Message}";
        }
        finally
        {
            _isPruningMessages = false;
        }
    }
}
