@page "/settings"
@inject IOptions<BrokerOptions> BrokerConfiguration
@inject IOptions<PersistenceOptions> PersistenceConfiguration

<PageTitle>Settings</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Configuration</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Runtime defaults</h1>
        </div>
        <p class="max-w-3xl text-base leading-8 text-cinder-800">
            These are the bound options the current shell uses. The settings page is also where future agents should
            surface persistence and broker configuration without collapsing architecture boundaries.
        </p>
    </header>

    <section class="grid gap-4 xl:grid-cols-2">
        <article class="rounded-[1.6rem] border border-white/60 bg-white/72 p-6 shadow-panel backdrop-blur">
            <h2 class="font-display text-3xl text-cinder-950">Broker</h2>
            <dl class="mt-5 grid gap-3 sm:grid-cols-[11rem_1fr]">
                <dt class="text-cinder-800/70">Host</dt>
                <dd class="font-medium text-cinder-950">@BrokerConfiguration.Value.Host</dd>
                <dt class="text-cinder-800/70">Port</dt>
                <dd class="font-medium text-cinder-950">@BrokerConfiguration.Value.Port</dd>
                <dt class="text-cinder-800/70">Default topic</dt>
                <dd class="font-medium text-cinder-950"><code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@BrokerConfiguration.Value.DefaultTopicPattern</code></dd>
                <dt class="text-cinder-800/70">Send enabled</dt>
                <dd class="font-medium text-cinder-950">@BrokerConfiguration.Value.EnableSend</dd>
            </dl>
        </article>

        <article class="rounded-[1.6rem] border border-white/60 bg-white/72 p-6 shadow-panel backdrop-blur">
            <h2 class="font-display text-3xl text-cinder-950">Persistence</h2>
            <dl class="mt-5 grid gap-3 sm:grid-cols-[11rem_1fr]">
                <dt class="text-cinder-800/70">Provider</dt>
                <dd class="font-medium text-cinder-950">@PersistenceConfiguration.Value.Provider</dd>
                <dt class="text-cinder-800/70">Connection</dt>
                <dd class="font-medium text-cinder-950"><code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@PersistenceConfiguration.Value.ConnectionString</code></dd>
                <dt class="text-cinder-800/70">Retention days</dt>
                <dd class="font-medium text-cinder-950">@PersistenceConfiguration.Value.MessageRetentionDays</dd>
            </dl>
        </article>
    </section>
</div>
