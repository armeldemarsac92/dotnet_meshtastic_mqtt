@page "/nodes"
@implements IAsyncDisposable
@inject IFavoriteNodeService FavoriteNodeService
@inject INodeService NodeService
@inject IWorkspaceContextAccessor WorkspaceContextAccessor
@inject ProjectionChangeNotifier ProjectionChangeNotifier

<PageTitle>Nodes</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Discovery</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Observed nodes</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            Browse nodes in controlled batches to keep query cost predictable while still supporting rich filters and telemetry views.
        </p>
    </header>

    <section class="liquid-panel grid gap-4 rounded-[1.6rem] p-5 lg:grid-cols-[1.2fr_0.9fr_0.9fr_0.9fr_0.9fr_0.8fr]">
        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Search</span>
            <input @bind="_query.SearchText"
                   @bind:event="oninput"
                   @bind:after="@(() => RefreshNodesAsync())"
                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                   placeholder="Node id, name, or channel" />
        </label>

        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Sort</span>
            <select @bind="_query.SortBy"
                    @bind:after="@(() => RefreshNodesAsync())"
                    class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950">
                <option value="@NodeSortOption.LastHeardDesc">Last heard</option>
                <option value="@NodeSortOption.NameAsc">Name</option>
                <option value="@NodeSortOption.BatteryDesc">Battery</option>
            </select>
        </label>

        <label class="liquid-input flex items-center gap-3 rounded-2xl px-4 py-3 text-sm text-cinder-900">
            <input type="checkbox" @bind="_query.OnlyWithLocation" @bind:after="@(() => RefreshNodesAsync())" />
            <span>Only with location</span>
        </label>

        <label class="liquid-input flex items-center gap-3 rounded-2xl px-4 py-3 text-sm text-cinder-900">
            <input type="checkbox" @bind="_query.OnlyWithTelemetry" @bind:after="@(() => RefreshNodesAsync())" />
            <span>Only with telemetry</span>
        </label>

        <label class="liquid-input flex items-center gap-3 rounded-2xl px-4 py-3 text-sm text-cinder-900">
            <input type="checkbox" @bind="_query.OnlyFavorites" @bind:after="@(() => RefreshNodesAsync())" />
            <span>Only favorites</span>
        </label>

        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Nodes displayed</span>
            <select @bind="_maxDisplayed"
                    @bind:after="@(() => RefreshNodesAsync())"
                    class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950">
                <option value="50">50</option>
                <option value="100">100</option>
                <option value="250">250</option>
                <option value="500">500</option>
            </select>
        </label>
    </section>

    <section class="flex flex-wrap items-center justify-between gap-2 text-sm text-cinder-800/82">
        <p>Showing @DisplayedNodeCount of @_totalMatchedNodeCount matching nodes. Each load adds @_maxDisplayed rows.</p>
        @if (!string.IsNullOrWhiteSpace(_favoriteStatusMessage))
        {
            <p>@_favoriteStatusMessage</p>
        }
    </section>

    <section class="liquid-panel overflow-hidden rounded-[1.6rem]">
        <table class="min-w-full border-collapse">
            <thead class="liquid-table-head">
                <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                    <th class="px-5 py-4">Favorite</th>
                    <th class="px-5 py-4">Node</th>
                    <th class="px-5 py-4">Channel</th>
                    <th class="px-5 py-4">Position</th>
                    <th class="px-5 py-4">Device</th>
                    <th class="px-5 py-4">Environment</th>
                    <th class="px-5 py-4">Last heard</th>
                </tr>
            </thead>
            <tbody>
                @if (_nodes.Count == 0)
                {
                    <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                        <td colspan="7" class="px-5 py-8 text-center text-cinder-800/78">
                            @(_isLoadingNodes ? "Loading nodes..." : "No nodes match the current filters.")
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var node in _nodes)
                    {
                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                            <td class="px-5 py-4">
                                <button @onclick="() => ToggleFavoriteAsync(node)"
                                        disabled="@(_favoriteActionNodeId == node.NodeId)"
                                        class="liquid-button cursor-pointer rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] @(IsFavorite(node.NodeId) ? "liquid-button-success" : "liquid-button-accent") disabled:cursor-not-allowed disabled:opacity-60">
                                    @(IsFavorite(node.NodeId) ? "Saved" : "Save")
                                </button>
                            </td>
                            <td class="px-5 py-4">
                                <button type="button"
                                        class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-xs font-semibold"
                                        @onclick="() => OpenNodeDetails(node.NodeId)">
                                    @GetNodeDisplayName(node)
                                </button>
                            </td>
                            <td class="px-5 py-4">
                                @if (string.IsNullOrWhiteSpace(node.LastHeardChannel))
                                {
                                    <span class="text-cinder-800/70">Unknown</span>
                                }
                                else
                                {
                                    <button type="button"
                                            class="liquid-inline-action cursor-pointer inline-flex rounded-full px-3 py-1 text-xs font-semibold"
                                            @onclick="() => OpenChannelDetailsFromKey(node.LastHeardChannel!)">
                                        @node.LastHeardChannel
                                    </button>
                                }
                            </td>
                            <td class="px-5 py-4 text-cinder-800/82">@FormatPosition(node)</td>
                            <td class="px-5 py-4">@RenderDeviceTelemetry(node)</td>
                            <td class="px-5 py-4">@RenderEnvironmentTelemetry(node)</td>
                            <td class="px-5 py-4">@(node.LastHeardAtUtc?.ToString("u") ?? "Unknown")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </section>

    @if (DisplayedNodeCount < _totalMatchedNodeCount)
    {
        <section class="flex justify-center">
            <button type="button"
                    class="liquid-button liquid-button-accent cursor-pointer rounded-full px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                    disabled="@_isLoadingNodes"
                    @onclick="LoadMoreNodesAsync">
                @(_isLoadingNodes ? "Loading..." : $"Load more ({Math.Min(_maxDisplayed, _totalMatchedNodeCount - DisplayedNodeCount)} next)")
            </button>
        </section>
    }
</div>

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetails"
                  OnOpenChannel="OpenChannelDetailsAsync" />

<ChannelDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedRegion) && !string.IsNullOrWhiteSpace(_selectedChannel))"
                     Region="@(_selectedRegion ?? string.Empty)"
                     Channel="@(_selectedChannel ?? string.Empty)"
                     OnClose="CloseChannelDetails"
                     OnOpenNode="OpenNodeDetailsAsync" />

@code {
    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private string? _favoriteActionNodeId;
    private readonly HashSet<string> _favoriteNodeIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _pendingNodeRefreshIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly List<NodeSummary> _nodes = [];
    private string? _favoriteStatusMessage;
    private bool _isLoadingNodes;
    private int _maxDisplayed = 100;
    private readonly NodeQuery _query = new();
    private int _requestVersion;
    private string? _selectedChannel;
    private string? _selectedNodeId;
    private string? _selectedRegion;
    private int _totalMatchedNodeCount;
    private CancellationTokenSource? _realtimeRefreshDebounceCancellationTokenSource;
    private int DisplayedNodeCount => _nodes.Count;

    protected override async Task OnInitializedAsync()
    {
        ProjectionChangeNotifier.Changed += HandleProjectionChangedAsync;
        await RefreshNodesAsync(_cancellationTokenSource.Token);
    }

    public ValueTask DisposeAsync()
    {
        ProjectionChangeNotifier.Changed -= HandleProjectionChangedAsync;
        _cancellationTokenSource.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();
        _cancellationTokenSource.Dispose();
        return ValueTask.CompletedTask;
    }

    private bool IsFavorite(string nodeId)
    {
        return _favoriteNodeIds.Contains(nodeId);
    }

    private static string GetNodeDisplayName(NodeSummary node)
    {
        return node.LongName ?? node.ShortName ?? node.NodeId;
    }

    private async Task RefreshFavoritesAsync(CancellationToken cancellationToken = default)
    {
        var favorites = await FavoriteNodeService.GetFavoriteNodes(cancellationToken);

        _favoriteNodeIds.Clear();

        foreach (var favorite in favorites)
        {
            _favoriteNodeIds.Add(favorite.NodeId);
        }
    }

    private Task HandleProjectionChangedAsync(ProjectionChangeEvent change)
    {
        if (!IsRelevantProjectionChange(change))
        {
            return Task.CompletedTask;
        }

        _pendingNodeRefreshIds.Add(change.EntityKey!);
        return ScheduleRealtimeRefreshAsync();
    }

    private bool IsRelevantProjectionChange(ProjectionChangeEvent change)
    {
        return string.Equals(change.WorkspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal) &&
            change.Kind == ProjectionChangeKind.NodeUpdated &&
            !string.IsNullOrWhiteSpace(change.EntityKey);
    }

    private async Task ScheduleRealtimeRefreshAsync()
    {
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_cancellationTokenSource.Token);
        _realtimeRefreshDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(300), debounceCancellationTokenSource.Token);
            await ApplyPendingNodeUpdatesAsync(debounceCancellationTokenSource.Token);
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_realtimeRefreshDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _realtimeRefreshDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

    private async Task ApplyPendingNodeUpdatesAsync(CancellationToken cancellationToken)
    {
        if (_pendingNodeRefreshIds.Count == 0)
        {
            return;
        }

        var nodeIds = _pendingNodeRefreshIds.ToArray();
        _pendingNodeRefreshIds.Clear();

        var updatedNodes = await Task.WhenAll(nodeIds.Select(nodeId => NodeService.GetNodeById(nodeId, cancellationToken)));
        var visibleNodesById = _nodes
            .Select((node, index) => (node, index))
            .ToDictionary(entry => entry.node.NodeId, entry => entry.index, StringComparer.OrdinalIgnoreCase);
        var didChange = false;

        foreach (var updatedNode in updatedNodes)
        {
            if (updatedNode is null)
            {
                continue;
            }

            if (!visibleNodesById.TryGetValue(updatedNode.NodeId, out var existingIndex))
            {
                continue;
            }

            if (!MatchesCurrentQuery(updatedNode))
            {
                _nodes.RemoveAt(existingIndex);
                _totalMatchedNodeCount = Math.Max(0, _totalMatchedNodeCount - 1);
                didChange = true;
                RebuildVisibleNodeIndex(visibleNodesById);
                continue;
            }

            _nodes[existingIndex] = updatedNode;
            didChange = true;
        }

        if (!didChange)
        {
            return;
        }

        _nodes.Sort(CompareNodes);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshNodesAsync(CancellationToken cancellationToken = default)
    {
        var requestVersion = System.Threading.Interlocked.Increment(ref _requestVersion);
        _isLoadingNodes = true;

        try
        {
            await RefreshFavoritesAsync(cancellationToken);
            var page = await NodeService.GetNodesPage(_query, 0, _maxDisplayed, cancellationToken);

            if (requestVersion != _requestVersion)
            {
                return;
            }

            _nodes.Clear();
            _nodes.AddRange(page.Items);
            _totalMatchedNodeCount = page.TotalCount;
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception exception)
        {
            _favoriteStatusMessage = $"Load failed: {exception.Message}";
        }
        finally
        {
            if (requestVersion == _requestVersion)
            {
                _isLoadingNodes = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private bool MatchesCurrentQuery(NodeSummary node)
    {
        if (_query.OnlyFavorites && !_favoriteNodeIds.Contains(node.NodeId))
        {
            return false;
        }

        if (_query.OnlyWithLocation && (!node.LastKnownLatitude.HasValue || !node.LastKnownLongitude.HasValue))
        {
            return false;
        }

        if (_query.OnlyWithTelemetry &&
            node.BatteryLevelPercent is null &&
            node.Voltage is null &&
            node.ChannelUtilization is null &&
            node.AirUtilTx is null &&
            node.UptimeSeconds is null &&
            node.TemperatureCelsius is null &&
            node.RelativeHumidity is null &&
            node.BarometricPressure is null)
        {
            return false;
        }

        var searchText = _query.SearchText.Trim();

        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        return ContainsIgnoreCase(node.NodeId, searchText) ||
            ContainsIgnoreCase(node.ShortName, searchText) ||
            ContainsIgnoreCase(node.LongName, searchText) ||
            ContainsIgnoreCase(node.LastHeardChannel, searchText);
    }

    private int CompareNodes(NodeSummary left, NodeSummary right)
    {
        return _query.SortBy switch
        {
            NodeSortOption.NameAsc => CompareByName(left, right),
            NodeSortOption.BatteryDesc => CompareByBattery(left, right),
            _ => CompareByLastHeard(left, right)
        };
    }

    private static int CompareByName(NodeSummary left, NodeSummary right)
    {
        var nameComparison = string.Compare(
            left.LongName ?? left.ShortName ?? left.NodeId,
            right.LongName ?? right.ShortName ?? right.NodeId,
            StringComparison.OrdinalIgnoreCase);

        return nameComparison != 0
            ? nameComparison
            : string.Compare(left.NodeId, right.NodeId, StringComparison.OrdinalIgnoreCase);
    }

    private static int CompareByBattery(NodeSummary left, NodeSummary right)
    {
        var batteryComparison = Nullable.Compare(right.BatteryLevelPercent, left.BatteryLevelPercent);

        return batteryComparison != 0
            ? batteryComparison
            : CompareByName(left, right);
    }

    private static int CompareByLastHeard(NodeSummary left, NodeSummary right)
    {
        var heardComparison = Nullable.Compare(right.LastHeardAtUtc, left.LastHeardAtUtc);

        return heardComparison != 0
            ? heardComparison
            : CompareByName(left, right);
    }

    private static bool ContainsIgnoreCase(string? value, string searchText)
    {
        return !string.IsNullOrWhiteSpace(value) &&
            value.Contains(searchText, StringComparison.OrdinalIgnoreCase);
    }

    private void RebuildVisibleNodeIndex(Dictionary<string, int> visibleNodesById)
    {
        visibleNodesById.Clear();

        for (var index = 0; index < _nodes.Count; index += 1)
        {
            visibleNodesById[_nodes[index].NodeId] = index;
        }
    }

    private async Task LoadMoreNodesAsync()
    {
        if (_isLoadingNodes || DisplayedNodeCount >= _totalMatchedNodeCount)
        {
            return;
        }

        var requestVersion = _requestVersion;
        _isLoadingNodes = true;

        try
        {
            var page = await NodeService.GetNodesPage(_query, DisplayedNodeCount, _maxDisplayed, _cancellationTokenSource.Token);

            if (requestVersion != _requestVersion)
            {
                return;
            }

            _totalMatchedNodeCount = page.TotalCount;
            _nodes.AddRange(page.Items);
        }
        catch (Exception exception)
        {
            _favoriteStatusMessage = $"Load failed: {exception.Message}";
        }
        finally
        {
            if (requestVersion == _requestVersion)
            {
                _isLoadingNodes = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task ToggleFavoriteAsync(NodeSummary node)
    {
        _favoriteActionNodeId = node.NodeId;
        _favoriteStatusMessage = null;

        try
        {
            if (IsFavorite(node.NodeId))
            {
                await FavoriteNodeService.RemoveFavoriteNode(node.NodeId);
                _favoriteStatusMessage = $"Removed {node.NodeId} from favorites.";
            }
            else
            {
                await FavoriteNodeService.SaveFavoriteNode(
                    new SaveFavoriteNodeRequest
                    {
                        NodeId = node.NodeId,
                        ShortName = node.ShortName,
                        LongName = node.LongName
                    });
                _favoriteStatusMessage = $"Saved {node.NodeId} as favorite.";
            }

            await RefreshFavoritesAsync(_cancellationTokenSource.Token);

            if (_query.OnlyFavorites)
            {
                await RefreshNodesAsync(_cancellationTokenSource.Token);
                return;
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception exception)
        {
            _favoriteStatusMessage = exception.Message;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _favoriteActionNodeId = null;
        }
    }

    private void OpenNodeDetails(string nodeId)
    {
        _selectedNodeId = nodeId;
    }

    private Task OpenNodeDetailsAsync(string nodeId)
    {
        OpenNodeDetails(nodeId);
        return Task.CompletedTask;
    }

    private Task CloseNodeDetails()
    {
        _selectedNodeId = null;
        return Task.CompletedTask;
    }

    private void OpenChannelDetailsFromKey(string channelKey)
    {
        if (!TrySplitChannelKey(channelKey, out var region, out var channel))
        {
            return;
        }

        _selectedRegion = region;
        _selectedChannel = channel;
    }

    private Task OpenChannelDetailsAsync(string channelKey)
    {
        OpenChannelDetailsFromKey(channelKey);
        return Task.CompletedTask;
    }

    private Task CloseChannelDetails()
    {
        _selectedRegion = null;
        _selectedChannel = null;
        return Task.CompletedTask;
    }

    private static string FormatPosition(NodeSummary node)
    {
        return node.LastKnownLatitude.HasValue && node.LastKnownLongitude.HasValue
            ? $"{node.LastKnownLatitude.Value:F5}, {node.LastKnownLongitude.Value:F5}"
            : "Unknown";
    }

    private static string GetBatteryClass(int batteryLevel)
    {
        return batteryLevel switch
        {
            <= 15 => "bg-red-100 text-red-700",
            <= 35 => "bg-orange-100 text-orange-700",
            <= 60 => "bg-amber-100 text-amber-700",
            _ => "bg-emerald-100 text-emerald-700"
        };
    }

    private static RenderFragment RenderDeviceTelemetry(NodeSummary node) => builder =>
    {
        var bubbles = new List<(string Text, string ClassName)>();

        if (node.BatteryLevelPercent.HasValue)
        {
            bubbles.Add(($"{node.BatteryLevelPercent.Value}% battery", GetBatteryClass(node.BatteryLevelPercent.Value)));
        }

        if (node.Voltage.HasValue)
        {
            bubbles.Add(($"{node.Voltage.Value:F2}V", "bg-cinder-900/8 text-cinder-900"));
        }

        if (node.ChannelUtilization.HasValue)
        {
            bubbles.Add(($"{node.ChannelUtilization.Value:F1}% ch", "bg-signal-500/12 text-signal-600"));
        }

        if (node.AirUtilTx.HasValue)
        {
            bubbles.Add(($"{node.AirUtilTx.Value:F1}% tx", "bg-sand-200 text-cinder-900"));
        }

        if (node.UptimeSeconds.HasValue)
        {
            bubbles.Add((FormatUptime(node.UptimeSeconds.Value), "bg-cinder-900/8 text-cinder-900"));
        }

        if (bubbles.Count == 0)
        {
            builder.AddContent(0, "No telemetry");
            return;
        }

        builder.OpenElement(1, "div");
        builder.AddAttribute(2, "class", "flex flex-wrap gap-2");

        var sequence = 3;
        foreach (var bubble in bubbles)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", $"rounded-full px-3 py-1 text-xs font-semibold {bubble.ClassName}");
            builder.AddContent(sequence++, bubble.Text);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static RenderFragment RenderEnvironmentTelemetry(NodeSummary node) => builder =>
    {
        var bubbles = new List<(string Text, string ClassName)>();

        if (node.TemperatureCelsius.HasValue)
        {
            bubbles.Add(($"{node.TemperatureCelsius.Value:F1}C", "bg-signal-500/12 text-signal-600"));
        }

        if (node.RelativeHumidity.HasValue)
        {
            bubbles.Add(($"{node.RelativeHumidity.Value:F1}% RH", "bg-cinder-900/8 text-cinder-900"));
        }

        if (node.BarometricPressure.HasValue)
        {
            bubbles.Add(($"{node.BarometricPressure.Value:F1} hPa", "bg-sand-200 text-cinder-900"));
        }

        if (bubbles.Count == 0)
        {
            builder.AddContent(0, "No telemetry");
            return;
        }

        builder.OpenElement(1, "div");
        builder.AddAttribute(2, "class", "flex flex-wrap gap-2");

        var sequence = 3;
        foreach (var bubble in bubbles)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", $"rounded-full px-3 py-1 text-xs font-semibold {bubble.ClassName}");
            builder.AddContent(sequence++, bubble.Text);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static string FormatUptime(long uptimeSeconds)
    {
        var uptime = TimeSpan.FromSeconds(uptimeSeconds);

        if (uptime.TotalDays >= 1)
        {
            return $"{(int)uptime.TotalDays}d {uptime.Hours}h";
        }

        if (uptime.TotalHours >= 1)
        {
            return $"{(int)uptime.TotalHours}h {uptime.Minutes}m";
        }

        return $"{uptime.Minutes}m";
    }

    private static bool TrySplitChannelKey(string channelKey, out string region, out string channel)
    {
        region = string.Empty;
        channel = string.Empty;

        if (string.IsNullOrWhiteSpace(channelKey))
        {
            return false;
        }

        var segments = channelKey.Split('/', 2, StringSplitOptions.TrimEntries);

        if (segments.Length != 2)
        {
            return false;
        }

        region = segments[0];
        channel = segments[1];
        return !string.IsNullOrWhiteSpace(region) && !string.IsNullOrWhiteSpace(channel);
    }
}
