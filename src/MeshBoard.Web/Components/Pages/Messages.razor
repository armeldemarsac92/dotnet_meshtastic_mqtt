@page "/messages"
@implements IAsyncDisposable
@inject IMessageService MessageService

<PageTitle>Messages</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Traffic</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Message stream</h1>
        </div>
        <p class="max-w-3xl text-base leading-8 text-cinder-800">
            This page refreshes every 3 seconds from persisted message history. The feed now stores packet types and
            deduplicates repeated broker packets so decoded traffic is easier to inspect.
        </p>
    </header>

    <section class="grid gap-4 rounded-[1.6rem] border border-white/60 bg-white/72 p-5 shadow-panel backdrop-blur lg:grid-cols-[1.2fr_0.8fr_0.8fr]">
        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Search</span>
            <input @bind="_filters.SearchText"
                   @bind:event="oninput"
                   class="w-full rounded-2xl border border-sand-200 bg-white px-4 py-3 text-sm text-cinder-950 outline-none"
                   placeholder="Node id, packet type, or preview text" />
        </label>

        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Visibility</span>
            <select @bind="_filters.Visibility"
                    class="w-full rounded-2xl border border-sand-200 bg-white px-4 py-3 text-sm text-cinder-950 outline-none">
                <option value="@MessageVisibility.All">All packets</option>
                <option value="@MessageVisibility.DecodedOnly">Decoded only</option>
                <option value="@MessageVisibility.OpaqueOnly">Opaque only</option>
                <option value="@MessageVisibility.PrivateOnly">Private only</option>
            </select>
        </label>

        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Packet type</span>
            <select @bind="_filters.PacketType"
                    class="w-full rounded-2xl border border-sand-200 bg-white px-4 py-3 text-sm text-cinder-950 outline-none">
                <option value="">Any packet type</option>
                @foreach (var packetType in PacketTypes)
                {
                    <option value="@packetType">@packetType</option>
                }
            </select>
        </label>
    </section>

    <section class="overflow-hidden rounded-[1.6rem] border border-white/60 bg-white/72 shadow-panel backdrop-blur">
        @if (FilteredMessages.Count == 0)
        {
            <div class="p-6 text-cinder-800/78">
                No packets match the current filters.
            </div>
        }
        else
        {
            <table class="min-w-full border-collapse">
                <thead class="bg-sand-50/80">
                    <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                        <th class="px-5 py-4">Received</th>
                        <th class="px-5 py-4">Type</th>
                        <th class="px-5 py-4">Topic</th>
                        <th class="px-5 py-4">From</th>
                        <th class="px-5 py-4">To</th>
                        <th class="px-5 py-4">Preview</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var message in FilteredMessages)
                    {
                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                            <td class="px-5 py-4">@message.ReceivedAtUtc.ToString("u")</td>
                            <td class="px-5 py-4">
                                <span class="@GetPacketTypeBadgeClass(message.PacketType)">@message.PacketType</span>
                            </td>
                            <td class="px-5 py-4"><code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@message.Topic</code></td>
                            <td class="px-5 py-4 font-medium">@message.FromNodeId</td>
                            <td class="px-5 py-4 text-cinder-800/80">@(message.ToNodeId ?? "Broadcast")</td>
                            <td class="px-5 py-4">@message.PayloadPreview</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private readonly MessageFilters _filters = new();
    private IReadOnlyCollection<MessageSummary> _messages = [];
    private Task? _refreshTask;
    private IReadOnlyCollection<MessageSummary> FilteredMessages => _messages
        .Where(ApplyVisibilityFilter)
        .Where(ApplyPacketTypeFilter)
        .Where(ApplySearchFilter)
        .ToList();
    private IReadOnlyCollection<string> PacketTypes => _messages
        .Select(message => message.PacketType)
        .Where(packetType => !string.IsNullOrWhiteSpace(packetType))
        .Distinct(StringComparer.Ordinal)
        .OrderBy(packetType => packetType)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _refreshTask = RefreshAsync(_cancellationTokenSource.Token);
    }

    public async ValueTask DisposeAsync()
    {
        _cancellationTokenSource.Cancel();

        if (_refreshTask is not null)
        {
            try
            {
                await _refreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _cancellationTokenSource.Dispose();
    }

    private async Task LoadAsync()
    {
        _messages = await MessageService.GetRecentMessages();
    }

    private async Task RefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool ApplyPacketTypeFilter(MessageSummary message)
    {
        return string.IsNullOrWhiteSpace(_filters.PacketType) ||
            string.Equals(message.PacketType, _filters.PacketType, StringComparison.Ordinal);
    }

    private bool ApplySearchFilter(MessageSummary message)
    {
        if (string.IsNullOrWhiteSpace(_filters.SearchText))
        {
            return true;
        }

        return message.FromNodeId.Contains(_filters.SearchText, StringComparison.OrdinalIgnoreCase) ||
            (message.ToNodeId?.Contains(_filters.SearchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            message.PacketType.Contains(_filters.SearchText, StringComparison.OrdinalIgnoreCase) ||
            message.PayloadPreview.Contains(_filters.SearchText, StringComparison.OrdinalIgnoreCase);
    }

    private bool ApplyVisibilityFilter(MessageSummary message)
    {
        return _filters.Visibility switch
        {
            MessageVisibility.DecodedOnly => IsDecodedMessage(message),
            MessageVisibility.OpaqueOnly => !IsDecodedMessage(message),
            MessageVisibility.PrivateOnly => message.IsPrivate,
            _ => true
        };
    }

    private static string GetPacketTypeBadgeClass(string packetType)
    {
        return packetType switch
        {
            "Text Message" => "rounded-full bg-signal-500/12 px-3 py-1 text-xs font-semibold text-signal-600",
            "Node Info" => "rounded-full bg-cinder-900/8 px-3 py-1 text-xs font-semibold text-cinder-900",
            "Position Update" => "rounded-full bg-sand-200 px-3 py-1 text-xs font-semibold text-cinder-900",
            "Encrypted Packet" => "rounded-full bg-cinder-900 px-3 py-1 text-xs font-semibold text-white",
            _ => "rounded-full bg-sand-100 px-3 py-1 text-xs font-semibold text-cinder-900"
        };
    }

    private static bool IsDecodedMessage(MessageSummary message)
    {
        return message.PacketType is not ("Encrypted Packet" or "Unknown Packet" or "Legacy Packet");
    }

    private sealed class MessageFilters
    {
        public string PacketType { get; set; } = string.Empty;

        public string SearchText { get; set; } = string.Empty;

        public MessageVisibility Visibility { get; set; } = MessageVisibility.All;
    }

    private enum MessageVisibility
    {
        All,
        DecodedOnly,
        OpaqueOnly,
        PrivateOnly
    }
}
