@page "/messages"
@implements IAsyncDisposable
@using MeshBoard.Web.State
@inject IBrokerMonitorService BrokerMonitorService
@inject ICachedMessagePageService CachedMessagePageService
@inject IWorkspaceContextAccessor WorkspaceContextAccessor
@inject ProjectionChangeNotifier ProjectionChangeNotifier
@inject ServerSelectionNotifier ServerSelectionNotifier

<PageTitle>Messages</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Traffic</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Message stream</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            Filter persisted traffic and toggle live channel subscriptions directly from this dashboard.
        </p>
    </header>

    <section class="liquid-panel rounded-[1.6rem] p-5">
        <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Listening channels</span>
            @if (ChannelEntries.Count == 0)
            {
                <span class="text-xs text-cinder-800/78">No active subscriptions. Open <a href="/topics" class="underline underline-offset-4">Topics</a> to subscribe.</span>
            }
            else
            {
                @foreach (var channelEntry in ChannelEntries)
                {
                    <button type="button"
                            class="liquid-button liquid-button-accent cursor-pointer rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em]"
                            @onclick="() => ToggleSubscriptionAsync(channelEntry.TopicPattern)">
                        @channelEntry.Label
                    </button>
                }
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(_subscriptionStatusMessage))
        {
            <p class="mt-3 text-sm text-cinder-800/80">@_subscriptionStatusMessage</p>
        }
    </section>

    <section class="liquid-panel grid gap-4 rounded-[1.6rem] p-5 lg:grid-cols-[1.15fr_0.75fr_0.75fr_0.75fr]">
        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Search</span>
            <input @bind="_filters.SearchText"
                   @bind:event="oninput"
                   @bind:after="ScheduleFilterRefreshAsync"
                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                   placeholder="Node id, packet type, or preview text" />
        </label>

        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Visibility</span>
            <select @bind="_filters.Visibility"
                    @bind:after="HandleFilterChangedAsync"
                    class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950">
                <option value="@MessageVisibilityFilter.All">All packets</option>
                <option value="@MessageVisibilityFilter.DecodedOnly">Decoded only</option>
                <option value="@MessageVisibilityFilter.OpaqueOnly">Opaque only</option>
                <option value="@MessageVisibilityFilter.PrivateOnly">Private only</option>
            </select>
        </label>

        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Packet type</span>
            <select @bind="_filters.PacketType"
                    @bind:after="HandleFilterChangedAsync"
                    class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950">
                <option value="">Any packet type</option>
                @foreach (var packetType in PacketTypes)
                {
                    <option value="@packetType">@packetType</option>
                }
            </select>
        </label>

        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Fallback refresh</span>
            <select @bind="_refreshDelaySeconds"
                    class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950">
                @foreach (var delayOption in RefreshDelayOptions)
                {
                    <option value="@delayOption.Seconds">@delayOption.Label</option>
                }
            </select>
        </label>
    </section>

    <section class="liquid-panel overflow-hidden rounded-[1.6rem]">
        @if (_messagePage.Items.Count == 0)
        {
            <div class="p-6 text-cinder-800/78">
                @(_isLoading ? "Loading packets..." : "No packets match the current filters.")
            </div>
        }
        else
        {
            <table class="min-w-full table-fixed border-collapse">
                <colgroup>
                    <col class="w-[16%]" />
                    <col class="w-[14%]" />
                    <col class="w-[14%]" />
                    <col class="w-[14%]" />
                    <col class="w-[10%]" />
                    <col class="w-[32%]" />
                </colgroup>
                <thead class="liquid-table-head">
                    <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                        <th class="px-5 py-4">Received</th>
                        <th class="px-5 py-4">Type</th>
                        <th class="px-5 py-4">Channel</th>
                        <th class="px-5 py-4">From</th>
                        <th class="px-5 py-4">To</th>
                        <th class="px-5 py-4">Preview</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var message in _messagePage.Items)
                    {
                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                            <td class="px-5 py-4 align-top whitespace-nowrap">@message.ReceivedAtUtc.ToString("u")</td>
                            <td class="px-5 py-4 align-top">
                                <span class="@GetPacketTypeBadgeClass(message.PacketType)">@message.PacketType</span>
                            </td>
                            <td class="px-5 py-4 align-top">
                                @if (TryGetChannelLabel(message.Topic, out var channelLabel, out var region, out var channel))
                                {
                                    <button type="button"
                                            class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                            @onclick="() => OpenChannelDetails(region, channel)">
                                        @channelLabel
                                    </button>
                                }
                                else
                                {
                                    <span class="inline-flex rounded-full bg-sand-100 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-cinder-900">
                                        Unknown
                                    </span>
                                }
                            </td>
                            <td class="px-5 py-4 align-top font-medium">
                                <button type="button"
                                        class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-xs font-semibold"
                                        @onclick="() => OpenNodeDetails(message.FromNodeId)">
                                    @GetSenderDisplayName(message)
                                </button>
                            </td>
                            <td class="px-5 py-4 align-top text-cinder-800/80">@(message.ToNodeId ?? "Broadcast")</td>
                            <td class="px-5 py-4 align-top">
                                <div class="space-y-2">
                                    <p class="break-words leading-6">@GetTruncatedPreview(message.PayloadPreview)</p>
                                    <button type="button"
                                            class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                            @onclick="() => OpenMessagePreview(message)">
                                        See message
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="flex flex-wrap items-center justify-between gap-3 border-t border-sand-100/80 px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-cinder-800/68">
                @GetPagingSummaryText()
            </p>

            <div class="flex flex-wrap items-center gap-2">
                <label class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">
                    <span>Page size</span>
                    <select @bind="_pageSize"
                            @bind:after="HandlePageSizeChangedAsync"
                            class="liquid-input rounded-full px-3 py-2 text-xs text-cinder-950">
                        @foreach (var pageSizeOption in PageSizeOptions)
                        {
                            <option value="@pageSizeOption">@pageSizeOption</option>
                        }
                    </select>
                </label>

                <button type="button"
                        class="liquid-button cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="GoToPreviousPageAsync"
                        disabled="@(!CanGoPrevious)">
                    Previous
                </button>

                <span class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">
                    Page @_currentPage of @GetTotalPages()
                </span>

                <button type="button"
                        class="liquid-button liquid-button-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="GoToNextPageAsync"
                        disabled="@(!CanGoNext)">
                    Next
                </button>
            </div>
        </div>
    </section>
</div>

@if (_previewMessage is not null)
{
    <div class="modal-overlay fixed inset-0 z-50 flex items-center justify-center bg-cinder-950/40 p-4 backdrop-blur-sm"
         @onclick="CloseMessagePreview">
        <article class="liquid-panel max-h-[85vh] w-full max-w-3xl overflow-hidden rounded-[1.6rem] overscroll-contain"
                 @onclick:stopPropagation="true">
            <header class="flex items-center justify-between border-b border-sand-100/80 px-5 py-4">
                <div class="space-y-1">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Message details</p>
                    <p class="text-sm text-cinder-900">@_previewMessage.ReceivedAtUtc.ToString("u")</p>
                </div>
                <button type="button"
                        class="liquid-button cursor-pointer rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="CloseMessagePreview">
                    Close
                </button>
            </header>
            <div class="max-h-[70vh] space-y-4 overflow-y-auto px-5 py-4 text-sm text-cinder-900 overscroll-contain">
                <div class="flex flex-wrap gap-2">
                    <span class="@GetPacketTypeBadgeClass(_previewMessage.PacketType)">@_previewMessage.PacketType</span>
                    @if (TryGetChannelLabel(_previewMessage.Topic, out var channelLabel, out var region, out var channel))
                    {
                        <button type="button"
                                class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                @onclick="() => OpenChannelDetails(region, channel)">
                            @channelLabel
                        </button>
                    }
                    <button type="button"
                            class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                            @onclick="() => OpenNodeDetails(_previewMessage.FromNodeId)">
                        @GetSenderDisplayName(_previewMessage)
                    </button>
                </div>
                <p class="text-cinder-800/82">To: @(_previewMessage.ToNodeId ?? "Broadcast")</p>
                <section class="liquid-subpanel rounded-2xl p-4">
                    <h2 class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">Full preview</h2>
                    <p class="mt-2 whitespace-pre-wrap break-words text-sm text-cinder-950">@_previewMessage.PayloadPreview</p>
                </section>
            </div>
        </article>
    </div>
}

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetails"
                  OnOpenChannel="OpenChannelDetailsFromKeyAsync" />

<ChannelDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedRegion) && !string.IsNullOrWhiteSpace(_selectedChannel))"
                     Region="@(_selectedRegion ?? string.Empty)"
                     Channel="@(_selectedChannel ?? string.Empty)"
                     OnClose="CloseChannelDetails"
                     OnOpenNode="OpenNodeDetailsFromModalAsync" />

@code {
    private const int PreviewLength = 140;
    private static readonly IReadOnlyCollection<int> PageSizeOptions = [50, 100, 250];
    private static readonly IReadOnlyCollection<string> PacketTypes =
    [
        "Text Message",
        "Compressed Text Message",
        "Node Info",
        "Position Update",
        "Telemetry",
        "Encrypted Packet",
        "Unknown Packet",
        "Legacy Packet"
    ];

    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private CancellationTokenSource? _filterDebounceCancellationTokenSource;
    private BrokerStatus _brokerStatus = new();
    private readonly MessageFilters _filters = new();
    private MessagePageResult _messagePage = new();
    private bool _isLoading;
    private int _currentPage = 1;
    private int _loadRequestVersion;
    private int _pageSize = 50;
    private MessageSummary? _previewMessage;
    private int _refreshDelaySeconds = 30;
    private int _realtimeRefreshQueued;
    private int _realtimeForceRefreshQueued;
    private Task? _realtimeRefreshTask;
    private Task? _refreshTask;
    private string? _selectedChannel;
    private string? _selectedNodeId;
    private string? _selectedRegion;
    private string? _subscriptionStatusMessage;

    private static IReadOnlyCollection<RefreshDelayOption> RefreshDelayOptions =>
    [
        new RefreshDelayOption { Seconds = 30, Label = "30 seconds" },
        new RefreshDelayOption { Seconds = 60, Label = "60 seconds" },
        new RefreshDelayOption { Seconds = 0, Label = "Paused" }
    ];

    private IReadOnlyCollection<ListeningChannelEntry> ChannelEntries => _brokerStatus.TopicFilters
        .Select(CreateListeningChannelEntry)
        .DistinctBy(entry => entry.TopicPattern)
        .OrderBy(entry => entry.Label, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private bool CanGoNext => !_isLoading && (_currentPage * _pageSize) < _messagePage.TotalCount;

    private bool CanGoPrevious => !_isLoading && _currentPage > 1;

    protected override async Task OnInitializedAsync()
    {
        ProjectionChangeNotifier.Changed += HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed += HandleServerSelectionChangedAsync;
        await LoadAsync(_cancellationTokenSource.Token);
        _refreshTask = RefreshAsync(_cancellationTokenSource.Token);
    }

    public ValueTask DisposeAsync()
    {
        ProjectionChangeNotifier.Changed -= HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed -= HandleServerSelectionChangedAsync;
        _cancellationTokenSource.Cancel();
        _filterDebounceCancellationTokenSource?.Cancel();
        _filterDebounceCancellationTokenSource?.Dispose();
        _cancellationTokenSource.Dispose();
        return ValueTask.CompletedTask;
    }

    private async Task HandleServerSelectionChangedAsync(string workspaceId)
    {
        if (!string.Equals(workspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal))
        {
            return;
        }

        _currentPage = 1;
        await LoadAsync(_cancellationTokenSource.Token, forceRefresh: true);
        await InvokeAsync(StateHasChanged);
    }

    private Task HandleProjectionChangedAsync(ProjectionChangeEvent change)
    {
        if (!IsRelevantProjectionChange(change))
        {
            return Task.CompletedTask;
        }

        return ScheduleRealtimeRefreshAsync();
    }

    private bool IsActiveSubscription(string topicPattern)
    {
        return _brokerStatus.TopicFilters.Contains(topicPattern, StringComparer.Ordinal);
    }

    private async Task ScheduleFilterRefreshAsync()
    {
        _filterDebounceCancellationTokenSource?.Cancel();
        _filterDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_cancellationTokenSource.Token);
        _filterDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(250), debounceCancellationTokenSource.Token);
            await LoadFirstPageAsync();
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_filterDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _filterDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

    private async Task HandleFilterChangedAsync()
    {
        await LoadFirstPageAsync();
    }

    private async Task HandlePageSizeChangedAsync()
    {
        await LoadFirstPageAsync();
    }

    private bool IsRelevantProjectionChange(ProjectionChangeEvent change)
    {
        if (!string.Equals(change.WorkspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal))
        {
            return false;
        }

        return change.Kind is ProjectionChangeKind.MessageAdded or ProjectionChangeKind.RuntimeStatusChanged;
    }

    private async Task ScheduleRealtimeRefreshAsync(bool forceRefresh = false)
    {
        if (forceRefresh)
        {
            Interlocked.Exchange(ref _realtimeForceRefreshQueued, 1);
        }

        Interlocked.Exchange(ref _realtimeRefreshQueued, 1);

        if (_realtimeRefreshTask is { IsCompleted: false })
        {
            return;
        }

        _realtimeRefreshTask = ProcessQueuedRealtimeRefreshesAsync();
        await _realtimeRefreshTask;
    }

    private async Task ProcessQueuedRealtimeRefreshesAsync()
    {
        try
        {
            while (!_cancellationTokenSource.IsCancellationRequested)
            {
                Interlocked.Exchange(ref _realtimeRefreshQueued, 0);
                var forceRefresh = Interlocked.Exchange(ref _realtimeForceRefreshQueued, 0) == 1;

                await Task.Delay(TimeSpan.FromMilliseconds(300), _cancellationTokenSource.Token);
                await LoadAsync(_cancellationTokenSource.Token, forceRefresh);
                await InvokeAsync(StateHasChanged);

                if (Volatile.Read(ref _realtimeRefreshQueued) == 0)
                {
                    break;
                }
            }
        }
        catch (OperationCanceledException) when (_cancellationTokenSource.IsCancellationRequested)
        {
        }
    }

    private async Task LoadAsync(CancellationToken cancellationToken, bool forceRefresh = false)
    {
        _brokerStatus = BrokerMonitorService.GetBrokerStatus();
        var requestVersion = ++_loadRequestVersion;

        _isLoading = true;

        try
        {
            var query = new MessageQuery
            {
                BrokerServer = _brokerStatus.ActiveServerAddress ?? string.Empty,
                PacketType = _filters.PacketType,
                SearchText = _filters.SearchText,
                Visibility = _filters.Visibility
            };

            var page = await CachedMessagePageService.GetMessagesPage(
                query,
                offset: (_currentPage - 1) * _pageSize,
                take: _pageSize,
                forceRefresh: forceRefresh,
                cancellationToken: cancellationToken);

            if (requestVersion != _loadRequestVersion)
            {
                return;
            }

            if (page.TotalCount > 0 && page.Items.Count == 0 && _currentPage > 1)
            {
                _currentPage = GetLastPageNumber(page.TotalCount);
                page = await CachedMessagePageService.GetMessagesPage(
                    query,
                    offset: (_currentPage - 1) * _pageSize,
                    take: _pageSize,
                    forceRefresh: forceRefresh,
                    cancellationToken: cancellationToken);

                if (requestVersion != _loadRequestVersion)
                {
                    return;
                }
            }

            _messagePage = page;
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        finally
        {
            if (requestVersion == _loadRequestVersion)
            {
                _isLoading = false;
            }
        }
    }

    private async Task RefreshAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (!cancellationToken.IsCancellationRequested)
            {
                var refreshDelaySeconds = _refreshDelaySeconds;

                if (refreshDelaySeconds <= 0)
                {
                    await Task.Delay(TimeSpan.FromMilliseconds(400), cancellationToken);
                    continue;
                }

                await Task.Delay(TimeSpan.FromSeconds(refreshDelaySeconds), cancellationToken);
                await LoadAsync(cancellationToken);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private async Task LoadFirstPageAsync()
    {
        _currentPage = 1;
        await LoadAsync(_cancellationTokenSource.Token);
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToPreviousPageAsync()
    {
        if (!CanGoPrevious)
        {
            return;
        }

        _currentPage--;
        await LoadAsync(_cancellationTokenSource.Token);
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToNextPageAsync()
    {
        if (!CanGoNext)
        {
            return;
        }

        _currentPage++;
        await LoadAsync(_cancellationTokenSource.Token);
        await InvokeAsync(StateHasChanged);
    }

    private string GetPagingSummaryText()
    {
        if (_isLoading && _messagePage.TotalCount == 0)
        {
            return "Loading packets";
        }

        if (_messagePage.TotalCount == 0)
        {
            return "No packets found";
        }

        var start = ((_currentPage - 1) * _pageSize) + 1;
        var end = Math.Min(_currentPage * _pageSize, _messagePage.TotalCount);

        return $"Showing {start}-{end} of {_messagePage.TotalCount} packets";
    }

    private int GetLastPageNumber(int totalCount)
    {
        return Math.Max(1, (int)Math.Ceiling(totalCount / (double)_pageSize));
    }

    private int GetTotalPages()
    {
        return _messagePage.TotalCount == 0 ? 1 : GetLastPageNumber(_messagePage.TotalCount);
    }

    private static string GetPacketTypeBadgeClass(string packetType)
    {
        return packetType switch
        {
            "Text Message" => "rounded-full bg-signal-500/12 px-3 py-1 text-xs font-semibold text-signal-600",
            "Node Info" => "rounded-full bg-cinder-900/8 px-3 py-1 text-xs font-semibold text-cinder-900",
            "Position Update" => "rounded-full bg-sand-200 px-3 py-1 text-xs font-semibold text-cinder-900",
            "Encrypted Packet" => "rounded-full bg-cinder-900 px-3 py-1 text-xs font-semibold text-white",
            _ => "rounded-full bg-sand-100 px-3 py-1 text-xs font-semibold text-cinder-900"
        };
    }

    private async Task ToggleSubscriptionAsync(string topicPattern)
    {
        try
        {
            if (IsActiveSubscription(topicPattern))
            {
                await BrokerMonitorService.UnsubscribeFromTopic(topicPattern);
                _subscriptionStatusMessage = $"Unsubscribed from {topicPattern}.";
            }
            else
            {
                await BrokerMonitorService.SubscribeToTopic(topicPattern);
                _subscriptionStatusMessage = $"Subscribed to {topicPattern}.";
            }
        }
        catch (Exception exception)
        {
            _subscriptionStatusMessage = exception.Message;
        }

        await LoadAsync(_cancellationTokenSource.Token);
    }

    private static bool TryGetChannelLabel(string topic, out string label, out string region, out string channel)
    {
        label = string.Empty;
        region = string.Empty;
        channel = string.Empty;

        if (string.IsNullOrWhiteSpace(topic))
        {
            return false;
        }

        var segments = topic.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (segments.Length < 5 ||
            !string.Equals(segments[0], "msh", StringComparison.OrdinalIgnoreCase) ||
            (!string.Equals(segments[3], "e", StringComparison.OrdinalIgnoreCase) &&
             !string.Equals(segments[3], "json", StringComparison.OrdinalIgnoreCase)))
        {
            return false;
        }

        region = segments[1];
        channel = segments[4];

        if (string.IsNullOrWhiteSpace(region) ||
            string.IsNullOrWhiteSpace(channel) ||
            channel is "#" or "+")
        {
            return false;
        }

        label = $"{region}/{channel}";
        return true;
    }

    private static ListeningChannelEntry CreateListeningChannelEntry(string topicFilter)
    {
        if (TryGetChannelLabel(topicFilter, out var label, out _, out _))
        {
            return new ListeningChannelEntry
            {
                Label = label,
                TopicPattern = topicFilter
            };
        }

        return new ListeningChannelEntry
        {
            Label = topicFilter,
            TopicPattern = topicFilter
        };
    }

    private static string GetSenderDisplayName(MessageSummary message)
    {
        if (!string.IsNullOrWhiteSpace(message.FromNodeShortName))
        {
            return message.FromNodeShortName;
        }

        if (!string.IsNullOrWhiteSpace(message.FromNodeLongName))
        {
            return message.FromNodeLongName;
        }

        if (!string.IsNullOrWhiteSpace(message.FromNodeId))
        {
            return message.FromNodeId;
        }

        if (TryExtractTopicNodeId(message.Topic, out var topicNodeId))
        {
            return topicNodeId;
        }

        return "Unknown";
    }

    private static string GetTruncatedPreview(string payloadPreview)
    {
        if (string.IsNullOrWhiteSpace(payloadPreview))
        {
            return "(empty message)";
        }

        var normalized = payloadPreview.ReplaceLineEndings(" ").Trim();

        if (normalized.Length <= PreviewLength)
        {
            return normalized;
        }

        return $"{normalized[..PreviewLength]}...";
    }

    private void OpenMessagePreview(MessageSummary message)
    {
        _previewMessage = message;
    }

    private void CloseMessagePreview()
    {
        _previewMessage = null;
    }

    private void OpenNodeDetails(string nodeId)
    {
        _previewMessage = null;
        _selectedNodeId = nodeId;
    }

    private void OpenChannelDetails(string region, string channel)
    {
        _previewMessage = null;
        _selectedRegion = region;
        _selectedChannel = channel;
    }

    private Task CloseNodeDetails()
    {
        _selectedNodeId = null;
        return Task.CompletedTask;
    }

    private Task CloseChannelDetails()
    {
        _selectedRegion = null;
        _selectedChannel = null;
        return Task.CompletedTask;
    }

    private Task OpenChannelDetailsFromKeyAsync(string channelKey)
    {
        if (TrySplitChannelKey(channelKey, out var region, out var channel))
        {
            OpenChannelDetails(region, channel);
        }

        return Task.CompletedTask;
    }

    private Task OpenNodeDetailsFromModalAsync(string nodeId)
    {
        OpenNodeDetails(nodeId);
        return Task.CompletedTask;
    }

    private static bool TrySplitChannelKey(string channelKey, out string region, out string channel)
    {
        region = string.Empty;
        channel = string.Empty;

        if (string.IsNullOrWhiteSpace(channelKey))
        {
            return false;
        }

        var segments = channelKey.Split('/', 2, StringSplitOptions.TrimEntries);

        if (segments.Length != 2)
        {
            return false;
        }

        region = segments[0];
        channel = segments[1];

        return !string.IsNullOrWhiteSpace(region) && !string.IsNullOrWhiteSpace(channel);
    }

    private static bool TryExtractTopicNodeId(string topic, out string nodeId)
    {
        nodeId = string.Empty;

        if (string.IsNullOrWhiteSpace(topic))
        {
            return false;
        }

        var segments = topic.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (segments.Length == 0)
        {
            return false;
        }

        var last = segments[^1];
        if (!string.IsNullOrWhiteSpace(last) && last.StartsWith('!'))
        {
            nodeId = last;
            return true;
        }

        return false;
    }

    private sealed class MessageFilters
    {
        public string PacketType { get; set; } = string.Empty;

        public string SearchText { get; set; } = string.Empty;

        public MessageVisibilityFilter Visibility { get; set; } = MessageVisibilityFilter.All;
    }

    private sealed class ListeningChannelEntry
    {
        public required string Label { get; set; }

        public required string TopicPattern { get; set; }
    }

    private sealed class RefreshDelayOption
    {
        public required string Label { get; set; }

        public required int Seconds { get; set; }
    }
