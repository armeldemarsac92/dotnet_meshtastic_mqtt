@page "/channels/{Region}/{Channel}"

<PageTitle>Channel Details</PageTitle>

<div class="space-y-6">
    <a href="/channels"
       class="liquid-button inline-flex cursor-pointer items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">
        Back to channels
    </a>

    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Cutover</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Legacy channel details retired</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            The server-rendered channel detail route for
            <code class="rounded-full bg-sand-100 px-3 py-1 text-xs">@Region / @Channel</code>
            is being removed in favor of browser-first channel projections and local live state.
        </p>
    </header>

    <section class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
        <article class="liquid-panel rounded-[1.6rem] p-6">
            <h2 class="font-display text-3xl text-cinder-950">Removed from the server route</h2>
            <ul class="mt-5 list-disc space-y-2 pl-5 text-cinder-800/84">
                <li>Server-side channel summary, top-node, and message detail views.</li>
                <li>Inline subscribe or unsubscribe actions backed by the legacy runtime.</li>
                <li>Preset editing and notifier-driven refresh for channel detail pages.</li>
            </ul>
        </article>

        <article class="liquid-panel rounded-[1.6rem] p-6">
            <h2 class="font-display text-3xl text-cinder-950">Cutover status</h2>
            <p class="mt-4 text-cinder-800/82">
                Use the browser-first client for channel details. This server route remains only as a migration marker.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a href="/channels" class="liquid-button inline-flex items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">Channels</a>
                <a href="/messages" class="liquid-button inline-flex items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">Messages</a>
            </div>
        </article>
    </section>
</div>

@code {
    [Parameter]
    public string Region { get; set; } = string.Empty;

    [Parameter]
    public string Channel { get; set; } = string.Empty;
}
