@page "/channels/{Region}/{Channel}"
@inject IBrokerMonitorService BrokerMonitorService
@inject IMessageService MessageService

<PageTitle>Channel Details</PageTitle>

<div class="space-y-6">
    <a href="/channels"
       class="liquid-button inline-flex cursor-pointer items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">
        Back to channels
    </a>

    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Channel</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">@Region / @Channel</h1>
        </div>
        <p class="max-w-3xl text-base leading-8 text-cinder-800">
            Details and traffic statistics for this channel based on recent persisted Meshtastic packets.
        </p>
    </header>

    <section class="liquid-panel rounded-[1.6rem] p-5">
        <div class="flex flex-wrap items-center gap-2">
            <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@TopicFilter</code>
            <button type="button"
                    class="liquid-button cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] @(IsSubscribed ? "liquid-button-active" : "liquid-button-accent")"
                    @onclick="ToggleSubscriptionAsync">
                @(IsSubscribed ? "Unsubscribe" : "Subscribe")
            </button>
        </div>
        @if (!string.IsNullOrWhiteSpace(_statusMessage))
        {
            <p class="mt-3 text-sm text-cinder-800/82">@_statusMessage</p>
        }
    </section>

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        <article class="liquid-subpanel rounded-[1.4rem] p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Packets</p>
            <strong class="mt-2 block text-3xl text-cinder-950">@_channelMessages.Count</strong>
        </article>
        <article class="liquid-subpanel rounded-[1.4rem] p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Unique senders</p>
            <strong class="mt-2 block text-3xl text-cinder-950">@_uniqueSenderCount</strong>
        </article>
        <article class="liquid-subpanel rounded-[1.4rem] p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Decoded ratio</p>
            <strong class="mt-2 block text-3xl text-cinder-950">@_decodedRatio%</strong>
        </article>
        <article class="liquid-subpanel rounded-[1.4rem] p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Last seen</p>
            <strong class="mt-2 block text-sm text-cinder-950">@(_lastSeenAtUtc?.ToString("u") ?? "Unknown")</strong>
        </article>
    </section>

    <section class="grid gap-4 xl:grid-cols-2">
        <article class="liquid-panel overflow-hidden rounded-[1.6rem]">
            <div class="border-b border-sand-100/80 px-5 py-4">
                <h2 class="font-display text-3xl text-cinder-950">Top nodes</h2>
            </div>
            @if (_topNodes.Count == 0)
            {
                <div class="p-6 text-cinder-800/78">No traffic observed for this channel yet.</div>
            }
            else
            {
                <table class="min-w-full border-collapse">
                    <thead class="liquid-table-head">
                        <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                            <th class="px-5 py-4">Node</th>
                            <th class="px-5 py-4">Packets</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var topNode in _topNodes)
                        {
                            <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                                <td class="px-5 py-4">
                                    <a href="@GetNodeDetailsHref(topNode.NodeId)" class="liquid-inline-action rounded-full px-3 py-1 text-xs font-semibold">@topNode.NodeId</a>
                                </td>
                                <td class="px-5 py-4">@topNode.PacketCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </article>

        <article class="liquid-panel overflow-hidden rounded-[1.6rem]">
            <div class="border-b border-sand-100/80 px-5 py-4">
                <h2 class="font-display text-3xl text-cinder-950">Recent messages</h2>
            </div>
            @if (_channelMessages.Count == 0)
            {
                <div class="p-6 text-cinder-800/78">No recent messages for this channel.</div>
            }
            else
            {
                <ul class="space-y-3 p-5 text-sm text-cinder-900">
                    @foreach (var message in _channelMessages.Take(25))
                    {
                        <li class="liquid-subpanel rounded-2xl p-3">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="rounded-full bg-sand-100 px-3 py-1 text-xs">@message.PacketType</span>
                                <span class="text-xs text-cinder-800/70">@message.ReceivedAtUtc.ToString("u")</span>
                            </div>
                            <p class="mt-2">@message.PayloadPreview</p>
                            <p class="mt-1 text-xs text-cinder-800/70">From @message.FromNodeId to @(message.ToNodeId ?? "Broadcast")</p>
                        </li>
                    }
                </ul>
            }
        </article>
    </section>
</div>

@code {
    [Parameter]
    public string Channel { get; set; } = string.Empty;

    [Parameter]
    public string Region { get; set; } = string.Empty;

    private IReadOnlyCollection<MessageSummary> _channelMessages = [];
    private int _decodedRatio;
    private DateTimeOffset? _lastSeenAtUtc;
    private string? _statusMessage;
    private IReadOnlyCollection<TopNodeEntry> _topNodes = [];
    private int _uniqueSenderCount;

    private string TopicFilter => $"msh/{Region}/2/e/{Channel}/#";

    private bool IsSubscribed => BrokerMonitorService.GetBrokerStatus().TopicFilters.Contains(TopicFilter, StringComparer.Ordinal);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var messages = await MessageService.GetRecentMessages(5_000);

        _channelMessages = messages
            .Where(message => IsTopicInChannel(message.Topic, Region, Channel))
            .OrderByDescending(message => message.ReceivedAtUtc)
            .ToList();

        _uniqueSenderCount = _channelMessages
            .Select(message => message.FromNodeId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

        _lastSeenAtUtc = _channelMessages.FirstOrDefault()?.ReceivedAtUtc;
        _decodedRatio = _channelMessages.Count == 0
            ? 0
            : (int)Math.Round(
                _channelMessages.Count(IsDecodedMessage) * 100d / _channelMessages.Count,
                MidpointRounding.AwayFromZero);

        _topNodes = _channelMessages
            .GroupBy(message => message.FromNodeId, StringComparer.OrdinalIgnoreCase)
            .Select(group => new TopNodeEntry { NodeId = group.Key, PacketCount = group.Count() })
            .OrderByDescending(entry => entry.PacketCount)
            .Take(12)
            .ToList();
    }

    private async Task ToggleSubscriptionAsync()
    {
        try
        {
            if (IsSubscribed)
            {
                await BrokerMonitorService.UnsubscribeFromTopic(TopicFilter);
                _statusMessage = $"Unsubscribed from {TopicFilter}.";
            }
            else
            {
                await BrokerMonitorService.SubscribeToTopic(TopicFilter);
                _statusMessage = $"Subscribed to {TopicFilter}.";
            }
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    private static bool IsDecodedMessage(MessageSummary message)
    {
        return message.PacketType is not ("Encrypted Packet" or "Unknown Packet" or "Legacy Packet");
    }

    private static bool IsTopicInChannel(string topic, string region, string channel)
    {
        if (string.IsNullOrWhiteSpace(topic))
        {
            return false;
        }

        var segments = topic.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (segments.Length < 5 ||
            !string.Equals(segments[0], "msh", StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(segments[1], region, StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(segments[4], channel, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        return string.Equals(segments[3], "e", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(segments[3], "json", StringComparison.OrdinalIgnoreCase);
    }

    private static string GetNodeDetailsHref(string nodeId)
    {
        return $"/nodes/details/{Uri.EscapeDataString(nodeId)}";
    }

    private sealed class TopNodeEntry
    {
        public required string NodeId { get; set; }

        public int PacketCount { get; set; }
    }
}
