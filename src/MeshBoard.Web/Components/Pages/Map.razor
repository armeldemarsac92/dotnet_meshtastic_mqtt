@page "/map"
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject INodeService NodeService
@inject IWorkspaceContextAccessor WorkspaceContextAccessor
@inject ProjectionChangeNotifier ProjectionChangeNotifier

<PageTitle>Map</PageTitle>

<div class="flex h-[calc(100dvh-3rem)] min-h-0 flex-col gap-4 sm:h-[calc(100dvh-4rem)] lg:h-[calc(100dvh-5rem)]">
    <header class="space-y-2">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Geospatial view</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Node map</h1>
        </div>
        <p class="max-w-5xl text-sm leading-7 text-cinder-800 sm:text-base">
            Browse all observed nodes on a 3D globe. Click a node to open details, hover to reveal its shared-channel cohort, and watch for echo rings when traffic is heard.
        </p>
    </header>

    <section class="liquid-panel grid shrink-0 gap-4 overflow-hidden rounded-[1.6rem] p-5 lg:grid-cols-[1.4fr_auto_1fr]">
        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Search on map</span>
            <input @bind="_searchText"
                   @bind:event="oninput"
                   @bind:after="ScheduleSearchRefreshAsync"
                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                   placeholder="Node id, short name, long name, or channel" />
        </label>

        <div class="flex items-end">
            <button type="button"
                    class="liquid-button liquid-button-accent cursor-pointer rounded-full px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                    @onclick="RefreshNodesAsync"
                    disabled="@_isLoading">
                @(_isLoading ? "Refreshing..." : "Refresh map")
            </button>
        </div>

        <div class="space-y-3 self-end text-sm text-cinder-800/82">
            <p>@GetMapSummaryText()</p>
            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <p class="text-xs text-cinder-800/72">@_statusMessage</p>
            }

            <div class="space-y-2">
                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-cinder-800/62">Visible channels</p>

                @if (_channelLegendEntries.Count == 0)
                {
                    <p class="text-xs text-cinder-800/70">No visible channel cohort in the current view.</p>
                }
                else
                {
                    <div class="flex flex-wrap gap-2">
                        @foreach (var entry in _channelLegendEntries)
                        {
                            <button type="button"
                                    class="inline-flex cursor-pointer items-center gap-2 rounded-full border border-sand-300/80 bg-sand-100/70 px-3 py-1 text-[0.72rem] font-medium text-cinder-900"
                                    @onclick="() => OpenChannelDetailsAsync(entry.Channel)">
                                <span class="h-2.5 w-2.5 rounded-full ring-1 ring-cinder-950/20"
                                      style="background-color:@entry.ColorCss"></span>
                                <span>@entry.Channel</span>
                                <span class="text-cinder-700/75">@entry.NodeCount</span>
                            </button>
                        }
                    </div>

                    @if (_hiddenChannelLegendCount > 0)
                    {
                        <p class="text-[0.72rem] text-cinder-800/68">+ @_hiddenChannelLegendCount more channel cohorts in view.</p>
                    }
                }
            </div>

            <p class="text-[0.72rem] text-cinder-800/64">
                Hover links show shared-channel cohorts, not proven radio paths.
            </p>
        </div>
    </section>

    <section class="liquid-panel min-h-0 flex-1 overflow-hidden rounded-[1.6rem] p-4">
        <div id="@MapElementId"
             class="meshboard-node-map h-full w-full overflow-hidden rounded-[1.25rem] border border-sand-200/80"></div>
    </section>
</div>

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetailsAsync"
                  OnOpenChannel="OpenChannelDetailsAsync" />

<ChannelDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedRegion) && !string.IsNullOrWhiteSpace(_selectedChannel))"
                     Region="@(_selectedRegion ?? string.Empty)"
                     Channel="@(_selectedChannel ?? string.Empty)"
                     OnClose="CloseChannelDetailsAsync"
                     OnOpenNode="OpenNodeDetailsAsync" />

@code {
    private const string MapElementId = "meshboard-node-map";
    private readonly CancellationTokenSource _componentCancellationTokenSource = new();
    private DotNetObjectReference<Map>? _mapCallbackReference;
    private bool _isLoading;
    private bool _isMapRenderPending;
    private IJSObjectReference? _mapModule;
    private int _locatedNodeCount;
    private readonly Dictionary<string, int> _pendingActivityPulseCounts = new(StringComparer.Ordinal);
    private IReadOnlyCollection<MapNodeActivity> _activityPulses = [];
    private IReadOnlyCollection<ChannelLegendEntry> _channelLegendEntries = [];
    private int _hiddenChannelLegendCount;
    private bool _shouldFitMapToNodes = true;
    private int _refreshRequestVersion;
    private CancellationTokenSource? _realtimeRefreshDebounceCancellationTokenSource;
    private CancellationTokenSource? _searchDebounceCancellationTokenSource;
    private string _searchText = string.Empty;
    private string? _selectedChannel;
    private string? _selectedNodeId;
    private string? _selectedRegion;
    private string? _statusMessage;
    private IReadOnlyCollection<NodeSummary> _nodesWithLocation = [];
    private IReadOnlyCollection<MapNodePoint> _visibleMapNodes = [];

    protected override async Task OnInitializedAsync()
    {
        ProjectionChangeNotifier.Changed += HandleProjectionChangedAsync;
        await RefreshNodesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isMapRenderPending = true;
        }

        if (_isMapRenderPending)
        {
            _isMapRenderPending = false;
            await RenderMapAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        ProjectionChangeNotifier.Changed -= HandleProjectionChangedAsync;
        _componentCancellationTokenSource.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();
        _searchDebounceCancellationTokenSource?.Cancel();
        _searchDebounceCancellationTokenSource?.Dispose();
        _mapCallbackReference?.Dispose();

        if (_mapModule is null)
        {
            _componentCancellationTokenSource.Dispose();
            return;
        }

        try
        {
            await _mapModule.InvokeVoidAsync("disposeNodeMap", MapElementId);
            await _mapModule.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        finally
        {
            _componentCancellationTokenSource.Dispose();
        }
    }

    [JSInvokable]
    public async Task OnNodeSelectedFromMap(string nodeId)
    {
        _selectedNodeId = nodeId;
        await InvokeAsync(StateHasChanged);
    }

    private Task HandleProjectionChangedAsync(ProjectionChangeEvent change)
    {
        if (!IsRelevantProjectionChange(change))
        {
            return Task.CompletedTask;
        }

        if (!string.IsNullOrWhiteSpace(change.EntityKey))
        {
            _pendingActivityPulseCounts.TryGetValue(change.EntityKey, out var pulseCount);
            _pendingActivityPulseCounts[change.EntityKey] = pulseCount + 1;
        }

        return ScheduleRealtimeRefreshAsync();
    }

    private bool IsRelevantProjectionChange(ProjectionChangeEvent change)
    {
        return string.Equals(change.WorkspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal) &&
            change.Kind == ProjectionChangeKind.NodeUpdated;
    }

    private async Task ScheduleRealtimeRefreshAsync()
    {
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_componentCancellationTokenSource.Token);
        _realtimeRefreshDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(300), debounceCancellationTokenSource.Token);
            await RefreshNodesAsync(fitMapToNodes: false);
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_realtimeRefreshDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _realtimeRefreshDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

    private async Task ScheduleSearchRefreshAsync()
    {
        _searchDebounceCancellationTokenSource?.Cancel();
        _searchDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_componentCancellationTokenSource.Token);
        _searchDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(250), debounceCancellationTokenSource.Token);
            await RefreshNodesAsync();
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_searchDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _searchDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

    private async Task CloseChannelDetailsAsync()
    {
        _selectedRegion = null;
        _selectedChannel = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseNodeDetailsAsync()
    {
        _selectedNodeId = null;
        await InvokeAsync(StateHasChanged);
    }

    private Task OpenNodeDetailsAsync(string nodeId)
    {
        _selectedNodeId = nodeId;
        return InvokeAsync(StateHasChanged);
    }

    private Task OpenChannelDetailsAsync(string channelKey)
    {
        if (!TrySplitChannelKey(channelKey, out var region, out var channel))
        {
            return Task.CompletedTask;
        }

        _selectedRegion = region;
        _selectedChannel = channel;
        return InvokeAsync(StateHasChanged);
    }

    private async Task RefreshNodesAsync()
    {
        await RefreshNodesAsync(fitMapToNodes: true);
    }

    private async Task RefreshNodesAsync(bool fitMapToNodes)
    {
        var requestVersion = ++_refreshRequestVersion;
        var normalizedSearchText = _searchText.Trim();
        _isLoading = true;
        _statusMessage = null;

        try
        {
            var nodes = await NodeService.GetLocatedNodes(
                normalizedSearchText,
                cancellationToken: _componentCancellationTokenSource.Token);

            if (requestVersion != _refreshRequestVersion)
            {
                return;
            }

            _nodesWithLocation = nodes;
            _locatedNodeCount = _nodesWithLocation.Count;
            ApplyMapPoints();
            _shouldFitMapToNodes = fitMapToNodes;
            _activityPulses = _pendingActivityPulseCounts.Count == 0
                ? []
                : _pendingActivityPulseCounts
                    .Select(entry => new MapNodeActivity
                    {
                        NodeId = entry.Key,
                        PulseCount = entry.Value
                    })
                    .ToList();
            _pendingActivityPulseCounts.Clear();
            _statusMessage = string.IsNullOrWhiteSpace(normalizedSearchText)
                ? $"Loaded {_locatedNodeCount} nodes with coordinates."
                : $"Loaded {_locatedNodeCount} matching nodes with coordinates.";
        }
        catch (OperationCanceledException) when (_componentCancellationTokenSource.IsCancellationRequested)
        {
        }
        catch (Exception exception)
        {
            if (requestVersion != _refreshRequestVersion)
            {
                return;
            }

            _nodesWithLocation = [];
            _visibleMapNodes = [];
            _locatedNodeCount = 0;
            _activityPulses = [];
            _channelLegendEntries = [];
            _hiddenChannelLegendCount = 0;
            _statusMessage = $"Map load failed: {exception.Message}";
            _isMapRenderPending = true;
        }
        finally
        {
            if (requestVersion == _refreshRequestVersion)
            {
                _isLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void ApplyMapPoints()
    {
        _visibleMapNodes = _nodesWithLocation
            .Where(node => node.LastKnownLatitude.HasValue && node.LastKnownLongitude.HasValue)
            .Select(node => new MapNodePoint
            {
                NodeId = node.NodeId,
                DisplayName = node.LongName ?? node.ShortName ?? node.NodeId,
                Channel = node.LastHeardChannel,
                Latitude = node.LastKnownLatitude!.Value,
                Longitude = node.LastKnownLongitude!.Value,
                BatteryLevelPercent = node.BatteryLevelPercent
            })
            .ToList();

        ApplyChannelLegend();
        _isMapRenderPending = true;
    }

    private void ApplyChannelLegend()
    {
        var channelEntries = _visibleMapNodes
            .Where(node => !string.IsNullOrWhiteSpace(node.Channel))
            .GroupBy(node => node.Channel!, StringComparer.Ordinal)
            .Select(group => new ChannelLegendEntry
            {
                Channel = group.Key,
                ColorCss = GetChannelColorCss(group.Key),
                NodeCount = group.Count()
            })
            .OrderByDescending(entry => entry.NodeCount)
            .ThenBy(entry => entry.Channel, StringComparer.Ordinal)
            .ToList();

        const int maxVisibleLegendEntries = 8;
        _channelLegendEntries = channelEntries.Take(maxVisibleLegendEntries).ToList();
        _hiddenChannelLegendCount = Math.Max(channelEntries.Count - maxVisibleLegendEntries, 0);
    }

    private async Task RenderMapAsync()
    {
        _mapModule ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/node-map.js");
        _mapCallbackReference ??= DotNetObjectReference.Create(this);

        await _mapModule.InvokeVoidAsync(
            "renderNodeMap",
            MapElementId,
            _visibleMapNodes,
            _activityPulses,
            _shouldFitMapToNodes,
            _mapCallbackReference);

        _activityPulses = [];
        _shouldFitMapToNodes = false;
    }

    private static bool TrySplitChannelKey(string channelKey, out string region, out string channel)
    {
        region = string.Empty;
        channel = string.Empty;

        if (string.IsNullOrWhiteSpace(channelKey))
        {
            return false;
        }

        var segments = channelKey.Split('/', 2, StringSplitOptions.TrimEntries);

        if (segments.Length != 2)
        {
            return false;
        }

        region = segments[0];
        channel = segments[1];
        return !string.IsNullOrWhiteSpace(region) && !string.IsNullOrWhiteSpace(channel);
    }

    private string GetMapSummaryText()
    {
        return string.IsNullOrWhiteSpace(_searchText)
            ? $"Showing {_visibleMapNodes.Count} located nodes."
            : $"Showing {_visibleMapNodes.Count} matching located nodes.";
    }

    private static string GetChannelColorCss(string channel)
    {
        if (string.IsNullOrWhiteSpace(channel))
        {
            return "#6bb6ef";
        }

        var hash = 0;

        foreach (var character in channel)
        {
            hash = ((hash << 5) - hash) + character;
        }

        var hue = Math.Abs(hash % 360);
        return $"hsl({hue} 72% 58%)";
    }

    private sealed class ChannelLegendEntry
    {
        public required string Channel { get; set; }

        public required string ColorCss { get; set; }

        public required int NodeCount { get; set; }
    }

    private sealed class MapNodeActivity
    {
        [System.Text.Json.Serialization.JsonPropertyName("nodeId")]
        public required string NodeId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("pulseCount")]
        public required int PulseCount { get; set; }
    }

    private sealed class MapNodePoint
    {
        [System.Text.Json.Serialization.JsonPropertyName("nodeId")]
        public required string NodeId { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("displayName")]
        public required string DisplayName { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("channel")]
        public string? Channel { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("latitude")]
        public required double Latitude { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("longitude")]
        public required double Longitude { get; set; }

        [System.Text.Json.Serialization.JsonPropertyName("batteryLevelPercent")]
        public int? BatteryLevelPercent { get; set; }
    }
}
