@page "/"
@implements IAsyncDisposable
@inject IBrokerMonitorService BrokerMonitorService
@inject IFavoriteNodeService FavoriteNodeService
@inject IMessageService MessageService
@inject INodeService NodeService
@inject IOptions<BrokerOptions> BrokerConfiguration
@inject IOptions<PersistenceOptions> PersistenceConfiguration
@inject ITopicPresetService TopicPresetService

<PageTitle>Dashboard</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Foundation</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Dependency-inverted Blazor shell</h1>
        </div>
        <p class="max-w-3xl text-base leading-8 text-cinder-800">
            The app now has real SQLite persistence, live MQTT ingestion, and protobuf decoding for key Meshtastic
            packet types. Current hardening work is focused on retention, diagnostics, and send-path safety.
        </p>
    </header>

    @if (_isLoading)
    {
        <section class="liquid-panel rounded-[1.6rem] p-6">
            <p class="text-cinder-800/80">Loading the application shell...</p>
        </section>
    }
    else
    {
        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Broker</p>
                <strong class="mt-3 block text-lg text-cinder-950">@_brokerStatus.Host:@_brokerStatus.Port</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@(_brokerStatus.IsConnected ? "Connected to MQTT" : "Broker offline")</span>
                @if (!string.IsNullOrWhiteSpace(_brokerStatus.LastStatusMessage))
                {
                    <span class="mt-3 block text-xs leading-6 text-cinder-800/70">@_brokerStatus.LastStatusMessage</span>
                }
            </article>
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Persistence</p>
                <strong class="mt-3 block text-lg text-cinder-950">@PersistenceConfiguration.Value.Provider</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@(_favoriteNodes.Count) favorites saved</span>
            </article>
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Subscriptions</p>
                <strong class="mt-3 block text-lg text-cinder-950">@_brokerStatus.TopicFilters.Count</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@(_topicPresets.Count) saved presets</span>
            </article>
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Activity</p>
                <strong class="mt-3 block text-lg text-cinder-950">@(_messages.Count) packets</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@_observedNodeCount observed nodes</span>
            </article>
        </section>

        <section class="grid gap-4 xl:grid-cols-2">
            <article class="liquid-panel rounded-[1.6rem] p-6">
                <h2 class="font-display text-3xl text-cinder-950">Active topic filters</h2>
                @if (_brokerStatus.TopicFilters.Count == 0)
                {
                    <p class="mt-4 text-cinder-800/78">No topic filters are currently subscribed.</p>
                }
                else
                {
                    <ul class="mt-4 space-y-3 text-cinder-800/85">
                        @foreach (var topicFilter in _brokerStatus.TopicFilters)
                        {
                            <li>
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@topicFilter</code>
                            </li>
                        }
                    </ul>
                }
            </article>

            <article class="liquid-panel rounded-[1.6rem] p-6">
                <h2 class="font-display text-3xl text-cinder-950">Current slice</h2>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-cinder-800/85">
                    <li>MQTT connects on startup and subscribes to the default Meshtastic topic.</li>
                    <li>Incoming packets are decoded and persisted into SQLite through application services.</li>
                    <li>The dashboard, nodes, and messages views refresh every 3 seconds.</li>
                    <li>Current hardening adds retention controls and richer integration-test coverage.</li>
                </ul>
            </article>
        </section>
    }
</div>

@code {
    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private BrokerStatus _brokerStatus = new();
    private IReadOnlyCollection<FavoriteNode> _favoriteNodes = [];
    private bool _isLoading = true;
    private IReadOnlyCollection<MessageSummary> _messages = [];
    private int _observedNodeCount;
    private Task? _refreshTask;
    private IReadOnlyCollection<TopicPreset> _topicPresets = [];

    protected override async Task OnInitializedAsync()
    {
        await BrokerMonitorService.EnsureConnected();
        await LoadAsync();
        _isLoading = false;
        _refreshTask = RefreshAsync(_cancellationTokenSource.Token);
    }

    public async ValueTask DisposeAsync()
    {
        _cancellationTokenSource.Cancel();

        if (_refreshTask is not null)
        {
            try
            {
                await _refreshTask;
            }
            catch (OperationCanceledException)
            {
            }
        }

        _cancellationTokenSource.Dispose();
    }

    private async Task LoadAsync()
    {
        _brokerStatus = BrokerMonitorService.GetBrokerStatus();
        _topicPresets = await TopicPresetService.GetTopicPresets();
        _favoriteNodes = await FavoriteNodeService.GetFavoriteNodes();
        _observedNodeCount = (await NodeService.GetNodesPage(offset: 0, take: 1)).TotalCount;
        _messages = await MessageService.GetRecentMessages();
    }

    private async Task RefreshAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));

        while (await timer.WaitForNextTickAsync(cancellationToken))
        {
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
    }
}
