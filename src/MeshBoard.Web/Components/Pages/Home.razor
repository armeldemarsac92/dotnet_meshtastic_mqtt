@page "/"
@implements IAsyncDisposable
@inject IBrokerMonitorService BrokerMonitorService
@inject IFavoriteNodeService FavoriteNodeService
@inject IHomeDashboardService HomeDashboardService
@inject IMessageService MessageService
@inject INodeService NodeService
@inject IWorkspaceContextAccessor WorkspaceContextAccessor
@inject IOptions<PersistenceOptions> PersistenceConfiguration
@inject ProjectionChangeNotifier ProjectionChangeNotifier
@inject ServerSelectionNotifier ServerSelectionNotifier

<PageTitle>Dashboard</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Overview</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Live Meshtastic dashboard</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            Track broker status, subscriptions, traffic, and nodes in one place. Use Topics to subscribe and Messages
            or Nodes to inspect live activity.
        </p>
    </header>

    @if (_isLoading)
    {
        <section class="liquid-panel rounded-[1.6rem] p-6">
            <p class="text-cinder-800/80">Loading the application shell...</p>
        </section>
    }
    else
    {
        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Broker</p>
                <strong class="mt-3 block text-lg text-cinder-950">@_brokerStatus.Host:@_brokerStatus.Port</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@(_brokerStatus.IsConnected ? "Connected to MQTT" : "Broker offline")</span>
                <span class="mt-2 block text-sm text-cinder-800/78">Queue @_brokerStatus.InboundQueueDepth/@_brokerStatus.InboundQueueCapacity, dropped @_brokerStatus.InboundDroppedCount</span>
                @if (!string.IsNullOrWhiteSpace(_brokerStatus.LastStatusMessage))
                {
                    <span class="mt-3 block text-xs leading-6 text-cinder-800/70">@_brokerStatus.LastStatusMessage</span>
                }
            </article>
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Persistence</p>
                <strong class="mt-3 block text-lg text-cinder-950">@PersistenceConfiguration.Value.Provider</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@(_favoriteNodes.Count) favorites saved</span>
            </article>
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Subscriptions</p>
                <strong class="mt-3 block text-lg text-cinder-950">@_brokerStatus.TopicFilters.Count</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@(_topicPresets.Count) saved presets</span>
            </article>
            <article class="liquid-panel rounded-[1.6rem] p-5">
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Activity</p>
                <strong class="mt-3 block text-lg text-cinder-950">@(_messages.Count) packets</strong>
                <span class="mt-2 block text-sm text-cinder-800/78">@_observedNodeCount observed nodes</span>
            </article>
        </section>

        <section class="grid gap-4 xl:grid-cols-2">
            <article class="liquid-panel rounded-[1.6rem] p-6">
                <h2 class="font-display text-3xl text-cinder-950">Active topic filters</h2>
                @if (_brokerStatus.TopicFilters.Count == 0)
                {
                    <p class="mt-4 text-cinder-800/78">No topic filters are currently subscribed.</p>
                }
                else
                {
                    <ul class="mt-4 space-y-3 text-cinder-800/85">
                        @foreach (var topicFilter in _brokerStatus.TopicFilters)
                        {
                            <li>
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@topicFilter</code>
                            </li>
                        }
                    </ul>
                }
            </article>

            <article class="liquid-panel rounded-[1.6rem] p-6">
                <h2 class="font-display text-3xl text-cinder-950">What you can do</h2>
                <ul class="mt-4 list-disc space-y-3 pl-5 text-cinder-800/85">
                    <li>Connect to the public Meshtastic MQTT broker.</li>
                    <li>Subscribe to channels and monitor recent packets.</li>
                    <li>Browse discovered nodes and their latest telemetry.</li>
                    <li>Save favorites and presets for faster follow-up.</li>
                </ul>
            </article>
        </section>
    }
</div>

@code {
    private static readonly TimeSpan FallbackRefreshInterval = TimeSpan.FromSeconds(30);
    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private BrokerStatus _brokerStatus = new();
    private IReadOnlyCollection<FavoriteNode> _favoriteNodes = [];
    private bool _isLoading = true;
    private IReadOnlyCollection<MessageSummary> _messages = [];
    private int _observedNodeCount;
    private bool _pendingBrokerStatusRefresh;
    private bool _pendingFavoritesRefresh;
    private bool _pendingMessagesRefresh;
    private bool _pendingObservedNodeCountRefresh;
    private CancellationTokenSource? _realtimeRefreshDebounceCancellationTokenSource;
    private Task? _refreshTask;
    private IReadOnlyCollection<TopicPreset> _topicPresets = [];

    protected override async Task OnInitializedAsync()
    {
        ProjectionChangeNotifier.Changed += HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed += HandleServerSelectionChangedAsync;
        await BrokerMonitorService.EnsureConnected(_cancellationTokenSource.Token);
        await LoadAsync(_cancellationTokenSource.Token);
        _isLoading = false;
        _refreshTask = RefreshAsync(_cancellationTokenSource.Token);
    }

    public ValueTask DisposeAsync()
    {
        ProjectionChangeNotifier.Changed -= HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed -= HandleServerSelectionChangedAsync;
        _cancellationTokenSource.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();
        _cancellationTokenSource.Dispose();
        return ValueTask.CompletedTask;
    }

    private async Task LoadAsync(CancellationToken cancellationToken, bool forceRefresh = false)
    {
        var snapshot = await HomeDashboardService.GetSnapshot(forceRefresh, cancellationToken);

        _brokerStatus = snapshot.BrokerStatus;
        _topicPresets = snapshot.TopicPresets;
        _favoriteNodes = snapshot.FavoriteNodes;
        _observedNodeCount = snapshot.ObservedNodeCount;
        _messages = snapshot.Messages;
    }

    private async Task RefreshAsync(CancellationToken cancellationToken)
    {
        try
        {
            using var timer = new PeriodicTimer(FallbackRefreshInterval);

            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await LoadAsync(cancellationToken);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
    }

    private Task HandleServerSelectionChangedAsync()
    {
        return ScheduleRealtimeRefreshAsync(forceRefresh: true);
    }

    private Task HandleProjectionChangedAsync(ProjectionChangeEvent change)
    {
        if (!string.Equals(change.WorkspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal))
        {
            return Task.CompletedTask;
        }

        switch (change.Kind)
        {
            case ProjectionChangeKind.MessageAdded:
                _pendingMessagesRefresh = true;
                return ScheduleRealtimeRefreshAsync();
            case ProjectionChangeKind.NodeUpdated:
                _pendingObservedNodeCountRefresh = true;
                return ScheduleRealtimeRefreshAsync();
            case ProjectionChangeKind.FavoriteNodesChanged:
                _pendingFavoritesRefresh = true;
                return ScheduleRealtimeRefreshAsync();
            case ProjectionChangeKind.RuntimeStatusChanged:
                _pendingBrokerStatusRefresh = true;
                return ScheduleRealtimeRefreshAsync();
            default:
                return Task.CompletedTask;
        }
    }

    private async Task ScheduleRealtimeRefreshAsync(bool forceRefresh = false)
    {
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_cancellationTokenSource.Token);
        _realtimeRefreshDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(300), debounceCancellationTokenSource.Token);
            if (forceRefresh)
            {
                _pendingBrokerStatusRefresh = false;
                _pendingFavoritesRefresh = false;
                _pendingMessagesRefresh = false;
                _pendingObservedNodeCountRefresh = false;
                await LoadAsync(debounceCancellationTokenSource.Token, true);
            }
            else
            {
                await ApplyPushUpdatesAsync(debounceCancellationTokenSource.Token);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_realtimeRefreshDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _realtimeRefreshDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

    private async Task ApplyPushUpdatesAsync(CancellationToken cancellationToken)
    {
        if (_pendingBrokerStatusRefresh)
        {
            _brokerStatus = BrokerMonitorService.GetBrokerStatus();
            _pendingBrokerStatusRefresh = false;
        }

        if (_pendingFavoritesRefresh)
        {
            _favoriteNodes = await FavoriteNodeService.GetFavoriteNodes(cancellationToken);
            _pendingFavoritesRefresh = false;
        }

        if (_pendingMessagesRefresh)
        {
            _messages = await MessageService.GetRecentMessages(120, cancellationToken);
            _pendingMessagesRefresh = false;
        }

        if (_pendingObservedNodeCountRefresh)
        {
            _observedNodeCount = await NodeService.CountNodes(cancellationToken: cancellationToken);
            _pendingObservedNodeCountRefresh = false;
        }
    }
}
