@page "/nodes/details/{NodeId}"

<PageTitle>Node Details</PageTitle>

<div class="space-y-6">
    <a href="/nodes"
       class="liquid-button inline-flex cursor-pointer items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">
        Back to nodes
    </a>

    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Cutover</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Legacy node details retired</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            The server-rendered node detail route for
            <code class="rounded-full bg-sand-100 px-3 py-1 text-xs">@NodeId</code>
            is being removed in favor of browser-first node projections and client-side detail views.
        </p>
    </header>

    <section class="grid gap-4 xl:grid-cols-[1.05fr_0.95fr]">
        <article class="liquid-panel rounded-[1.6rem] p-6">
            <h2 class="font-display text-3xl text-cinder-950">Removed from the server route</h2>
            <ul class="mt-5 list-disc space-y-2 pl-5 text-cinder-800/84">
                <li>Server-side node telemetry rendering and related message paging.</li>
                <li>Projection-driven refresh for direct node detail views.</li>
                <li>Map embed and channel cross-navigation owned by the legacy UI.</li>
            </ul>
        </article>

        <article class="liquid-panel rounded-[1.6rem] p-6">
            <h2 class="font-display text-3xl text-cinder-950">Cutover status</h2>
            <p class="mt-4 text-cinder-800/82">
                Use the browser-first client for node details. This server route remains only as a migration marker.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
                <a href="/nodes" class="liquid-button inline-flex items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">Nodes</a>
                <a href="/messages" class="liquid-button inline-flex items-center rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">Messages</a>
            </div>
        </article>
    </section>
</div>

@code {
    [Parameter]
    public string NodeId { get; set; } = string.Empty;
}
