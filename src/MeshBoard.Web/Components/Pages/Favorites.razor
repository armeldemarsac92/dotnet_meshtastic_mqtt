@page "/favorites"
@inject IFavoriteNodeService FavoriteNodeService

<PageTitle>Favorites</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Personal state</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Favorite nodes</h1>
        </div>
        <p class="max-w-3xl text-base leading-8 text-cinder-800">
            Favorites are user-specific state and belong behind a repository abstraction from day one. This keeps the
            eventual database swap isolated to infrastructure.
        </p>
    </header>

    <section class="overflow-hidden rounded-[1.6rem] border border-white/60 bg-white/72 shadow-panel backdrop-blur">
        @if (_favoriteNodes.Count == 0)
        {
            <div class="p-6 text-cinder-800/78">
                No favorite nodes are stored yet.
            </div>
        }
        else
        {
            <table class="min-w-full border-collapse">
                <thead class="bg-sand-50/80">
                    <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                        <th class="px-5 py-4">Node ID</th>
                        <th class="px-5 py-4">Short name</th>
                        <th class="px-5 py-4">Long name</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var favoriteNode in _favoriteNodes)
                    {
                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                            <td class="px-5 py-4"><code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@favoriteNode.NodeId</code></td>
                            <td class="px-5 py-4 font-medium">@(favoriteNode.ShortName ?? "-")</td>
                            <td class="px-5 py-4">@(favoriteNode.LongName ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private IReadOnlyCollection<FavoriteNode> _favoriteNodes = [];

    protected override async Task OnInitializedAsync()
    {
        _favoriteNodes = await FavoriteNodeService.GetFavoriteNodes();
    }
}
