@page "/favorites"
@implements IAsyncDisposable
@inject IFavoriteNodeService FavoriteNodeService
@inject IWorkspaceContextAccessor WorkspaceContextAccessor
@inject ProjectionChangeNotifier ProjectionChangeNotifier

<PageTitle>Favorites</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Personal state</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Favorite nodes</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            Keep important nodes in one list for quick access during monitoring sessions.
        </p>
    </header>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <p class="text-sm text-cinder-800/82">@_statusMessage</p>
    }

    <section class="liquid-panel overflow-hidden rounded-[1.6rem]">
        @if (_favoriteNodes.Count == 0)
        {
            <div class="p-6 text-cinder-800/78">
                No favorite nodes are stored yet.
            </div>
        }
        else
        {
            <table class="min-w-full border-collapse">
                <thead class="liquid-table-head">
                        <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                            <th class="px-5 py-4">Node ID</th>
                            <th class="px-5 py-4">Short name</th>
                            <th class="px-5 py-4">Long name</th>
                        <th class="px-5 py-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var favoriteNode in _favoriteNodes)
                    {
                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                            <td class="px-5 py-4">
                                <button type="button"
                                        class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-xs font-semibold"
                                        @onclick="() => OpenNodeDetails(favoriteNode.NodeId)">
                                    @favoriteNode.NodeId
                                </button>
                            </td>
                            <td class="px-5 py-4 font-medium">
                                @if (string.IsNullOrWhiteSpace(favoriteNode.ShortName))
                                {
                                    <span>-</span>
                                }
                                else
                                {
                                    <button type="button"
                                            class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-xs font-semibold"
                                            @onclick="() => OpenNodeDetails(favoriteNode.NodeId)">
                                        @favoriteNode.ShortName
                                    </button>
                                }
                            </td>
                            <td class="px-5 py-4">
                                @if (string.IsNullOrWhiteSpace(favoriteNode.LongName))
                                {
                                    <span>-</span>
                                }
                                else
                                {
                                    <button type="button"
                                            class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-xs font-semibold"
                                            @onclick="() => OpenNodeDetails(favoriteNode.NodeId)">
                                        @favoriteNode.LongName
                                    </button>
                                }
                            </td>
                            <td class="px-5 py-4">
                                <button @onclick="() => RemoveFavoriteAsync(favoriteNode.NodeId)"
                                        disabled="@(_pendingNodeId == favoriteNode.NodeId)"
                                        class="liquid-button liquid-button-danger rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60">
                                    Remove
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetails" />

@code {
    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private IReadOnlyCollection<FavoriteNode> _favoriteNodes = [];
    private string? _pendingNodeId;
    private CancellationTokenSource? _realtimeRefreshDebounceCancellationTokenSource;
    private string? _selectedNodeId;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        ProjectionChangeNotifier.Changed += HandleProjectionChangedAsync;
        await LoadAsync(_cancellationTokenSource.Token);
    }

    public ValueTask DisposeAsync()
    {
        ProjectionChangeNotifier.Changed -= HandleProjectionChangedAsync;
        _cancellationTokenSource.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();
        _cancellationTokenSource.Dispose();
        return ValueTask.CompletedTask;
    }

    private async Task LoadAsync(CancellationToken cancellationToken = default)
    {
        _favoriteNodes = await FavoriteNodeService.GetFavoriteNodes(cancellationToken);
    }

    private async Task RemoveFavoriteAsync(string nodeId)
    {
        _pendingNodeId = nodeId;
        _statusMessage = null;

        try
        {
            await FavoriteNodeService.RemoveFavoriteNode(nodeId);
            _statusMessage = $"Removed {nodeId} from favorites.";
            _favoriteNodes = _favoriteNodes
                .Where(favoriteNode => !string.Equals(favoriteNode.NodeId, nodeId, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }
        finally
        {
            _pendingNodeId = null;
        }
    }

    private void OpenNodeDetails(string nodeId)
    {
        _selectedNodeId = nodeId;
    }

    private Task CloseNodeDetails()
    {
        _selectedNodeId = null;
        return Task.CompletedTask;
    }

    private Task HandleProjectionChangedAsync(ProjectionChangeEvent change)
    {
        if (!string.Equals(change.WorkspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal) ||
            change.Kind != ProjectionChangeKind.FavoriteNodesChanged)
        {
            return Task.CompletedTask;
        }

        return ScheduleRealtimeRefreshAsync();
    }

    private async Task ScheduleRealtimeRefreshAsync()
    {
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_cancellationTokenSource.Token);
        _realtimeRefreshDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(300), debounceCancellationTokenSource.Token);
            await LoadAsync(debounceCancellationTokenSource.Token);
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_realtimeRefreshDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _realtimeRefreshDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

}
