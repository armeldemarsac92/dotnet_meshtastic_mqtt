@page "/topics"
@implements IAsyncDisposable
@using MeshBoard.Contracts.Configuration
@using MeshBoard.Contracts.Topics
@using MeshBoard.Web.State
@inject IBrokerMonitorService BrokerMonitorService
@inject IBrokerServerProfileService BrokerServerProfileService
@inject ITopicDiscoveryService TopicDiscoveryService
@inject ITopicExplorerService TopicExplorerService
@inject ITopicProbeService TopicProbeService
@inject ITopicPresetService TopicPresetService
@inject IWorkspaceContextAccessor WorkspaceContextAccessor
@inject ProjectionChangeNotifier ProjectionChangeNotifier
@inject ServerSelectionNotifier ServerSelectionNotifier

<PageTitle>Topics</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Subscriptions</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Topic explorer</h1>
        </div>
        <p class="max-w-5xl text-base leading-8 text-cinder-800">
            Choose the active MQTT server with tabs, manage server profiles, then subscribe to channels for the selected server.
        </p>
    </header>

    <section class="liquid-panel rounded-[1.6rem] p-5">
        <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
                <h2 class="font-display text-3xl text-cinder-950">Servers</h2>
                <p class="mt-2 text-xs leading-6 text-cinder-800/78">
                    Topic actions on this page apply to the currently active server.
                </p>
            </div>
            <div class="flex flex-wrap gap-2">
                <button type="button"
                        class="liquid-inline-action liquid-inline-action-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="OpenAddServerEditor">
                    Add server
                </button>
                <button type="button"
                        class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                        @onclick="OpenSelectedServerEditor"
                        disabled="@(_selectedServerProfile is null)">
                    Edit selected
                </button>
            </div>
        </div>

        @if (_isLoadingServerProfiles)
        {
            <p class="mt-4 text-cinder-800/78">Loading server profiles...</p>
        }
        else if (_serverProfiles.Count == 0)
        {
            <p class="mt-4 text-cinder-800/78">No server profiles yet. Add one to start listening.</p>
        }
        else
        {
            <div class="mt-4 flex flex-wrap gap-2">
                @foreach (var profile in _serverProfiles)
                {
                    <button type="button"
                            class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] @(_selectedServerProfile?.Id == profile.Id ? "liquid-inline-action-active" : "")"
                            @onclick="() => ActivateServerTabAsync(profile.Id)">
                        @profile.Name
                    </button>
                }
            </div>

            @if (_selectedServerProfile is not null)
            {
                <dl class="mt-4 grid gap-2 text-sm sm:grid-cols-[11rem_1fr]">
                    <dt class="text-cinder-800/70">Endpoint</dt>
                    <dd class="font-medium text-cinder-950">@_selectedServerProfile.ServerAddress</dd>
                    <dt class="text-cinder-800/70">Default topic</dt>
                    <dd class="font-medium text-cinder-950">
                        <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@_selectedServerProfile.DefaultTopicPattern</code>
                    </dd>
                    <dt class="text-cinder-800/70">Downlink</dt>
                    <dd class="font-medium text-cinder-950">
                        <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@_selectedServerProfile.DownlinkTopic</code>
                    </dd>
                </dl>
            }
        }

        @if (!string.IsNullOrWhiteSpace(_serverStatusMessage))
        {
            <p class="mt-4 text-sm text-cinder-800/82">@_serverStatusMessage</p>
        }

        @if (_showServerEditor)
        {
            <div class="mt-5 border-t border-sand-200/80 pt-4">
                <h3 class="font-display text-2xl text-cinder-950">@(_serverForm.Id.HasValue ? "Edit server" : "Add server")</h3>

                <div class="mt-4 grid gap-3 lg:grid-cols-2">
                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Name</span>
                        <InputText @bind-Value="_serverForm.Name"
                                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                   placeholder="Public Meshtastic" />
                    </label>

                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Host</span>
                        <InputText @bind-Value="_serverForm.Host"
                                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                   placeholder="mqtt.meshtastic.org" />
                    </label>

                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Port</span>
                        <InputNumber @bind-Value="_serverForm.Port"
                                     class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                     min="1"
                                     max="65535" />
                    </label>

                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Username</span>
                        <InputText @bind-Value="_serverForm.Username"
                                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                   placeholder="meshdev" />
                    </label>

                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Password</span>
                        <InputText @bind-Value="_serverForm.Password"
                                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                   placeholder="large4cats" />
                    </label>

                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Default topic</span>
                        <InputText @bind-Value="_serverForm.DefaultTopicPattern"
                                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                   placeholder="msh/US/2/e/#" />
                    </label>

                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Default channel key</span>
                        <InputText @bind-Value="_serverForm.DefaultEncryptionKeyBase64"
                                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                   placeholder="AQ==" />
                    </label>

                    <label class="space-y-2">
                        <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Downlink topic</span>
                        <InputText @bind-Value="_serverForm.DownlinkTopic"
                                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                   placeholder="msh/US/2/json/mqtt/" />
                    </label>
                </div>

                <div class="mt-4 flex flex-wrap gap-4 text-sm text-cinder-900">
                    <label class="flex items-center gap-2">
                        <InputCheckbox @bind-Value="_serverForm.UseTls" />
                        Use TLS
                    </label>
                    <label class="flex items-center gap-2">
                        <InputCheckbox @bind-Value="_serverForm.EnableSend" />
                        Enable send
                    </label>
                    <label class="flex items-center gap-2">
                        <InputCheckbox @bind-Value="_serverForm.IsActive" />
                        Make active after save
                    </label>
                </div>

                <div class="mt-4 flex flex-wrap gap-2">
                    <button type="button"
                            class="liquid-inline-action liquid-inline-action-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                            @onclick="SaveServerProfileAsync">
                        Save server
                    </button>
                    <button type="button"
                            class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                            @onclick="CloseServerEditor">
                        Cancel
                    </button>
                </div>
            </div>
        }
    </section>

    <section class="liquid-panel grid gap-4 rounded-[1.6rem] p-5 lg:grid-cols-[1.4fr_1fr]">
        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Search topics</span>
            <input @bind="_explorerSearchText"
                   @bind:event="oninput"
                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                   placeholder="Region, channel, or topic pattern" />
        </label>
        <div class="self-end space-y-3">
            <p class="text-xs leading-6 text-cinder-800/78">
                Use <strong class="text-cinder-950">Subscribe</strong> to listen immediately.
                <strong class="text-cinder-950">Probe MQTT</strong> discovers channels from live traffic.
            </p>
            <button type="button"
                    class="liquid-inline-action liquid-inline-action-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                    @onclick="ProbeTopicsAsync"
                    disabled="@_isProbingTopics">
                @(_isProbingTopics ? "Probing..." : "Probe MQTT (20s)")
            </button>
        </div>
    </section>

    <section class="grid gap-4 xl:grid-cols-2">
        <article class="liquid-panel flex h-[34rem] flex-col overflow-hidden rounded-[1.6rem] xl:h-[51rem]">
            <div class="border-b border-sand-100/80 px-5 py-4">
                <h2 class="font-display text-3xl text-cinder-950">Explorer</h2>
            </div>
            @if (FilteredExplorerEntries.Count == 0)
            {
                <div class="flex flex-1 items-center p-6 text-cinder-800/78">
                    No topics match this search.
                </div>
            }
            else
            {
                <div class="fade-scroll-frame min-h-0 flex-1">
                    <div class="fade-scroll-content fade-scroll-content-fill">
                        <div class="grid gap-3 p-5">
                            @foreach (var entry in FilteredExplorerEntries)
                            {
                                <article class="liquid-subpanel rounded-2xl p-4">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <strong class="text-sm text-cinder-950">@entry.Label</strong>
                                        @if (entry.IsRecommended)
                                        {
                                            <span class="rounded-full bg-signal-500/12 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-signal-600">Recommended</span>
                                        }
                                        else
                                        {
                                            <span class="rounded-full bg-cinder-900/8 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-cinder-900">Discovered</span>
                                        }
                                    </div>
                                    <code class="mt-3 block rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@entry.TopicPattern</code>
                                    <div class="mt-4 flex flex-wrap gap-2">
                                        <button type="button"
                                                class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                                @onclick="() => OpenChannelDetails(entry.Region, entry.Channel)">
                                            Details
                                        </button>
                                        <button type="button"
                                                class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] @(IsActiveSubscription(entry.TopicPattern) ? "liquid-inline-action-active" : "liquid-inline-action-accent")"
                                                @onclick="() => ToggleSubscriptionAsync(entry.TopicPattern)">
                                            @(IsActiveSubscription(entry.TopicPattern) ? "Unsubscribe" : "Subscribe")
                                        </button>
                                    </div>
                                </article>
                            }
                        </div>
                    </div>
                </div>
            }
        </article>

        <article class="liquid-panel rounded-[1.6rem] p-6 xl:h-[51rem] xl:overflow-y-auto">
            <h2 class="font-display text-3xl text-cinder-950">Live broker status</h2>
            <dl class="mt-5 grid gap-3 sm:grid-cols-[9rem_1fr]">
                <dt class="text-cinder-800/70">Server</dt>
                <dd class="font-medium text-cinder-950">@(_brokerStatus.ActiveServerName ?? "Unknown")</dd>
                <dt class="text-cinder-800/70">Connection</dt>
                <dd class="font-medium text-cinder-950">@(_brokerStatus.IsConnected ? "Connected" : "Disconnected")</dd>
                <dt class="text-cinder-800/70">Endpoint</dt>
                <dd class="font-medium text-cinder-950">@(_brokerStatus.ActiveServerAddress ?? $"{_brokerStatus.Host}:{_brokerStatus.Port}")</dd>
                @if (!string.IsNullOrWhiteSpace(_brokerStatus.LastStatusMessage))
                {
                    <dt class="text-cinder-800/70">Status</dt>
                    <dd class="text-sm text-cinder-900">@_brokerStatus.LastStatusMessage</dd>
                }
            </dl>

            <EditForm Model="_topicRequest" OnValidSubmit="SubscribeAsync">
                <div class="mt-6 space-y-3">
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Custom topic filter</label>
                    <InputText @bind-Value="_topicRequest.TopicFilter"
                               class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950 ring-0"
                               placeholder="msh/US/2/e/LongFast/#" />
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Preset name</label>
                    <InputText @bind-Value="_topicRequest.Name"
                               class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950 ring-0"
                               placeholder="US LongFast" />
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Channel key (optional)</label>
                    <InputText @bind-Value="_topicRequest.EncryptionKeyBase64"
                               class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950 ring-0"
                               placeholder="Base64 or hex key" />
                    <div class="flex flex-wrap gap-2">
                        <button type="submit"
                                class="liquid-inline-action liquid-inline-action-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">
                            Subscribe
                        </button>
                        <button type="button"
                                class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                @onclick="SaveCustomPresetAsync">
                            Save preset
                        </button>
                    </div>
                </div>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <p class="mt-4 text-sm text-cinder-800/80">@_statusMessage</p>
            }

            <div class="mt-6">
                <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Active filters</h3>
                @if (_brokerStatus.TopicFilters.Count == 0)
                {
                    <p class="mt-3 text-cinder-800/78">No active subscriptions yet.</p>
                }
                else
                {
                    <ul class="mt-3 space-y-3 text-cinder-800/85">
                        @foreach (var topicFilter in _brokerStatus.TopicFilters)
                        {
                            <li class="flex flex-wrap items-center gap-2">
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@topicFilter</code>
                                <button type="button"
                                        class="liquid-inline-action liquid-inline-action-danger cursor-pointer rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                        @onclick="() => UnsubscribeAsync(topicFilter)">
                                    Unsubscribe
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>
        </article>
    </section>

    <section class="liquid-panel overflow-hidden rounded-[1.6rem]">
        <div class="border-b border-sand-100/80 px-5 py-4">
            <h2 class="font-display text-3xl text-cinder-950">Saved presets</h2>
        </div>
        @if (_topicPresets.Count == 0)
        {
            <div class="p-6 text-cinder-800/78">
                No topic presets have been saved yet.
            </div>
        }
        else
        {
            <table class="min-w-full border-collapse">
                <thead class="liquid-table-head">
                    <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                        <th class="px-5 py-4">Name</th>
                        <th class="px-5 py-4">Topic pattern</th>
                        <th class="px-5 py-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var topicPreset in _topicPresets)
                    {
                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                            <td class="px-5 py-4 font-medium">@topicPreset.Name</td>
                            <td class="px-5 py-4"><code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@topicPreset.TopicPattern</code></td>
                            <td class="px-5 py-4">
                                @if (TryExtractChannelFromTopicPattern(topicPreset.TopicPattern, out var region, out var channel))
                                {
                                    <button type="button"
                                            class="liquid-inline-action mr-2 cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                            @onclick="() => OpenChannelDetails(region, channel)">
                                        Details
                                    </button>
                                }
                                <button type="button"
                                        class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] @(IsActiveSubscription(topicPreset.TopicPattern) ? "liquid-inline-action-active" : "liquid-inline-action-accent")"
                                        @onclick="() => ToggleSubscriptionAsync(topicPreset.TopicPattern)">
                                    @(IsActiveSubscription(topicPreset.TopicPattern) ? "Unsubscribe" : "Subscribe")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

<ChannelDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedRegion) && !string.IsNullOrWhiteSpace(_selectedChannel))"
                     Region="@(_selectedRegion ?? string.Empty)"
                     Channel="@(_selectedChannel ?? string.Empty)"
                     OnClose="CloseChannelDetails"
                     OnOpenNode="OpenNodeDetailsAsync" />

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetails"
                  OnOpenChannel="OpenChannelDetailsFromKeyAsync" />

@code {
    private readonly CancellationTokenSource _cancellationTokenSource = new();
    private BrokerStatus _brokerStatus = new();
    private IReadOnlyCollection<TopicCatalogEntry> _discoveredTopics = [];
    private string _explorerSearchText = string.Empty;
    private bool _isLoadingServerProfiles;
    private bool _isProbingTopics;
    private IReadOnlyCollection<TopicCatalogEntry> _recommendedTopics = [];
    private string? _selectedChannel;
    private string? _selectedNodeId;
    private string? _selectedRegion;
    private BrokerServerProfile? _selectedServerProfile;
    private IReadOnlyCollection<BrokerServerProfile> _serverProfiles = [];
    private ServerProfileForm _serverForm = new();
    private string? _serverStatusMessage;
    private bool _showServerEditor;
    private string? _statusMessage;
    private TopicRequest _topicRequest = new();
    private IReadOnlyCollection<TopicPreset> _topicPresets = [];
    private CancellationTokenSource? _realtimeRefreshDebounceCancellationTokenSource;

    private IReadOnlyCollection<TopicCatalogEntry> FilteredExplorerEntries => _recommendedTopics
        .Concat(_discoveredTopics)
        .GroupBy(entry => entry.TopicPattern, StringComparer.Ordinal)
        .Select(group => group.OrderByDescending(entry => entry.IsRecommended).First())
        .Where(MatchesExplorerSearch)
        .OrderBy(entry => entry.Region, StringComparer.OrdinalIgnoreCase)
        .ThenBy(entry => entry.Channel, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        ProjectionChangeNotifier.Changed += HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed += HandleServerSelectionChangedAsync;
        await LoadAsync();
    }

    public ValueTask DisposeAsync()
    {
        ProjectionChangeNotifier.Changed -= HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed -= HandleServerSelectionChangedAsync;
        _cancellationTokenSource.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();
        _cancellationTokenSource.Dispose();
        return ValueTask.CompletedTask;
    }

    private bool IsActiveSubscription(string topicFilter)
    {
        return _brokerStatus.TopicFilters.Contains(topicFilter, StringComparer.Ordinal);
    }

    private Task HandleServerSelectionChangedAsync(string workspaceId)
    {
        if (!string.Equals(workspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal))
        {
            return Task.CompletedTask;
        }

        return ScheduleRealtimeRefreshAsync();
    }

    private Task HandleProjectionChangedAsync(ProjectionChangeEvent change)
    {
        if (!IsRelevantProjectionChange(change))
        {
            return Task.CompletedTask;
        }

        return ScheduleRealtimeRefreshAsync();
    }

    private bool IsRelevantProjectionChange(ProjectionChangeEvent change)
    {
        if (!string.Equals(change.WorkspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal))
        {
            return false;
        }

        return change.Kind is ProjectionChangeKind.ChannelSummaryUpdated or ProjectionChangeKind.RuntimeStatusChanged;
    }

    private async Task ScheduleRealtimeRefreshAsync()
    {
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_cancellationTokenSource.Token);
        _realtimeRefreshDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(300), debounceCancellationTokenSource.Token);
            await LoadAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_realtimeRefreshDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _realtimeRefreshDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

    private async Task LoadAsync()
    {
        _isLoadingServerProfiles = true;

        try
        {
            var topicPresetsTask = TopicPresetService.GetTopicPresets();
            var discoveredTopicsTask = TopicDiscoveryService.GetDiscoveredTopics();
            var serverProfilesTask = BrokerServerProfileService.GetServerProfiles();

            await Task.WhenAll(topicPresetsTask, discoveredTopicsTask, serverProfilesTask);

            _topicPresets = await topicPresetsTask;
            _discoveredTopics = await discoveredTopicsTask;
            _serverProfiles = await serverProfilesTask;
            _brokerStatus = BrokerMonitorService.GetBrokerStatus();

            SyncSelectedServerFromStatus(applyDefaults: false);
            ApplyRecommendedTopicsForSelectedServer();
        }
        finally
        {
            _isLoadingServerProfiles = false;
        }
    }

    private async Task ActivateServerTabAsync(Guid profileId)
    {
        if (_selectedServerProfile?.Id == profileId)
        {
            return;
        }

        try
        {
            await BrokerMonitorService.SwitchActiveServerProfile(profileId);
            _serverStatusMessage = "Switched active MQTT server.";
            await ServerSelectionNotifier.NotifyChangedAsync(WorkspaceContextAccessor.GetWorkspaceId());
        }
        catch (Exception exception)
        {
            _serverStatusMessage = $"Switch failed: {exception.Message}";
        }

        await LoadAsync();
        SyncSelectedServerFromStatus(applyDefaults: true);
    }

    private void OpenAddServerEditor()
    {
        ResetServerForm();
        _showServerEditor = true;
    }

    private void OpenSelectedServerEditor()
    {
        if (_selectedServerProfile is null)
        {
            return;
        }

        LoadProfileIntoForm(_selectedServerProfile);
        _showServerEditor = true;
    }

    private async Task SaveServerProfileAsync()
    {
        var switchedActiveServer = false;

        try
        {
            var savedProfile = await BrokerServerProfileService.SaveServerProfile(
                new SaveBrokerServerProfileRequest
                {
                    Id = _serverForm.Id,
                    Name = _serverForm.Name,
                    Host = _serverForm.Host,
                    Port = _serverForm.Port,
                    UseTls = _serverForm.UseTls,
                    Username = _serverForm.Username,
                    Password = _serverForm.Password,
                    DefaultTopicPattern = _serverForm.DefaultTopicPattern,
                    DefaultEncryptionKeyBase64 = _serverForm.DefaultEncryptionKeyBase64,
                    DownlinkTopic = _serverForm.DownlinkTopic,
                    EnableSend = _serverForm.EnableSend,
                    IsActive = _serverForm.IsActive
                });

            if (savedProfile.IsActive)
            {
                await BrokerMonitorService.SwitchActiveServerProfile(savedProfile.Id);
                switchedActiveServer = true;
            }

            _serverStatusMessage = $"Saved server profile '{savedProfile.Name}'.";
            _showServerEditor = false;
            ResetServerForm();

            if (switchedActiveServer)
            {
                await ServerSelectionNotifier.NotifyChangedAsync(WorkspaceContextAccessor.GetWorkspaceId());
            }
        }
        catch (Exception exception)
        {
            _serverStatusMessage = $"Server save failed: {exception.Message}";
        }

        await LoadAsync();

        if (switchedActiveServer)
        {
            SyncSelectedServerFromStatus(applyDefaults: true);
        }
    }

    private void CloseServerEditor()
    {
        _showServerEditor = false;
    }

    private void LoadProfileIntoForm(BrokerServerProfile profile)
    {
        _serverForm = new ServerProfileForm
        {
            Id = profile.Id,
            Name = profile.Name,
            Host = profile.Host,
            Port = profile.Port,
            UseTls = profile.UseTls,
            Username = profile.Username,
            Password = profile.Password,
            DefaultTopicPattern = profile.DefaultTopicPattern,
            DefaultEncryptionKeyBase64 = profile.DefaultEncryptionKeyBase64,
            DownlinkTopic = profile.DownlinkTopic,
            EnableSend = profile.EnableSend,
            IsActive = profile.IsActive
        };
    }

    private void ResetServerForm()
    {
        _serverForm = new ServerProfileForm();
    }

    private void SyncSelectedServerFromStatus(bool applyDefaults)
    {
        var activeProfileId = _brokerStatus.ActiveServerProfileId;

        _selectedServerProfile = activeProfileId.HasValue
            ? _serverProfiles.FirstOrDefault(profile => profile.Id == activeProfileId.Value)
            : null;

        _selectedServerProfile ??= _serverProfiles.FirstOrDefault(profile => profile.IsActive);
        _selectedServerProfile ??= _serverProfiles.FirstOrDefault();

        if (_selectedServerProfile is null)
        {
            return;
        }

        if (applyDefaults || string.IsNullOrWhiteSpace(_topicRequest.TopicFilter))
        {
            _topicRequest.TopicFilter = _selectedServerProfile.DefaultTopicPattern;
        }
    }

    private void ApplyRecommendedTopicsForSelectedServer()
    {
        var recommendedTopics = TopicExplorerService.GetRecommendedTopics();

        if (_selectedServerProfile is null ||
            !TryExtractRegionAndVersionFromTopicPattern(
                _selectedServerProfile.DefaultTopicPattern,
                out var region,
                out var version))
        {
            _recommendedTopics = recommendedTopics;
            return;
        }

        _recommendedTopics = recommendedTopics
            .Where(
                entry => string.Equals(entry.Region, region, StringComparison.OrdinalIgnoreCase) &&
                    entry.TopicPattern.Contains($"/{version}/", StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private bool MatchesExplorerSearch(TopicCatalogEntry entry)
    {
        if (string.IsNullOrWhiteSpace(_explorerSearchText))
        {
            return true;
        }

        return entry.Label.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase) ||
            entry.TopicPattern.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase) ||
            entry.Region.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase) ||
            entry.Channel.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase);
    }

    private async Task SaveCustomPresetAsync()
    {
        if (string.IsNullOrWhiteSpace(_topicRequest.TopicFilter))
        {
            _statusMessage = "A topic filter is required.";
            return;
        }

        var defaultName = _topicRequest.TopicFilter.Trim();
        await SavePresetAsync(
            _topicRequest.TopicFilter.Trim(),
            string.IsNullOrWhiteSpace(_topicRequest.Name) ? defaultName : _topicRequest.Name.Trim(),
            _topicRequest.EncryptionKeyBase64);
    }

    private async Task SavePresetAsync(
        string topicPattern,
        string name,
        string? encryptionKeyBase64 = null)
    {
        try
        {
            var topicPreset = await TopicPresetService.SaveTopicPreset(
                new SaveTopicPresetRequest
                {
                    Name = name,
                    TopicPattern = topicPattern,
                    EncryptionKeyBase64 = string.IsNullOrWhiteSpace(encryptionKeyBase64)
                        ? null
                        : encryptionKeyBase64.Trim(),
                    IsDefault = false
                });

            _statusMessage = $"Saved preset '{topicPreset.Name}'.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

    private async Task SubscribeAsync()
    {
        try
        {
            await BrokerMonitorService.SubscribeToTopic(_topicRequest.TopicFilter);
            _statusMessage = $"Subscribed to {_topicRequest.TopicFilter}.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

    private async Task ProbeTopicsAsync()
    {
        if (_isProbingTopics)
        {
            return;
        }

        _isProbingTopics = true;

        try
        {
            var probeResult = await TopicProbeService.ProbeTopics(_explorerSearchText, 20);

            if (probeResult.ProbedTopicFilters.Count == 0)
            {
                _statusMessage = "No recommended channel matched this search for active probing.";
            }
            else
            {
                _statusMessage =
                    $"Probe completed: {probeResult.ProbedTopicFilters.Count} channels checked for {probeResult.DurationSeconds}s.";
            }
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }
        finally
        {
            _isProbingTopics = false;
        }

        await LoadAsync();
    }

    private async Task ToggleSubscriptionAsync(string topicFilter)
    {
        if (IsActiveSubscription(topicFilter))
        {
            await UnsubscribeAsync(topicFilter);
            return;
        }

        try
        {
            await BrokerMonitorService.SubscribeToTopic(topicFilter);
            _statusMessage = $"Subscribed to {topicFilter}.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

    private async Task UnsubscribeAsync(string topicFilter)
    {
        try
        {
            await BrokerMonitorService.UnsubscribeFromTopic(topicFilter);
            _statusMessage = $"Unsubscribed from {topicFilter}.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

