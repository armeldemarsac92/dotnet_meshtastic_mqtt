@page "/topics"
@inject IBrokerMonitorService BrokerMonitorService
@inject IMessageService MessageService
@inject ITopicExplorerService TopicExplorerService
@inject ITopicProbeService TopicProbeService
@inject ITopicPresetService TopicPresetService

<PageTitle>Topics</PageTitle>

<div class="space-y-6">
    <header class="space-y-3">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Subscriptions</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Topic explorer</h1>
        </div>
        <p class="max-w-3xl text-base leading-8 text-cinder-800">
            Browse recommended and discovered channels, save useful patterns as presets, and toggle subscriptions
            without leaving the app.
        </p>
    </header>

    <section class="liquid-panel grid gap-4 rounded-[1.6rem] p-5 lg:grid-cols-[1.4fr_1fr]">
        <label class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Search topics</span>
            <input @bind="_explorerSearchText"
                   @bind:event="oninput"
                   class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                   placeholder="Region, channel, or topic pattern" />
        </label>
        <div class="self-end space-y-3">
            <p class="text-xs leading-6 text-cinder-800/78">
                Use <strong class="text-cinder-950">Subscribe</strong> to start listening immediately and use
                <strong class="text-cinder-950">Live broker status</strong> to save custom presets.
                <strong class="text-cinder-950">Probe MQTT</strong> actively discovers channels from broker traffic.
            </p>
            <button type="button"
                    class="liquid-inline-action liquid-inline-action-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                    @onclick="ProbeTopicsAsync"
                    disabled="@_isProbingTopics">
                @(_isProbingTopics ? "Probing..." : "Probe MQTT (20s)")
            </button>
        </div>
    </section>

    <section class="grid gap-4 xl:grid-cols-2">
        <article class="liquid-panel overflow-hidden rounded-[1.6rem]">
            <div class="border-b border-sand-100/80 px-5 py-4">
                <h2 class="font-display text-3xl text-cinder-950">Explorer</h2>
            </div>
            @if (FilteredExplorerEntries.Count == 0)
            {
                <div class="p-6 text-cinder-800/78">
                    No topics match this search.
                </div>
            }
            else
            {
                <div class="grid gap-3 p-5">
                    @foreach (var entry in FilteredExplorerEntries)
                    {
                        <article class="liquid-subpanel rounded-2xl p-4">
                            <div class="flex flex-wrap items-center gap-2">
                                <strong class="text-sm text-cinder-950">@entry.Label</strong>
                                @if (entry.IsRecommended)
                                {
                                    <span class="rounded-full bg-signal-500/12 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-signal-600">Recommended</span>
                                }
                                else
                                {
                                    <span class="rounded-full bg-cinder-900/8 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-cinder-900">Discovered</span>
                                }
                            </div>
                            <code class="mt-3 block rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@entry.TopicPattern</code>
                            <div class="mt-4 flex flex-wrap gap-2">
                                <button type="button"
                                        class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                        @onclick="() => OpenChannelDetails(entry.Region, entry.Channel)">
                                    Details
                                </button>
                                <button type="button"
                                        class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] @(IsActiveSubscription(entry.TopicPattern) ? "liquid-inline-action-active" : "liquid-inline-action-accent")"
                                        @onclick="() => ToggleSubscriptionAsync(entry.TopicPattern)">
                                    @(IsActiveSubscription(entry.TopicPattern) ? "Unsubscribe" : "Subscribe")
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </article>

        <article class="liquid-panel rounded-[1.6rem] p-6">
            <h2 class="font-display text-3xl text-cinder-950">Live broker status</h2>
            <dl class="mt-5 grid gap-3 sm:grid-cols-[9rem_1fr]">
                <dt class="text-cinder-800/70">Connection</dt>
                <dd class="font-medium text-cinder-950">@(_brokerStatus.IsConnected ? "Connected" : "Disconnected")</dd>
                <dt class="text-cinder-800/70">Endpoint</dt>
                <dd class="font-medium text-cinder-950">@_brokerStatus.Host:@_brokerStatus.Port</dd>
                @if (!string.IsNullOrWhiteSpace(_brokerStatus.LastStatusMessage))
                {
                    <dt class="text-cinder-800/70">Status</dt>
                    <dd class="text-sm text-cinder-900">@_brokerStatus.LastStatusMessage</dd>
                }
            </dl>

            <EditForm Model="_topicRequest" OnValidSubmit="SubscribeAsync">
                <div class="mt-6 space-y-3">
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Custom topic filter</label>
                    <InputText @bind-Value="_topicRequest.TopicFilter"
                               class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950 ring-0"
                               placeholder="msh/US/2/e/LongFast/#" />
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Preset name</label>
                    <InputText @bind-Value="_topicRequest.Name"
                               class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950 ring-0"
                               placeholder="US LongFast" />
                    <label class="block text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Channel key (optional)</label>
                    <InputText @bind-Value="_topicRequest.EncryptionKeyBase64"
                               class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950 ring-0"
                               placeholder="Base64 or hex key" />
                    <div class="flex flex-wrap gap-2">
                        <button type="submit"
                                class="liquid-inline-action liquid-inline-action-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]">
                            Subscribe
                        </button>
                        <button type="button"
                                class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                @onclick="SaveCustomPresetAsync">
                            Save preset
                        </button>
                    </div>
                </div>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <p class="mt-4 text-sm text-cinder-800/80">@_statusMessage</p>
            }

            <div class="mt-6">
                <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Active filters</h3>
                @if (_brokerStatus.TopicFilters.Count == 0)
                {
                    <p class="mt-3 text-cinder-800/78">No active subscriptions yet.</p>
                }
                else
                {
                    <ul class="mt-3 space-y-3 text-cinder-800/85">
                        @foreach (var topicFilter in _brokerStatus.TopicFilters)
                        {
                            <li class="flex flex-wrap items-center gap-2">
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@topicFilter</code>
                                <button type="button"
                                        class="liquid-inline-action liquid-inline-action-danger cursor-pointer rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                        @onclick="() => UnsubscribeAsync(topicFilter)">
                                    Unsubscribe
                                </button>
                            </li>
                        }
                    </ul>
                }
            </div>
        </article>
    </section>

    <section class="liquid-panel overflow-hidden rounded-[1.6rem]">
        <div class="border-b border-sand-100/80 px-5 py-4">
            <h2 class="font-display text-3xl text-cinder-950">Saved presets</h2>
        </div>
        @if (_topicPresets.Count == 0)
        {
            <div class="p-6 text-cinder-800/78">
                No topic presets have been saved yet.
            </div>
        }
        else
        {
            <table class="min-w-full border-collapse">
                <thead class="liquid-table-head">
                    <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                        <th class="px-5 py-4">Name</th>
                        <th class="px-5 py-4">Topic pattern</th>
                        <th class="px-5 py-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var topicPreset in _topicPresets)
                    {
                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                            <td class="px-5 py-4 font-medium">@topicPreset.Name</td>
                            <td class="px-5 py-4"><code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@topicPreset.TopicPattern</code></td>
                            <td class="px-5 py-4">
                                @if (TryExtractChannelFromTopicPattern(topicPreset.TopicPattern, out var region, out var channel))
                                {
                                    <button type="button"
                                            class="liquid-inline-action mr-2 cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                            @onclick="() => OpenChannelDetails(region, channel)">
                                        Details
                                    </button>
                                }
                                <button type="button"
                                        class="liquid-inline-action cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] @(IsActiveSubscription(topicPreset.TopicPattern) ? "liquid-inline-action-active" : "liquid-inline-action-accent")"
                                        @onclick="() => ToggleSubscriptionAsync(topicPreset.TopicPattern)">
                                    @(IsActiveSubscription(topicPreset.TopicPattern) ? "Unsubscribe" : "Subscribe")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

<ChannelDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedRegion) && !string.IsNullOrWhiteSpace(_selectedChannel))"
                     Region="@(_selectedRegion ?? string.Empty)"
                     Channel="@(_selectedChannel ?? string.Empty)"
                     OnClose="CloseChannelDetails"
                     OnOpenNode="OpenNodeDetailsAsync" />

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetails"
                  OnOpenChannel="OpenChannelDetailsFromKeyAsync" />

@code {
    private BrokerStatus _brokerStatus = new();
    private IReadOnlyCollection<TopicCatalogEntry> _discoveredTopics = [];
    private string _explorerSearchText = string.Empty;
    private IReadOnlyCollection<TopicCatalogEntry> _recommendedTopics = [];
    private bool _isProbingTopics;
    private string? _selectedChannel;
    private string? _selectedNodeId;
    private string? _selectedRegion;
    private string? _statusMessage;
    private TopicRequest _topicRequest = new();
    private IReadOnlyCollection<TopicPreset> _topicPresets = [];

    private IReadOnlyCollection<TopicCatalogEntry> FilteredExplorerEntries => _recommendedTopics
        .Concat(_discoveredTopics)
        .GroupBy(entry => entry.TopicPattern, StringComparer.Ordinal)
        .Select(group => group.OrderByDescending(entry => entry.IsRecommended).First())
        .Where(MatchesExplorerSearch)
        .OrderBy(entry => entry.Region, StringComparer.OrdinalIgnoreCase)
        .ThenBy(entry => entry.Channel, StringComparer.OrdinalIgnoreCase)
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private bool IsActiveSubscription(string topicFilter)
    {
        return _brokerStatus.TopicFilters.Contains(topicFilter, StringComparer.Ordinal);
    }

    private async Task LoadAsync()
    {
        _topicPresets = await TopicPresetService.GetTopicPresets();
        _brokerStatus = BrokerMonitorService.GetBrokerStatus();
        _recommendedTopics = TopicExplorerService.GetRecommendedTopics();

        var recentMessages = await MessageService.GetRecentMessages(500);
        _discoveredTopics = TopicExplorerService.GetDiscoveredTopics(
            recentMessages.Select(message => message.Topic)
                .Concat(_brokerStatus.TopicFilters)
                .Concat(_topicPresets.Select(preset => preset.TopicPattern)));
    }

    private bool MatchesExplorerSearch(TopicCatalogEntry entry)
    {
        if (string.IsNullOrWhiteSpace(_explorerSearchText))
        {
            return true;
        }

        return entry.Label.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase) ||
            entry.TopicPattern.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase) ||
            entry.Region.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase) ||
            entry.Channel.Contains(_explorerSearchText, StringComparison.OrdinalIgnoreCase);
    }

    private async Task SaveCustomPresetAsync()
    {
        if (string.IsNullOrWhiteSpace(_topicRequest.TopicFilter))
        {
            _statusMessage = "A topic filter is required.";
            return;
        }

        var defaultName = _topicRequest.TopicFilter.Trim();
        await SavePresetAsync(
            _topicRequest.TopicFilter.Trim(),
            string.IsNullOrWhiteSpace(_topicRequest.Name) ? defaultName : _topicRequest.Name.Trim(),
            _topicRequest.EncryptionKeyBase64);
    }

    private async Task SavePresetAsync(
        string topicPattern,
        string name,
        string? encryptionKeyBase64 = null)
    {
        try
        {
            var topicPreset = await TopicPresetService.SaveTopicPreset(
                new SaveTopicPresetRequest
                {
                    Name = name,
                    TopicPattern = topicPattern,
                    EncryptionKeyBase64 = string.IsNullOrWhiteSpace(encryptionKeyBase64)
                        ? null
                        : encryptionKeyBase64.Trim(),
                    IsDefault = false
                });

            _statusMessage = $"Saved preset '{topicPreset.Name}'.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

    private async Task SubscribeAsync()
    {
        try
        {
            await BrokerMonitorService.SubscribeToTopic(_topicRequest.TopicFilter);
            _statusMessage = $"Subscribed to {_topicRequest.TopicFilter}.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

    private async Task ProbeTopicsAsync()
    {
        if (_isProbingTopics)
        {
            return;
        }

        _isProbingTopics = true;

        try
        {
            var probeResult = await TopicProbeService.ProbeTopics(_explorerSearchText, 20);

            if (probeResult.ProbedTopicFilters.Count == 0)
            {
                _statusMessage = "No recommended channel matched this search for active probing.";
            }
            else
            {
                _statusMessage =
                    $"Probe completed: {probeResult.ProbedTopicFilters.Count} channels checked for {probeResult.DurationSeconds}s.";
            }
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }
        finally
        {
            _isProbingTopics = false;
        }

        await LoadAsync();
    }

    private async Task ToggleSubscriptionAsync(string topicFilter)
    {
        if (IsActiveSubscription(topicFilter))
        {
            await UnsubscribeAsync(topicFilter);
            return;
        }

        try
        {
            await BrokerMonitorService.SubscribeToTopic(topicFilter);
            _statusMessage = $"Subscribed to {topicFilter}.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

    private async Task UnsubscribeAsync(string topicFilter)
    {
        try
        {
            await BrokerMonitorService.UnsubscribeFromTopic(topicFilter);
            _statusMessage = $"Unsubscribed from {topicFilter}.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }

        await LoadAsync();
    }

    private void OpenChannelDetails(string region, string channel)
    {
        _selectedRegion = region;
        _selectedChannel = channel;
    }

    private Task CloseChannelDetails()
    {
        _selectedRegion = null;
        _selectedChannel = null;
        return Task.CompletedTask;
    }

    private Task OpenNodeDetailsAsync(string nodeId)
    {
        _selectedNodeId = nodeId;
        return Task.CompletedTask;
    }

    private Task CloseNodeDetails()
    {
        _selectedNodeId = null;
        return Task.CompletedTask;
    }

    private Task OpenChannelDetailsFromKeyAsync(string channelKey)
    {
        if (TrySplitChannelKey(channelKey, out var region, out var channel))
        {
            OpenChannelDetails(region, channel);
        }

        return Task.CompletedTask;
    }

    private static bool TryExtractChannelFromTopicPattern(string topicPattern, out string region, out string channel)
    {
        region = string.Empty;
        channel = string.Empty;

        if (string.IsNullOrWhiteSpace(topicPattern))
        {
            return false;
        }

        var segments = topicPattern.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (segments.Length < 5 ||
            !string.Equals(segments[0], "msh", StringComparison.OrdinalIgnoreCase) ||
            (!string.Equals(segments[3], "e", StringComparison.OrdinalIgnoreCase) &&
             !string.Equals(segments[3], "json", StringComparison.OrdinalIgnoreCase)) ||
            string.Equals(segments[4], "#", StringComparison.Ordinal) ||
            string.Equals(segments[4], "+", StringComparison.Ordinal))
        {
            return false;
        }

        region = segments[1];
        channel = segments[4];
        return !string.IsNullOrWhiteSpace(region) && !string.IsNullOrWhiteSpace(channel);
    }

    private static bool TrySplitChannelKey(string channelKey, out string region, out string channel)
    {
        region = string.Empty;
        channel = string.Empty;

        if (string.IsNullOrWhiteSpace(channelKey))
        {
            return false;
        }

        var segments = channelKey.Split('/', 2, StringSplitOptions.TrimEntries);
        if (segments.Length != 2)
        {
            return false;
        }

        region = segments[0];
        channel = segments[1];
        return !string.IsNullOrWhiteSpace(region) && !string.IsNullOrWhiteSpace(channel);
    }

    private sealed class TopicRequest
    {
        public string EncryptionKeyBase64 { get; set; } = string.Empty;

        public string Name { get; set; } = string.Empty;

        public string TopicFilter { get; set; } = string.Empty;
    }
}
