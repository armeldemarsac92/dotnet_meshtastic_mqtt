@inherits LayoutComponentBase

<div class="min-h-screen bg-[radial-gradient(circle_at_top,rgba(137,214,255,0.45),transparent_28%),linear-gradient(180deg,#f5fbff_0%,#eaf2ff_44%,#dfe9fb_100%)] text-stone-900">
    <div class="grid min-h-screen lg:grid-cols-[18.5rem_1fr]">
        <aside class="flex flex-col gap-6 border-b border-white/10 bg-linear-to-b from-cinder-900 via-cinder-900 to-cinder-950 px-6 py-8 text-sand-50 lg:border-r lg:border-b-0">
            <div class="flex items-center gap-4">
                <div class="grid size-12 place-items-center rounded-2xl bg-linear-to-br from-signal-400 to-sand-200 font-display text-lg text-cinder-950 shadow-xl shadow-cinder-950/30">
                    MB
                </div>
                <div>
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-sand-200/70">Meshtastic MQTT</p>
                    <h1 class="font-display text-3xl text-sand-50">MeshBoard</h1>
                </div>
            </div>

            <nav class="grid gap-2 text-sm font-medium">
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/topics">Topics</NavLink>
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/messages">Messages</NavLink>
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/nodes">Nodes</NavLink>
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/channels">Channels</NavLink>
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/favorites">Favorites</NavLink>
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/compose">Compose</NavLink>
                <NavLink class="rounded-full px-4 py-3 text-sand-100/80 transition hover:bg-white/8 hover:text-white [&.active]:bg-white/12 [&.active]:text-white" href="/settings">Settings</NavLink>
            </nav>

            <div class="mt-auto rounded-[1.4rem] border border-white/8 bg-white/5 p-4 text-sm leading-7 text-sand-100/76 shadow-lg shadow-cinder-950/20">
                The UI stays thin. Application services own orchestration. Infrastructure stays replaceable.
            </div>
        </aside>

        <main class="px-5 py-6 sm:px-8 sm:py-8 lg:px-10 lg:py-10">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" class="hidden fixed right-4 bottom-4 max-w-sm rounded-2xl bg-red-700 px-4 py-3 text-sm text-white shadow-2xl shadow-red-950/40" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="ml-2 underline underline-offset-4">Reload</a>
    <span class="dismiss">🗙</span>
</div>
