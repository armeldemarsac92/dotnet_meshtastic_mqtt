@using MeshBoard.Application.Services
@using MeshBoard.Contracts.Configuration
@using MeshBoard.Web.State
@inherits LayoutComponentBase
@implements IDisposable
@inject IBrokerServerProfileService BrokerServerProfileService
@inject IBrokerMonitorService BrokerMonitorService
@inject ServerSelectionNotifier ServerSelectionNotifier

<div class="liquid-stage min-h-screen text-cinder-950">
    <div class="relative z-10 grid min-h-screen lg:h-screen lg:grid-cols-[18.5rem_1fr] lg:overflow-hidden">
        <aside class="liquid-sidebar flex flex-col gap-6 border-b px-6 py-8 text-sand-50 lg:sticky lg:top-0 lg:h-screen lg:overflow-y-auto lg:border-r lg:border-b-0">
            <div class="flex items-center gap-4">
                <div class="grid size-12 place-items-center rounded-2xl border border-white/50 bg-linear-to-br from-white/96 via-sand-100/90 to-signal-400/70 font-display text-lg text-cinder-950 shadow-lg shadow-cinder-950/35">
                    MB
                </div>
                <div>
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-sand-200/70">Meshtastic MQTT</p>
                    <h1 class="font-display text-3xl text-sand-50">MeshBoard</h1>
                </div>
            </div>

            <nav class="grid gap-2 text-sm font-medium">
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/topics">Topics</NavLink>
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/messages">Messages</NavLink>
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/nodes">Nodes</NavLink>
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/map">Map</NavLink>
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/favorites">Favorites</NavLink>
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/compose">Compose</NavLink>
                <NavLink class="liquid-nav-link rounded-full px-4 py-3" href="/settings">Settings</NavLink>
            </nav>

            <section class="liquid-sidebar-note rounded-[1.4rem] p-4 text-sm text-sand-100/86">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-sand-200/72">Active server</p>
                @if (_isLoadingServers)
                {
                    <p class="mt-2 text-xs">Loading servers...</p>
                }
                else if (_serverProfiles.Count <= 1)
                {
                    <p class="mt-2 text-xs">@(_activeServerName ?? "Default server")</p>
                    <a href="/topics" class="mt-2 inline-block text-xs underline underline-offset-4">Manage servers</a>
                }
                else
                {
                    <select class="liquid-input mt-2 w-full rounded-2xl px-3 py-2 text-xs text-cinder-950"
                            value="@_activeServerIdText"
                            @onchange="OnServerSelectionChangedAsync">
                        @foreach (var profile in _serverProfiles)
                        {
                            <option value="@profile.Id.ToString()">@profile.Name (@profile.ServerAddress)</option>
                        }
                    </select>
                    <a href="/topics" class="mt-2 inline-block text-xs underline underline-offset-4">Manage servers</a>
                }
            </section>

            <div class="liquid-sidebar-note mt-auto rounded-[1.4rem] p-4 text-sm leading-7 text-sand-100/82">
                <AuthorizeView>
                    <Authorized>
                        <div class="mb-4 rounded-[1.1rem] border border-white/16 bg-white/6 p-3">
                            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.2em] text-sand-200/72">Signed in</p>
                            <p class="mt-2 text-sm font-medium text-sand-50">@context.User.Identity?.Name</p>
                            <form method="post" action="/auth/logout" class="mt-3">
                                <input type="hidden" name="returnUrl" value="/login" />
                                <button type="submit"
                                        class="liquid-input w-full cursor-pointer rounded-full px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-cinder-950">
                                    Logout
                                </button>
                            </form>
                        </div>
                    </Authorized>
                </AuthorizeView>

                crafted by Armel de Marsac, want to contribute?
                <a class="underline underline-offset-4" href="https://github.com/armeldemarsac92/dotnet_meshtastic_mqtt" target="_blank" rel="noopener noreferrer">open a pr</a>
            </div>
        </aside>

        <main class="px-5 py-6 sm:px-8 sm:py-8 lg:h-screen lg:overflow-y-auto lg:px-10 lg:py-10">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" class="hidden fixed right-4 bottom-4 max-w-sm rounded-2xl bg-red-700 px-4 py-3 text-sm text-white shadow-2xl shadow-red-950/40" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="ml-2 underline underline-offset-4">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string? _activeServerIdText;
    private string? _activeServerName;
    private bool _isLoadingServers = true;
    private IReadOnlyCollection<BrokerServerProfile> _serverProfiles = [];

    protected override async Task OnInitializedAsync()
    {
        ServerSelectionNotifier.Changed += HandleServerSelectionChangedAsync;
        await LoadServersAsync();
    }

    private async Task LoadServersAsync()
    {
        _isLoadingServers = true;

        try
        {
            _serverProfiles = await BrokerServerProfileService.GetServerProfiles();
            var activeProfile = _serverProfiles.FirstOrDefault(profile => profile.IsActive);

            if (activeProfile is null)
            {
                activeProfile = await BrokerServerProfileService.GetActiveServerProfile();
            }

            _activeServerIdText = activeProfile.Id.ToString();
            _activeServerName = activeProfile.Name;
        }
        finally
        {
            _isLoadingServers = false;
        }
    }

    private async Task OnServerSelectionChangedAsync(ChangeEventArgs args)
    {
        if (args.Value is not string rawValue || !Guid.TryParse(rawValue, out var selectedProfileId))
        {
            return;
        }

        if (string.Equals(_activeServerIdText, rawValue, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await BrokerMonitorService.SwitchActiveServerProfile(selectedProfileId);
        await ServerSelectionNotifier.NotifyChangedAsync();
        await LoadServersAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleServerSelectionChangedAsync()
    {
        await LoadServersAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ServerSelectionNotifier.Changed -= HandleServerSelectionChangedAsync;
    }
}
