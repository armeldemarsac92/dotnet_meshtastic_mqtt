@implements IAsyncDisposable
@inject IBrokerMonitorService BrokerMonitorService
@inject IBrokerServerProfileService BrokerServerProfileService
@inject ICachedChannelDetailService CachedChannelDetailService
@inject ITopicPresetService TopicPresetService
@inject IWorkspaceContextAccessor WorkspaceContextAccessor
@inject ProjectionChangeNotifier ProjectionChangeNotifier
@inject ServerSelectionNotifier ServerSelectionNotifier

@if (IsOpen)
{
    <div class="modal-overlay fixed inset-0 z-50 flex items-center justify-center bg-cinder-950/45 p-4 backdrop-blur-sm"
         @onclick="CloseAsync">
        <article class="liquid-panel flex h-[92vh] w-full max-w-7xl flex-col overflow-hidden rounded-[1.8rem] overscroll-contain"
                 @onclick:stopPropagation="true">
            <header class="flex items-center justify-between border-b border-sand-100/80 px-5 py-4">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Channel details</p>
                </div>
                <button type="button"
                        class="liquid-button cursor-pointer rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="CloseAsync">
                    Close
                </button>
            </header>

            <div class="min-h-0 flex-1 overflow-hidden px-5 py-4 overscroll-contain">
                @if (_isLoading)
                {
                    <p class="text-sm text-cinder-800/78">Loading channel details...</p>
                }
                else
                {
                    <div class="flex h-full min-h-0 flex-col gap-6">
                        <header class="space-y-3">
                            <div>
                                <h2 class="font-display text-4xl text-cinder-950 sm:text-5xl">@Channel</h2>
                            </div>
                            <div class="flex flex-wrap items-center gap-2 text-sm text-cinder-800/82">
                                <span class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@Region</span>
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@TopicFilter</code>
                                @if (_observedBrokerServers.Count > 0)
                                {
                                    @foreach (var brokerServer in _observedBrokerServers)
                                    {
                                        <span class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">MQTT @brokerServer</span>
                                    }
                                }
                            </div>
                        </header>

                        <section class="liquid-panel rounded-[1.6rem] p-5">
                            <div class="flex flex-wrap items-center gap-2">
                                <button type="button"
                                        class="liquid-button cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] @(IsSubscribed ? "liquid-button-active" : "liquid-button-accent")"
                                        @onclick="ToggleSubscriptionAsync">
                                    @(IsSubscribed ? "Unsubscribe" : "Subscribe")
                                </button>
                            </div>

                            <div class="mt-4 grid gap-3 lg:grid-cols-[1fr_auto]">
                                <label class="space-y-2">
                                    <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Custom channel key (base64 or hex)</span>
                                    <input @bind="_encryptionKeyInput"
                                           class="liquid-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                                           placeholder="Leave empty to use default key" />
                                </label>
                                <div class="self-end">
                                    <button type="button"
                                            class="liquid-button liquid-button-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                            @onclick="SaveChannelPresetAsync">
                                        Save channel preset
                                    </button>
                                </div>
                            </div>

                            <p class="mt-3 text-xs text-cinder-800/78">
                                Default channel key:
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-[0.68rem] text-cinder-900">@_defaultEncryptionKeyBase64</code>
                            </p>

                            @if (!string.IsNullOrWhiteSpace(_statusMessage))
                            {
                                <p class="mt-3 text-sm text-cinder-800/82">@_statusMessage</p>
                            }
                        </section>

                        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Packets</p>
                                <strong class="mt-2 block text-3xl text-cinder-950">@_channelSummary.PacketCount</strong>
                            </article>
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Unique senders</p>
                                <strong class="mt-2 block text-3xl text-cinder-950">@_channelSummary.UniqueSenderCount</strong>
                            </article>
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Decoded ratio</p>
                                <strong class="mt-2 block text-3xl text-cinder-950">@DecodedRatio%</strong>
                            </article>
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Last seen</p>
                                <strong class="mt-2 block text-sm text-cinder-950">@(_channelSummary.LastSeenAtUtc?.ToString("u") ?? "Unknown")</strong>
                            </article>
                        </section>

                        <section class="grid min-h-0 flex-1 gap-4 xl:grid-cols-2">
                            <article class="liquid-panel flex h-full flex-col overflow-hidden rounded-[1.6rem]">
                                <div class="border-b border-sand-100/80 px-5 pt-5 pb-4">
                                    <h3 class="font-display text-3xl text-cinder-950">Top nodes</h3>
                                </div>
                                @if (_topNodes.Count == 0)
                                {
                                    <div class="flex flex-1 items-center p-6 text-cinder-800/78">No traffic observed for this channel yet.</div>
                                }
                                else
                                {
                                    <div class="fade-scroll-frame min-h-0 flex-1">
                                        <div class="fade-scroll-content fade-scroll-content-fill">
                                            <table class="min-w-full border-collapse">
                                                <thead class="liquid-table-head sticky top-0 z-10">
                                                    <tr class="text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                                                        <th class="px-5 py-4">Node</th>
                                                        <th class="px-5 py-4">Packets</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var topNode in _topNodes)
                                                    {
                                                        <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                                                            <td class="px-5 py-4">
                                                                <button type="button"
                                                                        class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-xs font-semibold"
                                                                        @onclick="() => OpenNodeDetailsAsync(topNode.NodeId)">
                                                                    @topNode.DisplayName
                                                                </button>
                                                            </td>
                                                            <td class="px-5 py-4">@topNode.PacketCount</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                }
                            </article>

                            <article class="liquid-panel flex h-full flex-col overflow-hidden rounded-[1.6rem]">
                                <div class="border-b border-sand-100/80 px-5 pt-5 pb-4">
                                    <h3 class="font-display text-3xl text-cinder-950">Recent messages</h3>
                                </div>
                                @if (_isMessagesLoading && _channelMessagesPage.TotalCount == 0)
                                {
                                    <div class="flex flex-1 items-center p-6 text-cinder-800/78">Loading channel messages...</div>
                                }
                                else if (_channelMessagesPage.Items.Count == 0)
                                {
                                    <div class="flex flex-1 items-center p-6 text-cinder-800/78">No recent messages for this channel.</div>
                                }
                                else
                                {
                                    <div class="fade-scroll-frame min-h-0 flex-1">
                                        <ul class="fade-scroll-content fade-scroll-content-fill space-y-3 p-5 text-sm text-cinder-900">
                                            @foreach (var message in _channelMessagesPage.Items)
                                            {
                                                <li class="liquid-subpanel rounded-2xl p-3">
                                                    <div class="flex flex-wrap items-center gap-2">
                                                        <span class="rounded-full bg-sand-100 px-3 py-1 text-xs">@message.PacketType</span>
                                                        <span class="text-xs text-cinder-800/70">@message.ReceivedAtUtc.ToString("u")</span>
                                                    </div>
                                                    <p class="mt-2">@message.PayloadPreview</p>
                                                    <p class="mt-1 text-xs text-cinder-800/70">From @GetSenderDisplayName(message) to @(message.ToNodeId ?? "Broadcast")</p>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                                <div class="flex flex-wrap items-center justify-between gap-3 border-t border-sand-100/80 px-5 py-4">
                                    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-cinder-800/68">
                                        @GetMessagePagingSummaryText()
                                    </p>
                                    <div class="flex flex-wrap items-center gap-2">
                                        <button type="button"
                                                class="liquid-button cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                                                @onclick="GoToPreviousMessagesPageAsync"
                                                disabled="@(!CanGoToPreviousMessagesPage)">
                                            Previous
                                        </button>
                                        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">
                                            Page @_currentMessagesPage of @GetMessagesTotalPages()
                                        </span>
                                        <button type="button"
                                                class="liquid-button liquid-button-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                                                @onclick="GoToNextMessagesPageAsync"
                                                disabled="@(!CanGoToNextMessagesPage)">
                                            Next
                                        </button>
                                    </div>
                                </div>
                            </article>
                        </section>
                    </div>
                }
            </div>
        </article>
    </div>
}

@code {
    private const int MessagesPageSize = 40;
    private readonly CancellationTokenSource _cancellationTokenSource = new();

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string Region { get; set; } = string.Empty;

    [Parameter]
    public string Channel { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<string> OnOpenNode { get; set; }

    private ChannelSummary _channelSummary = new();
    private MessagePageResult _channelMessagesPage = new();
    private int _currentMessagesPage = 1;
    private string _encryptionKeyInput = string.Empty;
    private bool _isMessagesLoading;
    private string? _loadedChannelKey;
    private TopicPreset? _matchedPreset;
    private bool _isLoading;
    private string? _statusMessage;
    private IReadOnlyCollection<ChannelTopNode> _topNodes = [];
    private string _defaultEncryptionKeyBase64 = TopicEncryptionKey.DefaultKeyBase64;
    private CancellationTokenSource? _realtimeRefreshDebounceCancellationTokenSource;

    private int DecodedRatio =>
        _channelSummary.PacketCount == 0
            ? 0
            : (int)Math.Round(
                _channelSummary.DecodedPacketCount * 100d / _channelSummary.PacketCount,
                MidpointRounding.AwayFromZero);

    private IReadOnlyCollection<string> _observedBrokerServers => _channelSummary.ObservedBrokerServers;

    private bool IsSubscribed =>
        BrokerMonitorService.GetBrokerStatus().TopicFilters.Contains(TopicFilter, StringComparer.Ordinal);

    private bool CanGoToNextMessagesPage =>
        !_isMessagesLoading && !_isLoading && (_currentMessagesPage * MessagesPageSize) < _channelMessagesPage.TotalCount;

    private bool CanGoToPreviousMessagesPage =>
        !_isMessagesLoading && !_isLoading && _currentMessagesPage > 1;

    private string TopicFilter => $"msh/{Region}/2/e/{Channel}/#";

    protected override void OnInitialized()
    {
        ProjectionChangeNotifier.Changed += HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed += HandleServerSelectionChangedAsync;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen || string.IsNullOrWhiteSpace(Region) || string.IsNullOrWhiteSpace(Channel))
        {
            _loadedChannelKey = null;
            return;
        }

        var channelKey = $"{Region}/{Channel}";

        if (string.Equals(_loadedChannelKey, channelKey, StringComparison.Ordinal))
        {
            return;
        }

        _loadedChannelKey = channelKey;
        _currentMessagesPage = 1;
        await LoadAsync(_cancellationTokenSource.Token, forceRefresh: true);
    }

    public ValueTask DisposeAsync()
    {
        ProjectionChangeNotifier.Changed -= HandleProjectionChangedAsync;
        ServerSelectionNotifier.Changed -= HandleServerSelectionChangedAsync;
        _cancellationTokenSource.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();
        _cancellationTokenSource.Dispose();
        return ValueTask.CompletedTask;
    }

    private Task HandleServerSelectionChangedAsync(string workspaceId)
    {
        if (!IsOpen ||
            !string.Equals(workspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal))
        {
            return Task.CompletedTask;
        }

        return ScheduleRealtimeRefreshAsync(forceRefresh: true);
    }

    private Task HandleProjectionChangedAsync(ProjectionChangeEvent change)
    {
        if (!IsRelevantProjectionChange(change))
        {
            return Task.CompletedTask;
        }

        if (change.Kind == ProjectionChangeKind.RuntimeStatusChanged)
        {
            return InvokeAsync(StateHasChanged);
        }

        return ScheduleRealtimeRefreshAsync();
    }

    private bool IsRelevantProjectionChange(ProjectionChangeEvent change)
    {
        if (!IsOpen ||
            string.IsNullOrWhiteSpace(Region) ||
            string.IsNullOrWhiteSpace(Channel) ||
            !string.Equals(change.WorkspaceId, WorkspaceContextAccessor.GetWorkspaceId(), StringComparison.Ordinal))
        {
            return false;
        }

        if (change.Kind == ProjectionChangeKind.RuntimeStatusChanged)
        {
            return true;
        }

        return change.Kind == ProjectionChangeKind.ChannelSummaryUpdated &&
            !string.IsNullOrWhiteSpace(change.EntityKey) &&
            string.Equals(change.EntityKey, GetChannelEntityKey(), StringComparison.OrdinalIgnoreCase);
    }

    private async Task ScheduleRealtimeRefreshAsync(bool forceRefresh = false)
    {
        _realtimeRefreshDebounceCancellationTokenSource?.Cancel();
        _realtimeRefreshDebounceCancellationTokenSource?.Dispose();

        var debounceCancellationTokenSource = CancellationTokenSource.CreateLinkedTokenSource(_cancellationTokenSource.Token);
        _realtimeRefreshDebounceCancellationTokenSource = debounceCancellationTokenSource;

        try
        {
            await Task.Delay(TimeSpan.FromMilliseconds(300), debounceCancellationTokenSource.Token);
            await LoadAsync(debounceCancellationTokenSource.Token, forceRefresh);
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) when (debounceCancellationTokenSource.IsCancellationRequested)
        {
        }
        finally
        {
            if (ReferenceEquals(_realtimeRefreshDebounceCancellationTokenSource, debounceCancellationTokenSource))
            {
                _realtimeRefreshDebounceCancellationTokenSource = null;
            }

            debounceCancellationTokenSource.Dispose();
        }
    }

    private async Task LoadAsync(
        CancellationToken cancellationToken = default,
        bool forceRefresh = false)
    {
        _isLoading = true;
        _statusMessage = null;

        try
        {
            var channelSummaryTask = CachedChannelDetailService.GetChannelSummary(Region, Channel, forceRefresh, cancellationToken);
            var topNodesTask = CachedChannelDetailService.GetTopNodesByChannel(Region, Channel, 12, forceRefresh, cancellationToken);
            var messagesTask = LoadMessagesPageAsync(cancellationToken, forceRefresh);
            var presetsTask = TopicPresetService.GetTopicPresets(cancellationToken);
            var activeServerTask = BrokerServerProfileService.GetActiveServerProfile(cancellationToken);

            await Task.WhenAll(channelSummaryTask, topNodesTask, messagesTask, presetsTask, activeServerTask);

            _channelSummary = await channelSummaryTask;
            _topNodes = await topNodesTask;
            var presets = await presetsTask;
            var activeServer = await activeServerTask;

            _defaultEncryptionKeyBase64 = string.IsNullOrWhiteSpace(activeServer.DefaultEncryptionKeyBase64)
                ? TopicEncryptionKey.DefaultKeyBase64
                : activeServer.DefaultEncryptionKeyBase64;

            _matchedPreset = presets.FirstOrDefault(
                preset => string.Equals(
                    NormalizeTransportSegment(preset.TopicPattern),
                    NormalizeTransportSegment(TopicFilter),
                    StringComparison.OrdinalIgnoreCase));

            _encryptionKeyInput = _matchedPreset?.EncryptionKeyBase64 ?? string.Empty;
        }
        catch (OperationCanceledException) when (cancellationToken.IsCancellationRequested)
        {
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
            _channelSummary = new ChannelSummary();
            _channelMessagesPage = new MessagePageResult();
            _topNodes = [];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMessagesPageAsync(
        CancellationToken cancellationToken = default,
        bool forceRefresh = false)
    {
        _isMessagesLoading = true;

        try
        {
            var page = await CachedChannelDetailService.GetMessagesPageByChannel(
                Region,
                Channel,
                offset: (_currentMessagesPage - 1) * MessagesPageSize,
                take: MessagesPageSize,
                forceRefresh: forceRefresh,
                cancellationToken: cancellationToken);

            if (page.TotalCount > 0 && page.Items.Count == 0 && _currentMessagesPage > 1)
            {
                _currentMessagesPage = GetLastMessagesPageNumber(page.TotalCount);
                page = await CachedChannelDetailService.GetMessagesPageByChannel(
                    Region,
                    Channel,
                    offset: (_currentMessagesPage - 1) * MessagesPageSize,
                    take: MessagesPageSize,
                    forceRefresh: forceRefresh,
                    cancellationToken: cancellationToken);
            }

            _channelMessagesPage = page;
        }
        finally
        {
            _isMessagesLoading = false;
        }
    }

    private async Task GoToPreviousMessagesPageAsync()
    {
        if (!CanGoToPreviousMessagesPage)
        {
            return;
        }

        _currentMessagesPage--;
        await LoadMessagesPageAsync();
    }

    private async Task GoToNextMessagesPageAsync()
    {
        if (!CanGoToNextMessagesPage)
        {
            return;
        }

        _currentMessagesPage++;
        await LoadMessagesPageAsync();
    }

    private async Task SaveChannelPresetAsync()
    {
        try
        {
            var savedPreset = await TopicPresetService.SaveTopicPreset(
                new SaveTopicPresetRequest
                {
                    Name = _matchedPreset?.Name ?? $"{Region} {Channel}",
                    TopicPattern = TopicFilter,
                    EncryptionKeyBase64 = string.IsNullOrWhiteSpace(_encryptionKeyInput)
                        ? null
                        : _encryptionKeyInput.Trim(),
                    IsDefault = _matchedPreset?.IsDefault ?? false
                });

            _matchedPreset = savedPreset;
            _encryptionKeyInput = savedPreset.EncryptionKeyBase64 ?? string.Empty;
            _statusMessage = $"Saved preset '{savedPreset.Name}'.";
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }
    }

    private async Task ToggleSubscriptionAsync()
    {
        try
        {
            if (IsSubscribed)
            {
                await BrokerMonitorService.UnsubscribeFromTopic(TopicFilter);
                _statusMessage = $"Unsubscribed from {TopicFilter}.";
            }
            else
            {
                await BrokerMonitorService.SubscribeToTopic(TopicFilter);
                _statusMessage = $"Subscribed to {TopicFilter}.";
            }
        }
        catch (Exception exception)
        {
            _statusMessage = exception.Message;
        }
    }

    private async Task CloseAsync()
    {
        await OnClose.InvokeAsync();
    }

    private async Task OpenNodeDetailsAsync(string nodeId)
    {
        if (!OnOpenNode.HasDelegate)
        {
            return;
        }

        await OnClose.InvokeAsync();
        await OnOpenNode.InvokeAsync(nodeId);
    }

    private static string GetSenderDisplayName(MessageSummary message)
    {
        if (!string.IsNullOrWhiteSpace(message.FromNodeShortName))
        {
            return message.FromNodeShortName;
        }

        if (!string.IsNullOrWhiteSpace(message.FromNodeLongName))
        {
            return message.FromNodeLongName;
        }

        return message.FromNodeId;
    }

    private string GetMessagePagingSummaryText()
    {
        if (_isMessagesLoading && _channelMessagesPage.TotalCount == 0)
        {
            return "Loading packets";
        }

        if (_channelMessagesPage.TotalCount == 0)
        {
            return "No packets found";
        }

        var start = ((_currentMessagesPage - 1) * MessagesPageSize) + 1;
        var end = Math.Min(_currentMessagesPage * MessagesPageSize, _channelMessagesPage.TotalCount);

        return $"Showing {start}-{end} of {_channelMessagesPage.TotalCount} packets";
    }

    private int GetLastMessagesPageNumber(int totalCount)
    {
        return Math.Max(1, (int)Math.Ceiling(totalCount / (double)MessagesPageSize));
    }

    private int GetMessagesTotalPages()
    {
        return _channelMessagesPage.TotalCount == 0 ? 1 : GetLastMessagesPageNumber(_channelMessagesPage.TotalCount);
    }

    private static string NormalizeTransportSegment(string topicPattern)
    {
        if (string.IsNullOrWhiteSpace(topicPattern))
        {
            return string.Empty;
        }

        var segments = topicPattern
            .Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (segments.Length >= 4 &&
            string.Equals(segments[0], "msh", StringComparison.OrdinalIgnoreCase) &&
            string.Equals(segments[3], "json", StringComparison.OrdinalIgnoreCase))
        {
            segments[3] = "e";
        }

        return string.Join('/', segments);
    }

    private string GetChannelEntityKey()
    {
        return $"{Region.Trim()}/{Channel.Trim()}";
    }
}
