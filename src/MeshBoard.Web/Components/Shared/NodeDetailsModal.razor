@inject ICachedNodeDetailService CachedNodeDetailService
@inject IFavoriteNodeService FavoriteNodeService

@if (IsOpen)
{
    <div class="modal-overlay fixed inset-0 z-50 flex items-center justify-center bg-cinder-950/45 p-4 backdrop-blur-sm"
         @onclick="CloseAsync">
        <article class="liquid-panel flex h-[92vh] w-full max-w-7xl flex-col overflow-hidden rounded-[1.8rem] overscroll-contain"
                 @onclick:stopPropagation="true">
            <header class="flex items-center justify-between border-b border-sand-100/80 px-5 py-4">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Node details</p>
                </div>
                <button type="button"
                        class="liquid-button cursor-pointer rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="CloseAsync">
                    Close
                </button>
            </header>

            <div class="min-h-0 flex-1 overflow-hidden px-5 py-4 overscroll-contain">
                @if (_isLoading)
                {
                    <p class="text-sm text-cinder-800/78">Loading node details...</p>
                }
                else if (!string.IsNullOrWhiteSpace(_loadError))
                {
                    <p class="text-sm text-red-600">@_loadError</p>
                }
                else if (_node is null)
                {
                    <div class="space-y-2">
                        <h2 class="font-display text-3xl text-cinder-950">Node not found</h2>
                        <p class="text-cinder-800">No observed node matched <code class="rounded-full bg-sand-100 px-3 py-1 text-xs">@NodeId</code>.</p>
                    </div>
                }
                else
                {
                    <div class="flex h-full min-h-0 flex-col gap-6">
                        <header class="space-y-3">
                            <div>
                                <h2 class="font-display text-4xl text-cinder-950 sm:text-5xl">@(_node.LongName ?? _node.ShortName ?? _node.NodeId)</h2>
                            </div>
                            <div class="flex flex-wrap items-center gap-2 text-sm text-cinder-800/82">
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@_node.NodeId</code>
                                @if (!string.IsNullOrWhiteSpace(_node.BrokerServer))
                                {
                                    <span class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">MQTT @_node.BrokerServer</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(_node.LastHeardChannel))
                                {
                                    <button type="button"
                                            class="liquid-inline-action cursor-pointer rounded-full px-3 py-1 text-xs font-semibold"
                                            @onclick="() => OpenChannelDetailsAsync(_node.LastHeardChannel!)">
                                        @_node.LastHeardChannel
                                    </button>
                                }
                                @if (_isFavorite)
                                {
                                    <button type="button"
                                            class="liquid-button liquid-button-danger rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                                            @onclick="ToggleFavoriteAsync"
                                            disabled="@_isFavoriteActionPending">
                                        Remove
                                    </button>
                                }
                                else
                                {
                                    <button type="button"
                                            class="liquid-button liquid-button-accent cursor-pointer rounded-full px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                                            @onclick="ToggleFavoriteAsync"
                                            disabled="@_isFavoriteActionPending">
                                        Save
                                    </button>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(_favoriteStatusMessage))
                            {
                                <p class="text-sm text-cinder-800/82">@_favoriteStatusMessage</p>
                            }
                        </header>

                        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Published messages</p>
                                <strong class="mt-2 block text-3xl text-cinder-950">@_publishedMessageCount</strong>
                            </article>
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Displayed messages</p>
                                <strong class="mt-2 block text-3xl text-cinder-950">@_relatedMessagesPage.Items.Count</strong>
                            </article>
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Last heard</p>
                                <strong class="mt-2 block text-sm text-cinder-950">@(_node.LastHeardAtUtc?.ToString("u") ?? "Unknown")</strong>
                            </article>
                            <article class="liquid-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Position</p>
                                <strong class="mt-2 block text-sm text-cinder-950">@FormatPosition(_node)</strong>
                            </article>
                        </section>

                        <section class="grid gap-4 xl:grid-cols-2">
                            <article class="liquid-panel rounded-[1.6rem] px-6 pt-7 pb-6">
                                <h3 class="font-display text-3xl text-cinder-950">Device telemetry</h3>
                                @RenderDeviceTelemetry(_node)
                            </article>
                            <article class="liquid-panel rounded-[1.6rem] px-6 pt-7 pb-6">
                                <h3 class="font-display text-3xl text-cinder-950">Environment telemetry</h3>
                                @RenderEnvironmentTelemetry(_node)
                            </article>
                        </section>

                        <section class="grid min-h-0 flex-1 gap-4 xl:grid-cols-2">
                            <article class="liquid-panel flex h-full min-h-0 flex-col overflow-hidden rounded-[1.6rem]">
                                <div class="border-b border-sand-100/80 px-5 pt-5 pb-4">
                                    <h3 class="font-display text-3xl text-cinder-950">Recent published messages</h3>
                                </div>
                                @if (_isMessagesLoading && _relatedMessagesPage.TotalCount == 0)
                                {
                                    <div class="flex flex-1 items-center p-6 text-cinder-800/78">Loading node messages...</div>
                                }
                                else if (_relatedMessagesPage.Items.Count == 0)
                                {
                                    <div class="flex flex-1 items-center p-6 text-cinder-800/78">No recent packets published by this node.</div>
                                }
                                else
                                {
                                    <div class="fade-scroll-frame min-h-0 flex-1">
                                        <div class="fade-scroll-content fade-scroll-content-fill">
                                            <ul class="space-y-3 p-5 text-sm text-cinder-900">
                                                @foreach (var message in _relatedMessagesPage.Items)
                                                {
                                                    <li class="liquid-subpanel rounded-2xl p-3">
                                                        <div class="flex flex-wrap items-center gap-2">
                                                            <span class="rounded-full bg-sand-100 px-3 py-1 text-xs">@message.PacketType</span>
                                                            <span class="text-xs text-cinder-800/70">@message.ReceivedAtUtc.ToString("u")</span>
                                                        </div>
                                                        <p class="mt-2">@message.PayloadPreview</p>
                                                        <p class="mt-1 text-xs text-cinder-800/70">From @message.FromNodeId to @(message.ToNodeId ?? "Broadcast")</p>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                }
                                <div class="flex flex-wrap items-center justify-between gap-3 border-t border-sand-100/80 px-5 py-4">
                                    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-cinder-800/68">
                                        @GetMessagePagingSummaryText()
                                    </p>
                                    <div class="flex flex-wrap items-center gap-2">
                                        <button type="button"
                                                class="liquid-button cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                                                @onclick="GoToPreviousMessagesPageAsync"
                                                disabled="@(!CanGoToPreviousMessagesPage)">
                                            Previous
                                        </button>
                                        <span class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">
                                            Page @_currentMessagesPage of @GetMessagesTotalPages()
                                        </span>
                                        <button type="button"
                                                class="liquid-button liquid-button-accent cursor-pointer rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] disabled:cursor-not-allowed disabled:opacity-60"
                                                @onclick="GoToNextMessagesPageAsync"
                                                disabled="@(!CanGoToNextMessagesPage)">
                                            Next
                                        </button>
                                    </div>
                                </div>
                            </article>

                            <article class="liquid-panel flex h-full min-h-0 flex-col overflow-hidden rounded-[1.6rem] px-6 pt-7 pb-6">
                                <h3 class="font-display text-3xl text-cinder-950">Map</h3>
                                @if (TryBuildMapEmbedUrl(_node, out var mapEmbedUrl))
                                {
                                    <div class="mt-4 min-h-0 flex-1 overflow-hidden rounded-2xl border border-sand-200">
                                        <iframe title="Node position map"
                                                class="block h-full min-h-[14rem] w-full lg:min-h-0"
                                                src="@mapEmbedUrl"></iframe>
                                    </div>
                                }
                                else
                                {
                                    <p class="mt-4 text-cinder-800/78">No coordinates available for this node yet.</p>
                                }
                            </article>
                        </section>
                    </div>
                }
            </div>
        </article>
    </div>
}

@code {
    private const int MessagesPageSize = 40;

    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string NodeId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<string> OnOpenChannel { get; set; }

    private bool _isLoading;
    private bool _isMessagesLoading;
    private bool _isFavorite;
    private bool _isFavoriteActionPending;
    private string? _loadError;
    private string? _favoriteStatusMessage;
    private NodeSummary? _node;
    private int _publishedMessageCount;
    private MessagePageResult _relatedMessagesPage = new();
    private int _currentMessagesPage = 1;
    private string? _loadedNodeId;

    private bool CanGoToNextMessagesPage =>
        !_isMessagesLoading && !_isLoading && (_currentMessagesPage * MessagesPageSize) < _relatedMessagesPage.TotalCount;

    private bool CanGoToPreviousMessagesPage =>
        !_isMessagesLoading && !_isLoading && _currentMessagesPage > 1;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen || string.IsNullOrWhiteSpace(NodeId))
        {
            _loadedNodeId = null;
            _favoriteStatusMessage = null;
            return;
        }

        if (string.Equals(_loadedNodeId, NodeId, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        _loadedNodeId = NodeId;
        _currentMessagesPage = 1;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _isFavoriteActionPending = false;
        _loadError = null;
        _favoriteStatusMessage = null;

        try
        {
            var nodeTask = CachedNodeDetailService.GetNodeById(NodeId);
            var favoriteNodesTask = FavoriteNodeService.GetFavoriteNodes();

            await Task.WhenAll(nodeTask, favoriteNodesTask);

            _node = await nodeTask;
            var favoriteNodes = await favoriteNodesTask;

            _isFavorite = _node is not null &&
                favoriteNodes.Any(favoriteNode => string.Equals(favoriteNode.NodeId, _node.NodeId, StringComparison.OrdinalIgnoreCase));

            if (_node is null)
            {
                _relatedMessagesPage = new MessagePageResult();
                _publishedMessageCount = 0;
                _isFavorite = false;
                return;
            }

            await LoadMessagesPageAsync();
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
            _node = null;
            _relatedMessagesPage = new MessagePageResult();
            _publishedMessageCount = 0;
            _isFavorite = false;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMessagesPageAsync()
    {
        if (_node is null)
        {
            _relatedMessagesPage = new MessagePageResult();
            _publishedMessageCount = 0;
            return;
        }

        _isMessagesLoading = true;

        try
        {
            var page = await CachedNodeDetailService.GetMessagesPageBySender(
                _node.NodeId,
                offset: (_currentMessagesPage - 1) * MessagesPageSize,
                take: MessagesPageSize);

            if (page.TotalCount > 0 && page.Items.Count == 0 && _currentMessagesPage > 1)
            {
                _currentMessagesPage = GetLastMessagesPageNumber(page.TotalCount);
                page = await CachedNodeDetailService.GetMessagesPageBySender(
                    _node.NodeId,
                    offset: (_currentMessagesPage - 1) * MessagesPageSize,
                    take: MessagesPageSize);
            }

            _relatedMessagesPage = page;
            _publishedMessageCount = page.TotalCount;
        }
        finally
        {
            _isMessagesLoading = false;
        }
    }

    private async Task GoToPreviousMessagesPageAsync()
    {
        if (!CanGoToPreviousMessagesPage)
        {
            return;
        }

        _currentMessagesPage--;
        await LoadMessagesPageAsync();
    }

    private async Task GoToNextMessagesPageAsync()
    {
        if (!CanGoToNextMessagesPage)
        {
            return;
        }

        _currentMessagesPage++;
        await LoadMessagesPageAsync();
    }

    private async Task ToggleFavoriteAsync()
    {
        if (_node is null || _isFavoriteActionPending)
        {
            return;
        }

        _isFavoriteActionPending = true;
        _favoriteStatusMessage = null;

        try
        {
            if (_isFavorite)
            {
                await FavoriteNodeService.RemoveFavoriteNode(_node.NodeId);
                _isFavorite = false;
                _favoriteStatusMessage = $"Removed {_node.NodeId} from favorites.";
                return;
            }

            await FavoriteNodeService.SaveFavoriteNode(
                new SaveFavoriteNodeRequest
                {
                    NodeId = _node.NodeId,
                    ShortName = _node.ShortName,
                    LongName = _node.LongName
                });

            _isFavorite = true;
            _favoriteStatusMessage = $"Saved {_node.NodeId} to favorites.";
        }
        catch (Exception exception)
        {
            _favoriteStatusMessage = exception.Message;
        }
        finally
        {
            _isFavoriteActionPending = false;
        }
    }

    private async Task CloseAsync()
    {
        await OnClose.InvokeAsync();
    }

    private async Task OpenChannelDetailsAsync(string channelKey)
    {
        if (!OnOpenChannel.HasDelegate)
        {
            return;
        }

        await OnClose.InvokeAsync();
        await OnOpenChannel.InvokeAsync(channelKey);
    }

    private static string FormatPosition(NodeSummary node)
    {
        return node.LastKnownLatitude.HasValue && node.LastKnownLongitude.HasValue
            ? $"{node.LastKnownLatitude.Value:F5}, {node.LastKnownLongitude.Value:F5}"
            : "Unknown";
    }

    private static bool TryBuildMapEmbedUrl(NodeSummary node, out string mapEmbedUrl)
    {
        if (!node.LastKnownLatitude.HasValue || !node.LastKnownLongitude.HasValue)
        {
            mapEmbedUrl = string.Empty;
            return false;
        }

        var latitude = node.LastKnownLatitude.Value;
        var longitude = node.LastKnownLongitude.Value;
        const double delta = 0.02;

        var left = longitude - delta;
        var right = longitude + delta;
        var top = latitude + delta;
        var bottom = latitude - delta;

        mapEmbedUrl =
            $"https://www.openstreetmap.org/export/embed.html?bbox={left.ToString(System.Globalization.CultureInfo.InvariantCulture)}%2C{bottom.ToString(System.Globalization.CultureInfo.InvariantCulture)}%2C{right.ToString(System.Globalization.CultureInfo.InvariantCulture)}%2C{top.ToString(System.Globalization.CultureInfo.InvariantCulture)}&layer=mapnik&marker={latitude.ToString(System.Globalization.CultureInfo.InvariantCulture)}%2C{longitude.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
        return true;
    }

    private string GetMessagePagingSummaryText()
    {
        if (_isMessagesLoading && _relatedMessagesPage.TotalCount == 0)
        {
            return "Loading packets";
        }

        if (_relatedMessagesPage.TotalCount == 0)
        {
            return "No packets found";
        }

        var start = ((_currentMessagesPage - 1) * MessagesPageSize) + 1;
        var end = Math.Min(_currentMessagesPage * MessagesPageSize, _relatedMessagesPage.TotalCount);

        return $"Showing {start}-{end} of {_relatedMessagesPage.TotalCount} packets";
    }

    private int GetLastMessagesPageNumber(int totalCount)
    {
        return Math.Max(1, (int)Math.Ceiling(totalCount / (double)MessagesPageSize));
    }

    private int GetMessagesTotalPages()
    {
        return _relatedMessagesPage.TotalCount == 0 ? 1 : GetLastMessagesPageNumber(_relatedMessagesPage.TotalCount);
    }

    private static string GetBatteryClass(int batteryLevel)
    {
        return batteryLevel switch
        {
            <= 15 => "bg-red-100 text-red-700",
            <= 35 => "bg-orange-100 text-orange-700",
            <= 60 => "bg-amber-100 text-amber-700",
            _ => "bg-emerald-100 text-emerald-700"
        };
    }

    private static RenderFragment RenderDeviceTelemetry(NodeSummary node) => builder =>
    {
        var bubbles = new List<(string Text, string ClassName)>();

        if (node.BatteryLevelPercent.HasValue)
        {
            bubbles.Add(($"{node.BatteryLevelPercent.Value}% battery", GetBatteryClass(node.BatteryLevelPercent.Value)));
        }

        if (node.Voltage.HasValue)
        {
            bubbles.Add(($"{node.Voltage.Value:F2}V", "bg-cinder-900/8 text-cinder-900"));
        }

        if (node.ChannelUtilization.HasValue)
        {
            bubbles.Add(($"{node.ChannelUtilization.Value:F1}% ch", "bg-signal-500/12 text-signal-600"));
        }

        if (node.AirUtilTx.HasValue)
        {
            bubbles.Add(($"{node.AirUtilTx.Value:F1}% tx", "bg-sand-200 text-cinder-900"));
        }

        if (node.UptimeSeconds.HasValue)
        {
            bubbles.Add((FormatUptime(node.UptimeSeconds.Value), "bg-cinder-900/8 text-cinder-900"));
        }

        if (bubbles.Count == 0)
        {
            builder.AddContent(0, "No telemetry");
            return;
        }

        builder.OpenElement(1, "div");
        builder.AddAttribute(2, "class", "mt-4 flex flex-wrap gap-2");

        var sequence = 3;
        foreach (var bubble in bubbles)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", $"rounded-full px-3 py-1 text-xs font-semibold {bubble.ClassName}");
            builder.AddContent(sequence++, bubble.Text);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static RenderFragment RenderEnvironmentTelemetry(NodeSummary node) => builder =>
    {
        var bubbles = new List<(string Text, string ClassName)>();

        if (node.TemperatureCelsius.HasValue)
        {
            bubbles.Add(($"{node.TemperatureCelsius.Value:F1}C", "bg-signal-500/12 text-signal-600"));
        }

        if (node.RelativeHumidity.HasValue)
        {
            bubbles.Add(($"{node.RelativeHumidity.Value:F1}% RH", "bg-cinder-900/8 text-cinder-900"));
        }

        if (node.BarometricPressure.HasValue)
        {
            bubbles.Add(($"{node.BarometricPressure.Value:F1} hPa", "bg-sand-200 text-cinder-900"));
        }

        if (bubbles.Count == 0)
        {
            builder.AddContent(0, "No telemetry");
            return;
        }

        builder.OpenElement(1, "div");
        builder.AddAttribute(2, "class", "mt-4 flex flex-wrap gap-2");

        var sequence = 3;
        foreach (var bubble in bubbles)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", $"rounded-full px-3 py-1 text-xs font-semibold {bubble.ClassName}");
            builder.AddContent(sequence++, bubble.Text);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private static string FormatUptime(long uptimeSeconds)
    {
        var uptime = TimeSpan.FromSeconds(uptimeSeconds);

        if (uptime.TotalDays >= 1)
        {
            return $"{(int)uptime.TotalDays}d {uptime.Hours}h";
        }

        if (uptime.TotalHours >= 1)
        {
            return $"{(int)uptime.TotalHours}h {uptime.Minutes}m";
        }

        return $"{uptime.Minutes}m";
    }
}
