{
  "MeshtasticRuntime": {
    "EnableHostedService": true
  },
  "Broker": {
    "Host": "mqtt.meshtastic.org",
    "Port": 1883,
    "UseTls": false,
    "ClientId": "meshboard-realtime-bridge",
    "DefaultTopicPattern": "msh/US/2/e/#",
    "DownlinkTopic": "msh/US/2/json/mqtt/",
    "EnableSend": false
  },
  "RealtimeDownstreamBroker": {
    "Host": "localhost",
    "Port": 1883,
    "UseTls": false,
    "ClientId": "meshboard-realtime-bridge",
    "Username": "",
    "Password": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Persistence": {
    "Provider": "PostgreSQL",
    "ConnectionString": "Host=localhost;Port=15432;Database=meshboard;Username=meshboard;Password=meshboard"
  }
}
