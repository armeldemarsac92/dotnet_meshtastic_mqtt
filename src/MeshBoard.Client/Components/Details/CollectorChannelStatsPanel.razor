@using MeshBoard.Client.Services
@using MeshBoard.Contracts.Collector
@inject PublicCollectorApiClient PublicCollectorApiClient

@if (!string.IsNullOrWhiteSpace(Region) && !string.IsNullOrWhiteSpace(ChannelName))
{
    <section class="grid gap-4 xl:grid-cols-[0.95fr_1.05fr]">
        <article class="shell-panel rounded-[1.6rem] px-6 pt-7 pb-6">
            <div class="flex items-center justify-between gap-3">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Collector stats</p>
                    <h3 class="mt-2 font-display text-3xl text-cinder-950">Channel analysis</h3>
                </div>
                <span class="rounded-full bg-sand-100 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-cinder-900">7 days</span>
            </div>

            @if (_isLoading)
            {
                <p class="mt-5 text-sm text-cinder-800/72">Loading collector stats...</p>
            }
            else if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <p class="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_errorMessage</p>
            }
            else
            {
                <div class="mt-5 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
                    <article class="shell-subpanel rounded-[1.4rem] p-4">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Packets</p>
                        <p class="mt-3 text-2xl font-semibold text-cinder-950">@GetPacketCount()</p>
                    </article>
                    <article class="shell-subpanel rounded-[1.4rem] p-4">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Packet types</p>
                        <p class="mt-3 text-2xl font-semibold text-cinder-950">@_packetTypeSummaries.Count</p>
                    </article>
                    <article class="shell-subpanel rounded-[1.4rem] p-4">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Peak active nodes</p>
                        <p class="mt-3 text-2xl font-semibold text-cinder-950">@GetPeakActiveNodeCount()</p>
                    </article>
                    <article class="shell-subpanel rounded-[1.4rem] p-4">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Link observations</p>
                        <p class="mt-3 text-2xl font-semibold text-cinder-950">@GetNeighborObservationCount()</p>
                    </article>
                </div>

                <div class="mt-5 grid gap-4 lg:grid-cols-2">
                    <div class="shell-subpanel rounded-[1.4rem] p-4">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Packet mix</p>
                        @if (_packetTypeSummaries.Count == 0)
                        {
                            <p class="mt-3 text-sm text-cinder-800/72">No collector packet rollups matched this channel.</p>
                        }
                        else
                        {
                            <ul class="mt-4 space-y-3 text-sm text-cinder-900">
                                @foreach (var summary in _packetTypeSummaries)
                                {
                                    <li class="flex items-center justify-between gap-4 rounded-2xl border border-sand-100/80 bg-white/60 px-4 py-3">
                                        <span>@summary.PacketType</span>
                                        <strong>@summary.PacketCount</strong>
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    <div class="shell-subpanel rounded-[1.4rem] p-4">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Strongest radio links</p>
                        @if (_linkSummaries.Count == 0)
                        {
                            <p class="mt-3 text-sm text-cinder-800/72">No collector radio-link rollups matched this channel.</p>
                        }
                        else
                        {
                            <ul class="mt-4 space-y-3 text-sm text-cinder-900">
                                @foreach (var summary in _linkSummaries)
                                {
                                    <li class="rounded-2xl border border-sand-100/80 bg-white/60 px-4 py-3">
                                        <div class="flex items-center justify-between gap-4">
                                            <span class="font-medium">@summary.Label</span>
                                            <strong>@summary.ObservationCount</strong>
                                        </div>
                                        <div class="mt-2 flex flex-wrap gap-3 text-xs text-cinder-800/70">
                                            <span>Avg SNR: @FormatSnr(summary.AverageSnrDb)</span>
                                            <span>Max SNR: @FormatSnr(summary.MaxSnrDb)</span>
                                            <span>Last seen: @FormatTimestamp(summary.LastSeenAtUtc)</span>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            }
        </article>
    </section>
}

@code {
    private const int LookbackHours = 24 * 7;
    private CollectorChannelPacketStatsSnapshot? _channelStats;
    private string? _errorMessage;
    private bool _isLoading;
    private string? _lastLoadedScopeKey;
    private IReadOnlyList<LinkSummary> _linkSummaries = Array.Empty<LinkSummary>();
    private CollectorNeighborLinkStatsSnapshot? _neighborStats;
    private IReadOnlyList<PacketTypeSummary> _packetTypeSummaries = Array.Empty<PacketTypeSummary>();

    [Parameter]
    public string? ChannelName { get; set; }

    [Parameter]
    public string? Region { get; set; }

    [Parameter]
    public string? ServerAddress { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        var scopeKey = BuildScopeKey();
        if (scopeKey is null)
        {
            _lastLoadedScopeKey = null;
            _channelStats = null;
            _neighborStats = null;
            _packetTypeSummaries = Array.Empty<PacketTypeSummary>();
            _linkSummaries = Array.Empty<LinkSummary>();
            _errorMessage = null;
            _isLoading = false;
            return;
        }

        if (string.Equals(_lastLoadedScopeKey, scopeKey, StringComparison.Ordinal))
        {
            return;
        }

        await LoadAsync(scopeKey);
    }

    private async Task LoadAsync(string scopeKey)
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var channelStatsTask = PublicCollectorApiClient.GetChannelPacketStatsAsync(
                new CollectorPacketStatsQuery
                {
                    ServerAddress = ServerAddress,
                    Region = Region,
                    ChannelName = ChannelName,
                    LookbackHours = LookbackHours,
                    MaxRows = 240
                });
            var neighborStatsTask = PublicCollectorApiClient.GetNeighborLinkStatsAsync(
                new CollectorNeighborLinkStatsQuery
                {
                    ServerAddress = ServerAddress,
                    Region = Region,
                    ChannelName = ChannelName,
                    LookbackHours = LookbackHours,
                    MaxRows = 120
                });

            await Task.WhenAll(channelStatsTask, neighborStatsTask);

            _channelStats = await channelStatsTask;
            _neighborStats = await neighborStatsTask;
            _packetTypeSummaries = BuildPacketTypeSummaries(_channelStats);
            _linkSummaries = BuildLinkSummaries(_neighborStats);
            _lastLoadedScopeKey = scopeKey;
        }
        catch (Exception exception)
        {
            _channelStats = null;
            _neighborStats = null;
            _packetTypeSummaries = Array.Empty<PacketTypeSummary>();
            _linkSummaries = Array.Empty<LinkSummary>();
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private string? BuildScopeKey()
    {
        return string.IsNullOrWhiteSpace(Region) || string.IsNullOrWhiteSpace(ChannelName)
            ? null
            : $"{ServerAddress?.Trim()}|{Region.Trim()}|{ChannelName.Trim()}";
    }

    private int GetPacketCount() => _packetTypeSummaries.Sum(summary => summary.PacketCount);

    private int GetPeakActiveNodeCount()
    {
        return _channelStats?.Rollups.Any() == true
            ? _channelStats.Rollups.Max(rollup => rollup.ActiveNodeCount)
            : 0;
    }

    private int GetNeighborObservationCount() => _linkSummaries.Sum(summary => summary.ObservationCount);

    private static IReadOnlyList<PacketTypeSummary> BuildPacketTypeSummaries(CollectorChannelPacketStatsSnapshot? snapshot)
    {
        return snapshot?.Rollups
            .GroupBy(rollup => rollup.PacketType, StringComparer.OrdinalIgnoreCase)
            .Select(group => new PacketTypeSummary(group.Key, group.Sum(rollup => rollup.PacketCount)))
            .OrderByDescending(summary => summary.PacketCount)
            .ThenBy(summary => summary.PacketType, StringComparer.OrdinalIgnoreCase)
            .Take(6)
            .ToArray()
            ?? [];
    }

    private static IReadOnlyList<LinkSummary> BuildLinkSummaries(CollectorNeighborLinkStatsSnapshot? snapshot)
    {
        return snapshot?.Rollups
            .GroupBy(
                rollup => $"{rollup.SourceNodeId}|{rollup.TargetNodeId}",
                StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var latest = group
                    .OrderByDescending(entry => entry.LastSeenAtUtc)
                    .First();
                var averages = group
                    .Where(entry => entry.AverageSnrDb.HasValue)
                    .Select(entry => entry.AverageSnrDb!.Value)
                    .ToArray();

                return new LinkSummary(
                    $"{latest.SourceLongName ?? latest.SourceShortName ?? latest.SourceNodeId} → {latest.TargetLongName ?? latest.TargetShortName ?? latest.TargetNodeId}",
                    group.Sum(entry => entry.ObservationCount),
                    averages.Length == 0 ? null : averages.Average(),
                    group
                        .Where(entry => entry.MaxSnrDb.HasValue)
                        .Select(entry => (double?)entry.MaxSnrDb)
                        .DefaultIfEmpty()
                        .Max(),
                    group.Max(entry => entry.LastSeenAtUtc));
            })
            .OrderByDescending(summary => summary.ObservationCount)
            .ThenBy(summary => summary.Label, StringComparer.OrdinalIgnoreCase)
            .Take(6)
            .ToArray()
            ?? [];
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
            : "Unknown";
    }

    private static string FormatSnr(double? value)
    {
        return value.HasValue
            ? FormattableString.Invariant($"{value.Value:F1} dB")
            : "Unknown";
    }

    private sealed record PacketTypeSummary(string PacketType, int PacketCount);

    private sealed record LinkSummary(
        string Label,
        int ObservationCount,
        double? AverageSnrDb,
        double? MaxSnrDb,
        DateTimeOffset LastSeenAtUtc);
}
