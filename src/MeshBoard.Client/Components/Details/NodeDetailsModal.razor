@using MeshBoard.Client.Collector
@using MeshBoard.Client.Messages
@using MeshBoard.Client.Nodes
@using MeshBoard.Client.Services
@using MeshBoard.Contracts.Collector
@using MeshBoard.Contracts.Nodes
@implements IAsyncDisposable
@inject DecryptedMessageStore DecryptedMessageStore
@inject IJSRuntime JS
@inject NodeProjectionStore NodeProjectionStore
@inject PublicCollectorApiClient PublicCollectorApiClient
@inject PublicCollectorService PublicCollectorService

@if (IsOpen)
{
    <div class="fixed inset-0 z-[60] flex items-center justify-center bg-cinder-950/45 p-4 pb-[5.5rem] backdrop-blur-sm lg:pb-4"
         @onclick="CloseAsync">
        <article class="shell-panel flex max-h-[calc(100dvh-8rem)] w-full max-w-6xl flex-col overflow-hidden rounded-[1.8rem] lg:max-h-[92vh]"
                 @onclick:stopPropagation="true">
            <header class="flex items-center justify-between gap-4 border-b border-sand-100/80 px-5 py-4">
                <div class="flex items-center gap-3">
                    @if (_historyStack.Count > 0)
                    {
                        <button type="button"
                                class="shell-button rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                                @onclick="NavigateBackAsync">
                            Back
                        </button>
                    }
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Node details</p>
                </div>

                <button type="button"
                        class="shell-button rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="CloseAsync">
                    Close
                </button>
            </header>

            <div class="min-h-0 flex-1 overflow-y-auto overscroll-y-contain px-5 py-4">
                @if (_isLoadingCollectorNode && !HasNodeData)
                {
                    <p class="text-sm text-cinder-800/72">Loading node data...</p>
                }
                else if (!HasNodeData)
                {
                    <div class="space-y-2">
                        <h2 class="font-display text-3xl text-cinder-950">Node not found</h2>
                        <p class="text-sm leading-7 text-cinder-800/80">
                            No live node projection or collector-backed data currently matches
                            <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@_currentNodeId</code>.
                        </p>
                    </div>
                }
                else
                {
                    <div class="flex h-full min-h-0 flex-col gap-6">
                        <header class="space-y-3">
                            <div>
                                <h2 class="font-display text-4xl text-cinder-950 sm:text-5xl">@EffectiveDisplayName</h2>
                            </div>

                            <div class="flex flex-wrap items-center gap-2 text-sm text-cinder-800/82">
                                <code class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@_currentNodeId</code>
                                @if (!string.IsNullOrWhiteSpace(EffectiveChannelKey))
                                {
                                    <button type="button"
                                            class="shell-button shell-button-accent rounded-full px-3 py-1 text-xs font-semibold"
                                            @onclick="() => OpenChannelAsync(EffectiveChannelKey!)">
                                        @EffectiveChannelKey
                                    </button>
                                }
                                @if (_node is not null)
                                {
                                    <span class="rounded-full bg-white/75 px-3 py-1 text-xs text-cinder-800/78">@_node.ObservedPacketCount observed packets</span>
                                }
                                @if (_collectorNode is not null && _node is null)
                                {
                                    <span class="rounded-full bg-white/75 px-3 py-1 text-xs text-cinder-800/78">Collector-backed snapshot</span>
                                }
                            </div>
                        </header>

                        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
                            <article class="shell-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Observed packets</p>
                                <strong class="mt-2 block text-3xl text-cinder-950">@(_node?.ObservedPacketCount ?? 0)</strong>
                            </article>
                            <article class="shell-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Buffered messages</p>
                                <strong class="mt-2 block text-3xl text-cinder-950">@_relatedMessages.Count</strong>
                            </article>
                            <article class="shell-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Last heard</p>
                                <strong class="mt-2 block text-sm text-cinder-950">@FormatTimestamp(EffectiveLastHeardAtUtc)</strong>
                            </article>
                            <article class="shell-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Broker</p>
                                <strong class="mt-2 block text-sm text-cinder-950">@EffectiveBrokerServer</strong>
                            </article>
                            <article class="shell-subpanel rounded-[1.4rem] p-5">
                                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Position</p>
                                <strong class="mt-2 block text-sm text-cinder-950">@FormatPosition()</strong>
                            </article>
                        </section>

                        <CollectorNodeStatsPanel NodeId="@_currentNodeId" OnNeighborNodeClicked="OpenNeighborNodeAsync" />

                        <section class="grid gap-4 xl:grid-cols-2">
                            <article class="shell-panel rounded-[1.6rem] px-6 pt-7 pb-6">
                                <h3 class="font-display text-3xl text-cinder-950">Device telemetry</h3>
                                <dl class="mt-5 grid gap-3 text-sm text-cinder-900">
                                    @foreach (var item in GetDeviceTelemetryItems())
                                    {
                                        <div class="flex items-center justify-between gap-4 rounded-2xl border border-sand-100/80 bg-white/55 px-4 py-3">
                                            <dt class="text-cinder-800/68">@item.Label</dt>
                                            <dd class="text-right">@item.Value</dd>
                                        </div>
                                    }
                                </dl>
                            </article>

                            <article class="shell-panel rounded-[1.6rem] px-6 pt-7 pb-6">
                                <h3 class="font-display text-3xl text-cinder-950">Environment telemetry</h3>
                                <dl class="mt-5 grid gap-3 text-sm text-cinder-900">
                                    @foreach (var item in GetEnvironmentTelemetryItems())
                                    {
                                        <div class="flex items-center justify-between gap-4 rounded-2xl border border-sand-100/80 bg-white/55 px-4 py-3">
                                            <dt class="text-cinder-800/68">@item.Label</dt>
                                            <dd class="text-right">@item.Value</dd>
                                        </div>
                                    }
                                </dl>
                            </article>
                        </section>

                        <section class="grid min-h-0 flex-1 gap-4 xl:grid-cols-2">
                            <article class="shell-panel flex min-h-[20rem] flex-col overflow-hidden rounded-[1.6rem]">
                                <div class="border-b border-sand-100/80 px-5 pt-5 pb-4">
                                    <h3 class="font-display text-3xl text-cinder-950">Recent decoded messages</h3>
                                </div>

                                @if (_relatedMessages.Count == 0)
                                {
                                    <div class="flex flex-1 items-center p-6 text-sm leading-7 text-cinder-800/78">
                                        No decoded messages from this node are currently retained in the local browser buffer.
                                    </div>
                                }
                                else
                                {
                                    <div class="min-h-0 flex-1 overflow-y-auto p-5">
                                        <ul class="space-y-3 text-sm text-cinder-900">
                                            @foreach (var message in _relatedMessages)
                                            {
                                                <li class="shell-subpanel rounded-2xl p-4">
                                                    <div class="flex flex-wrap items-center gap-2">
                                                        <span class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">@FormatPacketType(message.PacketType)</span>
                                                        <span class="text-xs text-cinder-800/70">@FormatTimestamp(message.ReceivedAtUtc)</span>
                                                        @if (message.HopStart.HasValue && message.HopLimit.HasValue && message.HopStart == message.HopLimit)
                                                        {
                                                            <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs text-emerald-800">Direct</span>
                                                        }
                                                        else if (message.HopStart.HasValue && message.HopLimit.HasValue)
                                                        {
                                                            <span class="rounded-full bg-sky-100 px-3 py-1 text-xs text-sky-800">@(message.HopStart - message.HopLimit) hop@(message.HopStart - message.HopLimit == 1 ? "" : "s")</span>
                                                        }
                                                        @if (message.RxSnr.HasValue)
                                                        {
                                                            <span class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">SNR @message.RxSnr.Value.ToString("F1") dB</span>
                                                        }
                                                        @if (message.RxRssi.HasValue)
                                                        {
                                                            <span class="rounded-full bg-sand-100 px-3 py-1 text-xs text-cinder-900">RSSI @message.RxRssi.Value dBm</span>
                                                        }
                                                    </div>
                                                    <p class="mt-3 leading-7 text-cinder-900">@FormatPayloadPreview(message.PayloadPreview)</p>
                                                    @if (message.TracerouteInfo is not null && message.TracerouteInfo.RouteNodeIds.Count > 0)
                                                    {
                                                        <div class="mt-2 flex flex-wrap items-center gap-1 text-xs text-cinder-800/68">
                                                            <span>Route:</span>
                                                            @for (var i = 0; i < message.TracerouteInfo.RouteNodeIds.Count; i++)
                                                            {
                                                                <code class="rounded bg-sand-100 px-2 py-0.5 text-cinder-900">@message.TracerouteInfo.RouteNodeIds[i]</code>
                                                                @if (i < message.TracerouteInfo.RouteNodeIds.Count - 1)
                                                                {
                                                                    <span>→</span>
                                                                }
                                                            }
                                                        </div>
                                                    }
                                                    <p class="mt-2 text-xs text-cinder-800/68">From @FormatNodeId(message.SourceNodeNumber ?? message.FromNodeNumber) to @(FormatNodeId(message.DestinationNodeNumber) ?? "Broadcast")</p>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </article>

                            <article class="shell-panel flex min-h-[20rem] flex-col overflow-hidden rounded-[1.6rem] px-6 pt-7 pb-6">
                                <h3 class="font-display text-3xl text-cinder-950">Map</h3>

                                @if (EffectiveLatitude.HasValue && EffectiveLongitude.HasValue)
                                {
                                    <div id="@MiniMapElementId"
                                         class="mt-4 min-h-0 flex-1 overflow-hidden rounded-2xl border border-sand-200/80"></div>
                                }
                                else
                                {
                                    <p class="mt-4 text-sm leading-7 text-cinder-800/78">No coordinates are available for this node yet.</p>
                                }

                                @if (!string.IsNullOrWhiteSpace(_node?.LastPayloadPreview))
                                {
                                    <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50/90 px-4 py-3 text-sm leading-7 text-cinder-900">
                                        @_node!.LastPayloadPreview
                                    </div>
                                }
                            </article>
                        </section>
                    </div>
                }
            </div>
        </article>
    </div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public string NodeId { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback<string> OnOpenChannel { get; set; }

    [Parameter]
    public EventCallback<string> OnOpenNode { get; set; }

    private bool HasNodeData => _node is not null || _collectorNode is not null;

    private string EffectiveBrokerServer => _node?.BrokerServer ?? _collectorNode?.BrokerServer ?? "Unknown";

    private string? EffectiveChannelKey => _node?.LastHeardChannel ?? _collectorNode?.LastHeardChannel;

    private string EffectiveDisplayName => _node?.DisplayName ?? _collectorNode?.LongName ?? _collectorNode?.ShortName ?? _currentNodeId;

    private DateTimeOffset? EffectiveLastHeardAtUtc => _node?.LastHeardAtUtc ?? _collectorNode?.LastHeardAtUtc;

    private double? EffectiveLatitude => _node?.LastKnownLatitude ?? _collectorNode?.LastKnownLatitude;

    private double? EffectiveLongitude => _node?.LastKnownLongitude ?? _collectorNode?.LastKnownLongitude;

    private readonly Stack<string> _historyStack = new();
    private string _currentNodeId = string.Empty;
    private string _lastExternalNodeId = string.Empty;

    private NodeSummary? _collectorNode;
    private NodeSummary? _apiNode;
    private string? _lastApiNodeId;
    private bool _isLoadingCollectorNode;
    private const string MiniMapElementId = "meshboard-node-detail-mini-map";
    private NodeProjectionEnvelope? _node;
    private IReadOnlyList<DecryptedMessageEnvelope> _relatedMessages = Array.Empty<DecryptedMessageEnvelope>();
    private bool _scrollLocked;
    private bool _miniMapRendered;
    private string? _lastMiniMapNodeId;
    private Lazy<Task<IJSObjectReference>>? _moduleTask;

    protected override void OnInitialized()
    {
        NodeProjectionStore.Changed += HandleStoreChanged;
        DecryptedMessageStore.Changed += HandleStoreChanged;
        PublicCollectorService.Changed += HandleStoreChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen && _miniMapRendered)
        {
            await DisposeMiniMapAsync();
        }

        // Detect external node change from parent — reset internal navigation history
        if (!string.Equals(_lastExternalNodeId, NodeId, StringComparison.OrdinalIgnoreCase))
        {
            _lastExternalNodeId = NodeId;
            _historyStack.Clear();
            _currentNodeId = NodeId;
            _miniMapRendered = false;
            _lastMiniMapNodeId = null;
        }

        RefreshProjectionData();
        await SyncScrollLockAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsOpen || EffectiveLatitude is null || EffectiveLongitude is null)
        {
            return;
        }

        if (_miniMapRendered && string.Equals(_lastMiniMapNodeId, _currentNodeId, StringComparison.Ordinal))
        {
            return;
        }

        try
        {
            var module = await GetMapModuleAsync();
            await module.InvokeVoidAsync("renderMiniMap", MiniMapElementId, EffectiveLatitude.Value, EffectiveLongitude.Value);
            _miniMapRendered = true;
            _lastMiniMapNodeId = _currentNodeId;
        }
        catch (JSDisconnectedException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        NodeProjectionStore.Changed -= HandleStoreChanged;
        DecryptedMessageStore.Changed -= HandleStoreChanged;
        PublicCollectorService.Changed -= HandleStoreChanged;

        if (_scrollLocked)
        {
            _scrollLocked = false;
            try { await JS.InvokeVoidAsync("meshboardUi.unlockScroll"); }
            catch (JSDisconnectedException) { }
        }

        await DisposeMiniMapAsync();

        if (_moduleTask?.IsValueCreated == true)
        {
            try
            {
                var module = await _moduleTask.Value;
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

    private Task<IJSObjectReference> GetMapModuleAsync()
    {
        _moduleTask ??= new Lazy<Task<IJSObjectReference>>(
            () => JS.InvokeAsync<IJSObjectReference>("import", "./js/node-map.js?v=5").AsTask());
        return _moduleTask.Value;
    }

    private async Task DisposeMiniMapAsync()
    {
        if (!_miniMapRendered)
        {
            return;
        }

        _miniMapRendered = false;
        _lastMiniMapNodeId = null;

        if (_moduleTask?.IsValueCreated == true)
        {
            try
            {
                var module = await _moduleTask.Value;
                await module.InvokeVoidAsync("disposeMiniMap", MiniMapElementId);
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

    private async Task SyncScrollLockAsync()
    {
        if (IsOpen && !_scrollLocked)
        {
            _scrollLocked = true;
            await JS.InvokeVoidAsync("meshboardUi.lockScroll");
        }
        else if (!IsOpen && _scrollLocked)
        {
            _scrollLocked = false;
            await JS.InvokeVoidAsync("meshboardUi.unlockScroll");
        }
    }

    private void HandleStoreChanged()
    {
        if (!IsOpen)
        {
            return;
        }

        RefreshProjectionData();
        _ = InvokeAsync(StateHasChanged);
    }

    private void RefreshProjectionData()
    {
        if (!IsOpen || string.IsNullOrWhiteSpace(_currentNodeId))
        {
            _node = null;
            _collectorNode = null;
            _apiNode = null;
            _lastApiNodeId = null;
            _isLoadingCollectorNode = false;
            _relatedMessages = Array.Empty<DecryptedMessageEnvelope>();
            return;
        }

        // Clear cached API node if current node changed
        if (!string.Equals(_lastApiNodeId, _currentNodeId, StringComparison.OrdinalIgnoreCase))
        {
            _apiNode = null;
        }

        _node = NodeProjectionStore.Current.Nodes
            .FirstOrDefault(node => string.Equals(node.NodeId, _currentNodeId, StringComparison.OrdinalIgnoreCase));

        // Prefer map snapshot; fall back to previously fetched API node
        _collectorNode = PublicCollectorService.State.MapSnapshot?.Nodes
            .FirstOrDefault(node => string.Equals(node.NodeId, _currentNodeId, StringComparison.OrdinalIgnoreCase))
            ?? _apiNode;

        // Kick off API fetch when neither live nor snapshot has the node
        if (_node is null && _collectorNode is null
            && !_isLoadingCollectorNode
            && !string.Equals(_lastApiNodeId, _currentNodeId, StringComparison.OrdinalIgnoreCase))
        {
            _ = LoadCollectorNodeAsync(_currentNodeId);
        }

        var effectiveNodeId = _node?.NodeId ?? _collectorNode?.NodeId;
        if (effectiveNodeId is null || !ProjectionDetailsSupport.TryParseNodeNumber(effectiveNodeId, out var nodeNumber))
        {
            _relatedMessages = Array.Empty<DecryptedMessageEnvelope>();
            return;
        }

        _relatedMessages = DecryptedMessageStore.Current.Messages
            .Where(message => message.SourceNodeNumber == nodeNumber || message.FromNodeNumber == nodeNumber)
            .OrderByDescending(message => message.ReceivedAtUtc)
            .Take(40)
            .ToArray();
    }

    private async Task LoadCollectorNodeAsync(string nodeId)
    {
        _isLoadingCollectorNode = true;
        _lastApiNodeId = nodeId;
        await InvokeAsync(StateHasChanged);

        try
        {
            var page = await PublicCollectorApiClient.GetNodePageAsync(new CollectorNodePageQuery
            {
                SearchText = nodeId,
                PageSize = 10
            });

            // Verify node hasn't changed while we were fetching
            if (!string.Equals(nodeId, _currentNodeId, StringComparison.OrdinalIgnoreCase))
            {
                return;
            }

            _apiNode = page.Items.FirstOrDefault(n =>
                string.Equals(n.NodeId, nodeId, StringComparison.OrdinalIgnoreCase));
            _collectorNode = PublicCollectorService.State.MapSnapshot?.Nodes
                .FirstOrDefault(n => string.Equals(n.NodeId, nodeId, StringComparison.OrdinalIgnoreCase))
                ?? _apiNode;
        }
        catch
        {
            // Silently fail — "node not found" state will display
        }
        finally
        {
            _isLoadingCollectorNode = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenNeighborNodeAsync(string nodeId)
    {
        if (string.IsNullOrWhiteSpace(nodeId)) return;

        if (!string.IsNullOrWhiteSpace(_currentNodeId))
            _historyStack.Push(_currentNodeId);

        _currentNodeId = nodeId;
        _miniMapRendered = false;
        _lastMiniMapNodeId = null;
        RefreshProjectionData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task NavigateBackAsync()
    {
        if (_historyStack.Count == 0) return;

        _currentNodeId = _historyStack.Pop();
        _miniMapRendered = false;
        _lastMiniMapNodeId = null;
        RefreshProjectionData();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseAsync()
    {
        await OnClose.InvokeAsync();
    }

    private async Task OpenChannelAsync(string channelKey)
    {
        if (!OnOpenChannel.HasDelegate)
        {
            return;
        }

        await OnClose.InvokeAsync();
        await OnOpenChannel.InvokeAsync(channelKey);
    }

    private IReadOnlyList<DetailItem> GetDeviceTelemetryItems()
    {
        var items = new List<DetailItem>();

        if ((_node?.BatteryLevelPercent ?? _collectorNode?.BatteryLevelPercent) is { } batteryLevelPercent)
        {
            items.Add(new DetailItem("Battery", $"{batteryLevelPercent}%"));
        }

        if ((_node?.Voltage ?? _collectorNode?.Voltage) is { } voltage)
        {
            items.Add(new DetailItem("Voltage", FormattableString.Invariant($"{voltage:F2}V")));
        }

        if ((_node?.ChannelUtilization ?? _collectorNode?.ChannelUtilization) is { } channelUtilization)
        {
            items.Add(new DetailItem("Channel utilization", FormattableString.Invariant($"{channelUtilization:F1}%")));
        }

        if ((_node?.AirUtilTx ?? _collectorNode?.AirUtilTx) is { } airUtilTx)
        {
            items.Add(new DetailItem("Air utilization TX", FormattableString.Invariant($"{airUtilTx:F1}%")));
        }

        if ((_node?.UptimeSeconds ?? _collectorNode?.UptimeSeconds) is { } uptimeSeconds)
        {
            items.Add(new DetailItem("Uptime", FormatDuration(uptimeSeconds)));
        }

        if (items.Count == 0)
        {
            items.Add(new DetailItem("Status", "No device telemetry yet"));
        }

        return items;
    }

    private IReadOnlyList<DetailItem> GetEnvironmentTelemetryItems()
    {
        var items = new List<DetailItem>();

        if ((_node?.TemperatureCelsius ?? _collectorNode?.TemperatureCelsius) is { } temperatureCelsius)
        {
            items.Add(new DetailItem("Temperature", FormattableString.Invariant($"{temperatureCelsius:F1}C")));
        }

        if ((_node?.RelativeHumidity ?? _collectorNode?.RelativeHumidity) is { } relativeHumidity)
        {
            items.Add(new DetailItem("Humidity", FormattableString.Invariant($"{relativeHumidity:F1}% RH")));
        }

        if ((_node?.BarometricPressure ?? _collectorNode?.BarometricPressure) is { } barometricPressure)
        {
            items.Add(new DetailItem("Pressure", FormattableString.Invariant($"{barometricPressure:F1} hPa")));
        }

        if (items.Count == 0)
        {
            items.Add(new DetailItem("Status", "No environment telemetry yet"));
        }

        return items;
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
            : "Unknown";
    }

    private static string FormatPacketType(string? packetType)
    {
        return string.IsNullOrWhiteSpace(packetType) ? "Decoded packet" : packetType.Trim();
    }

    private static string FormatPayloadPreview(string? payloadPreview)
    {
        return string.IsNullOrWhiteSpace(payloadPreview)
            ? "No payload preview captured for this packet."
            : payloadPreview.Trim();
    }

    private string FormatPosition()
    {
        return EffectiveLatitude.HasValue && EffectiveLongitude.HasValue
            ? FormattableString.Invariant($"{EffectiveLatitude.Value:F5}, {EffectiveLongitude.Value:F5}")
            : "No position yet";
    }

    private static string FormatNodeId(uint? nodeNumber)
    {
        return ProjectionDetailsSupport.FormatNodeId(nodeNumber) ?? "Unknown";
    }

    private static string FormatDuration(long uptimeSeconds)
    {
        var uptime = TimeSpan.FromSeconds(uptimeSeconds);

        if (uptime.TotalDays >= 1)
        {
            return $"{(int)uptime.TotalDays}d {uptime.Hours}h";
        }

        if (uptime.TotalHours >= 1)
        {
            return $"{(int)uptime.TotalHours}h {uptime.Minutes}m";
        }

        return $"{uptime.Minutes}m";
    }

    private sealed record DetailItem(string Label, string Value);
}
