@page "/feed"
@page "/messages"
@attribute [Authorize]
@implements IDisposable
@using MeshBoard.Client.Components.Details
@using MeshBoard.Client.Nodes
@inject BrowserRealtimeClient BrowserRealtimeClient
@inject BrokerPreferenceApiClient BrokerPreferenceApiClient
@inject DecryptedMessageStore DecryptedMessageStore
@inject NodeProjectionStore NodeProjectionStore
@inject RealtimeClientState RealtimeClientState

<PageTitle>Feed</PageTitle>

<div class="space-y-4">
    <div class="shell-panel rounded-[2rem] px-6 py-4">
        <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex items-center gap-3">
                <span class="size-2.5 rounded-full @(_connectionSnapshot.IsConnected ? "bg-emerald-500" : "bg-cinder-400")"></span>
                <div>
                    <p class="text-sm font-semibold text-cinder-950">
                        @(_connectionSnapshot.IsConnected ? "Connected" : _connectionSnapshot.Status)
                    </p>
                    @if (!string.IsNullOrWhiteSpace(_activeBrokerName))
                    {
                        <p class="text-xs text-cinder-800/68">@_activeBrokerName</p>
                    }
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-2">
                <span class="text-xs text-cinder-800/60">
                    @_messageSnapshot.Messages.Count packets &middot; @_connectionSnapshot.ActiveSubscriptionCount subs
                </span>

                @if (!_connectionSnapshot.IsConnected)
                {
                    <button class="shell-button shell-button-accent rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                            @onclick="ConnectAsync"
                            disabled="@_connectionSnapshot.IsConnecting">
                        @ConnectLabel
                    </button>
                }
                else
                {
                    <button class="shell-button rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                            @onclick="DisconnectAsync"
                            disabled="@_connectionSnapshot.IsDisconnecting">
                        @DisconnectLabel
                    </button>
                }

                <button class="shell-button rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="ClearFeed"
                        disabled="@(_messageSnapshot.Messages.Count == 0)">
                    Clear
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_commandError))
        {
            <p class="mt-3 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_commandError</p>
        }
    </div>

    @if (DiscoveredChannels.Count > 0)
    {
        <div class="overflow-x-auto">
            <div class="flex gap-2 pb-1">
                <button type="button" class="@GetChipClass(null)" @onclick="() => SelectChannel(null)">All</button>
                @foreach (var channel in DiscoveredChannels)
                {
                    <button type="button" class="@GetChipClass(channel)" @onclick="() => SelectChannel(channel)">
                        @channel
                    </button>
                }
            </div>
        </div>
    }

    <div class="shell-panel grid gap-4 rounded-[2rem] p-6 sm:grid-cols-2">
        <label class="space-y-2">
            <span class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Search</span>
            <input class="w-full rounded-2xl border border-sand-200 bg-white px-4 py-3 text-sm text-cinder-950 shadow-sm"
                   @bind="_searchText"
                   @bind:event="oninput"
                   placeholder="Node, broker, packet type, preview text" />
        </label>

        <label class="space-y-2">
            <span class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Packet type</span>
            <input class="w-full rounded-2xl border border-sand-200 bg-white px-4 py-3 text-sm text-cinder-950 shadow-sm"
                   @bind="_packetTypeFilter"
                   @bind:event="oninput"
                   placeholder="Text, Telemetry, Node Info" />
        </label>
    </div>

    @if (FilteredMessages.Count == 0)
    {
        <div class="shell-panel rounded-[2rem] p-8 text-center">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-signal-600">No messages yet</p>
            <p class="mt-3 text-sm leading-7 text-cinder-800/78">
                Open the realtime connection above to start receiving packets.
            </p>
        </div>
    }
    else
    {
        <div class="grid gap-3 lg:hidden">
            @foreach (var message in FilteredMessages)
            {
                <article class="message-card shell-panel rounded-[1.6rem] p-5"
                         @onclick="() => OpenMessagePreview(message)">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="@GetPacketTypeBadgeClass(message.PacketType)">@FormatPacketType(message.PacketType)</span>
                            @if (TryGetChannelLabel(message.SourceTopic, out var channelLabel, out var channelKey))
                            {
                                <button type="button"
                                        class="shell-button rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => OpenChannelDetails(channelKey)">
                                    @channelLabel
                                </button>
                            }
                        </div>
                        <span class="shrink-0 text-xs text-cinder-800/60" title="@FormatTimestamp(message.ReceivedAtUtc)">@FormatRelativeTime(message.ReceivedAtUtc)</span>
                    </div>

                    <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-cinder-800/72">
                        @if (TryGetSenderNodeId(message, out var senderNodeId))
                        {
                            <button type="button"
                                    class="font-medium text-cinder-950"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => OpenNodeDetails(senderNodeId)">
                                @GetNodeDisplayName(senderNodeId)
                            </button>
                            <span>&rarr;</span>
                        }
                        @if (TryGetDestinationNodeId(message, out var destNodeId))
                        {
                            <button type="button"
                                    class="font-medium text-cinder-950"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => OpenNodeDetails(destNodeId)">
                                @GetNodeDisplayName(destNodeId)
                            </button>
                        }
                        else
                        {
                            <span>Broadcast</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(message.PayloadPreview))
                    {
                        <p class="mt-3 text-sm leading-6 text-cinder-900">@GetTruncatedPreview(message.PayloadPreview)</p>
                    }
                </article>
            }
        </div>

        <section class="shell-panel hidden overflow-hidden rounded-[2rem] p-0 lg:block">
            <div class="overflow-x-auto">
                <table class="min-w-full table-fixed border-collapse">
                    <colgroup>
                        <col class="w-[16%]" />
                        <col class="w-[14%]" />
                        <col class="w-[14%]" />
                        <col class="w-[14%]" />
                        <col class="w-[10%]" />
                        <col class="w-[32%]" />
                    </colgroup>
                    <thead class="border-b border-sand-100/80 bg-white/65 text-left text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">
                        <tr>
                            <th class="px-5 py-4">Received</th>
                            <th class="px-5 py-4">Type</th>
                            <th class="px-5 py-4">Channel</th>
                            <th class="px-5 py-4">From</th>
                            <th class="px-5 py-4">To</th>
                            <th class="px-5 py-4">Preview</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var message in FilteredMessages)
                        {
                            <tr class="border-t border-sand-100/80 text-sm text-cinder-900">
                                <td class="px-5 py-4 align-top whitespace-nowrap">@FormatTimestamp(message.ReceivedAtUtc)</td>
                                <td class="px-5 py-4 align-top">
                                    <span class="@GetPacketTypeBadgeClass(message.PacketType)">@FormatPacketType(message.PacketType)</span>
                                    <div class="mt-2 text-xs text-cinder-800/62">@FormatPacketMetadata(message)</div>
                                    <div class="mt-2 text-xs text-cinder-800/68">@DescribeProjectionState(message)</div>
                                </td>
                                <td class="px-5 py-4 align-top">
                                    @if (TryGetChannelLabel(message.SourceTopic, out var channelLabel, out var channelKey))
                                    {
                                        <button type="button"
                                                class="shell-button rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                                @onclick="() => OpenChannelDetails(channelKey)">
                                            @channelLabel
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="inline-flex rounded-full bg-sand-100 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-cinder-900">
                                            Unknown
                                        </span>
                                    }
                                </td>
                                <td class="px-5 py-4 align-top">
                                    @if (TryGetSenderNodeId(message, out var senderNodeId))
                                    {
                                        <button type="button"
                                                class="text-left"
                                                @onclick="() => OpenNodeDetails(senderNodeId)">
                                            <div class="font-medium text-cinder-950">@GetNodeDisplayName(senderNodeId)</div>
                                            <div class="mt-2 text-xs text-cinder-800/62">@senderNodeId</div>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-cinder-800/72">Unknown</span>
                                    }
                                </td>
                                <td class="px-5 py-4 align-top text-cinder-800/80">
                                    @if (TryGetDestinationNodeId(message, out var destinationNodeId))
                                    {
                                        <button type="button"
                                                class="text-left"
                                                @onclick="() => OpenNodeDetails(destinationNodeId)">
                                            <div class="font-medium text-cinder-950">@GetNodeDisplayName(destinationNodeId)</div>
                                            <div class="mt-2 text-xs text-cinder-800/62">@destinationNodeId</div>
                                        </button>
                                    }
                                    else
                                    {
                                        <span>Broadcast</span>
                                    }
                                </td>
                                <td class="px-5 py-4 align-top">
                                    <div class="space-y-2">
                                        <p class="break-words leading-6">@GetTruncatedPreview(message.PayloadPreview)</p>
                                        <div class="text-xs text-cinder-800/68">Broker: @DisplayValue(message.BrokerServer)</div>
                                        <button type="button"
                                                class="shell-button shell-button-accent rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                                @onclick="() => OpenMessagePreview(message)">
                                            See message
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@if (_previewMessage is not null)
{
    <div class="fixed inset-0 z-40 flex items-center justify-center bg-cinder-950/45 p-4 backdrop-blur-sm"
         @onclick="CloseMessagePreview">
        <article class="shell-panel max-h-[85vh] w-full max-w-3xl overflow-hidden rounded-[1.6rem]"
                 @onclick:stopPropagation="true">
            <header class="flex items-center justify-between gap-4 border-b border-sand-100/80 px-5 py-4">
                <div class="space-y-1">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Message details</p>
                    <p class="text-sm text-cinder-900">@FormatTimestamp(_previewMessage.ReceivedAtUtc)</p>
                </div>

                <button type="button"
                        class="shell-button rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="CloseMessagePreview">
                    Close
                </button>
            </header>

            <div class="max-h-[70vh] space-y-4 overflow-y-auto px-5 py-4 text-sm text-cinder-900">
                <div class="flex flex-wrap gap-2">
                    <span class="@GetPacketTypeBadgeClass(_previewMessage.PacketType)">@FormatPacketType(_previewMessage.PacketType)</span>
                    @if (TryGetChannelLabel(_previewMessage.SourceTopic, out var channelLabel, out var channelKey))
                    {
                        <button type="button"
                                class="shell-button rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                @onclick="() => OpenChannelDetailsFromPreview(channelKey)">
                            @channelLabel
                        </button>
                    }
                    @if (TryGetSenderNodeId(_previewMessage, out var previewSenderNodeId))
                    {
                        <button type="button"
                                class="shell-button rounded-full px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em]"
                                @onclick="() => OpenNodeDetailsFromPreview(previewSenderNodeId)">
                            @GetNodeDisplayName(previewSenderNodeId)
                        </button>
                    }
                </div>

                <div class="grid gap-4 sm:grid-cols-2">
                    <div class="shell-subpanel rounded-2xl p-4">
                        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">Broker</p>
                        <p class="mt-2 break-words text-sm text-cinder-950">@DisplayValue(_previewMessage.BrokerServer)</p>
                    </div>

                    <div class="shell-subpanel rounded-2xl p-4">
                        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">Projection state</p>
                        <p class="mt-2 text-sm text-cinder-950">@DescribeProjectionState(_previewMessage)</p>
                    </div>
                </div>

                <section class="shell-subpanel rounded-2xl p-4">
                    <h2 class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">Source topic</h2>
                    <code class="mt-3 block break-all text-xs leading-6 text-cinder-950">@_previewMessage.SourceTopic</code>
                    @if (!string.IsNullOrWhiteSpace(_previewMessage.DownstreamTopic))
                    {
                        <p class="mt-3 text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">Downstream topic</p>
                        <code class="mt-3 block break-all text-xs leading-6 text-cinder-950">@_previewMessage.DownstreamTopic</code>
                    }
                </section>

                <section class="shell-subpanel rounded-2xl p-4">
                    <h2 class="text-xs font-semibold uppercase tracking-[0.14em] text-cinder-800/68">Full preview</h2>
                    <p class="mt-3 whitespace-pre-wrap break-words text-sm leading-7 text-cinder-950">@FormatPayloadPreview(_previewMessage.PayloadPreview)</p>
                </section>
            </div>
        </article>
    </div>
}

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetails"
                  OnOpenChannel="OpenChannelDetailsAsync"
                  OnOpenNode="OpenNodeDetailsAsync" />

<ChannelDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedChannelKey))"
                     ChannelKey="@(_selectedChannelKey ?? string.Empty)"
                     OnClose="CloseChannelDetails"
                     OnOpenNode="OpenNodeDetailsAsync" />

@code {
    private string? _activeBrokerName;
    private string? _commandError;
    private RealtimeClientSnapshot _connectionSnapshot = new();
    private DecryptedMessageSnapshot _messageSnapshot = new();
    private NodeProjectionSnapshot _nodeSnapshot = new();
    private string _packetTypeFilter = string.Empty;
    private DecryptedMessageEnvelope? _previewMessage;
    private string _searchText = string.Empty;
    private string? _selectedChannelFilter;
    private string? _selectedChannelKey;
    private string? _selectedNodeId;

    protected override void OnInitialized()
    {
        _connectionSnapshot = RealtimeClientState.Snapshot;
        _messageSnapshot = DecryptedMessageStore.Current;
        _nodeSnapshot = NodeProjectionStore.Current;
        RealtimeClientState.Changed += HandleConnectionChanged;
        DecryptedMessageStore.Changed += HandleFeedChanged;
        NodeProjectionStore.Changed += HandleNodeProjectionChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var server = await BrokerPreferenceApiClient.GetActiveAsync();
            _activeBrokerName = server?.Name;
        }
        catch
        {
            // broker name is cosmetic — ignore failures
        }
    }

    public void Dispose()
    {
        RealtimeClientState.Changed -= HandleConnectionChanged;
        DecryptedMessageStore.Changed -= HandleFeedChanged;
        NodeProjectionStore.Changed -= HandleNodeProjectionChanged;
    }

    private string ConnectLabel => _connectionSnapshot.IsConnecting
        ? "Opening..."
        : _connectionSnapshot.IsConnected
            ? "Connected"
            : "Open realtime";

    private string DisconnectLabel => _connectionSnapshot.IsDisconnecting
        ? "Disconnecting..."
        : "Disconnect";

    private IReadOnlyList<string> DiscoveredChannels =>
        _messageSnapshot.Messages
            .Where(m => TryGetChannelLabel(m.SourceTopic, out _, out _))
            .Select(m =>
            {
                TryGetChannelLabel(m.SourceTopic, out _, out var key);
                return key;
            })
            .Where(k => !string.IsNullOrWhiteSpace(k))
            .Distinct(StringComparer.Ordinal)
            .OrderBy(k => k, StringComparer.Ordinal)
            .ToArray();

    private void SelectChannel(string? channelFilter)
    {
        _selectedChannelFilter = channelFilter;
    }

    private string GetChipClass(string? channelFilter)
    {
        var isSelected = channelFilter == _selectedChannelFilter;
        return isSelected
            ? "shrink-0 rounded-full border border-signal-600 bg-signal-600 px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-white transition-colors"
            : "shrink-0 rounded-full border border-sand-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-cinder-900 transition-colors hover:border-signal-400";
    }

    private void ClearFeed()
    {
        _previewMessage = null;
        _selectedChannelFilter = null;
        DecryptedMessageStore.Clear();
    }

    private async Task ConnectAsync()
    {
        _commandError = null;

        try
        {
            await BrowserRealtimeClient.ConnectAsync();
        }
        catch (InvalidOperationException exception)
        {
            _commandError = exception.Message;
        }
    }

    private async Task DisconnectAsync()
    {
        _commandError = null;

        try
        {
            await BrowserRealtimeClient.DisconnectAsync();
        }
        catch (InvalidOperationException exception)
        {
            _commandError = exception.Message;
        }
    }

    private static string DisplayValue(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not set" : value;
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
            : "No packets yet";
    }

    private static string FormatRelativeTime(DateTimeOffset? value)
    {
        if (!value.HasValue) return "Never";
        var diff = DateTimeOffset.UtcNow - value.Value;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return value.Value.ToLocalTime().ToString("MMM d");
    }

    private void HandleConnectionChanged()
    {
        _connectionSnapshot = RealtimeClientState.Snapshot;
        InvokeAsync(StateHasChanged);
    }

    private void HandleFeedChanged()
    {
        _messageSnapshot = DecryptedMessageStore.Current;
        InvokeAsync(StateHasChanged);
    }

    private void HandleNodeProjectionChanged()
    {
        _nodeSnapshot = NodeProjectionStore.Current;
        InvokeAsync(StateHasChanged);
    }

    private IReadOnlyList<DecryptedMessageEnvelope> FilteredMessages =>
        _messageSnapshot.Messages
            .Where(MatchesChannelFilter)
            .Where(MatchesPacketTypeFilter)
            .Where(MatchesSearchText)
            .ToArray();

    private bool MatchesChannelFilter(DecryptedMessageEnvelope message)
    {
        if (_selectedChannelFilter is null) return true;
        return TryGetChannelLabel(message.SourceTopic, out _, out var channelKey) &&
            string.Equals(channelKey, _selectedChannelFilter, StringComparison.Ordinal);
    }

    private bool MatchesPacketTypeFilter(DecryptedMessageEnvelope message)
    {
        return string.IsNullOrWhiteSpace(_packetTypeFilter) ||
            message.PacketType.Contains(_packetTypeFilter.Trim(), StringComparison.OrdinalIgnoreCase) ||
            message.PortNumName.Contains(_packetTypeFilter.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesSearchText(DecryptedMessageEnvelope message)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var filter = _searchText.Trim();

        return message.SourceTopic.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            message.PayloadPreview.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            message.BrokerServer.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            message.PortNumName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            message.PacketType.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            GetNodeDisplayName(message).Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            TryGetChannelLabel(message.SourceTopic, out var channelLabel, out _) &&
            channelLabel.Contains(filter, StringComparison.OrdinalIgnoreCase);
    }

    private static string DescribeProjectionState(DecryptedMessageEnvelope message)
    {
        return message.IsEncrypted
            ? "Projected from locally decrypted traffic"
            : "Projected from decoded transport packet";
    }

    private static string FormatPacketType(string? packetType)
    {
        return string.IsNullOrWhiteSpace(packetType) ? "Decoded packet" : packetType.Trim();
    }

    private static string FormatPayloadPreview(string? payloadPreview)
    {
        return string.IsNullOrWhiteSpace(payloadPreview)
            ? "No payload preview captured for this packet."
            : payloadPreview.Trim();
    }

    private static string GetTruncatedPreview(string? payloadPreview)
    {
        var preview = FormatPayloadPreview(payloadPreview);
        return preview.Length <= 140 ? preview : $"{preview[..140]}...";
    }

    private static string FormatPacketMetadata(DecryptedMessageEnvelope message)
    {
        return string.IsNullOrWhiteSpace(message.PortNumName)
            ? $"Port {message.PortNumValue}"
            : $"{message.PortNumName} ({message.PortNumValue})";
    }

    private string GetNodeDisplayName(DecryptedMessageEnvelope message)
    {
        return TryGetSenderNodeId(message, out var senderNodeId)
            ? GetNodeDisplayName(senderNodeId)
            : "Unknown";
    }

    private string GetNodeDisplayName(string nodeId)
    {
        var node = _nodeSnapshot.Nodes
            .FirstOrDefault(candidate => string.Equals(candidate.NodeId, nodeId, StringComparison.OrdinalIgnoreCase));

        return node?.DisplayName ?? nodeId;
    }

    private static string GetPacketTypeBadgeClass(string? packetType)
    {
        var normalizedPacketType = packetType?.Trim() ?? string.Empty;

        return normalizedPacketType switch
        {
            "Text Message" or "Compressed Text Message" =>
                "inline-flex rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-emerald-700",
            "Telemetry" =>
                "inline-flex rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-amber-700",
            "Node Info" or "Position Update" =>
                "inline-flex rounded-full border border-slate-200 bg-white px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-cinder-900",
            _ =>
                "inline-flex rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.14em] text-rose-700"
        };
    }

    private static bool TryGetChannelLabel(string sourceTopic, out string channelLabel, out string channelKey)
    {
        channelLabel = string.Empty;
        channelKey = string.Empty;

        if (string.IsNullOrWhiteSpace(sourceTopic))
        {
            return false;
        }

        var segments = sourceTopic
            .Split('/', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length < 5 || !string.Equals(segments[0], "msh", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var transportSegment = segments[3];
        if (!string.Equals(transportSegment, "e", StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(transportSegment, "json", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var region = segments[1];
        var channelName = segments[4];

        if (string.IsNullOrWhiteSpace(region) || string.IsNullOrWhiteSpace(channelName))
        {
            return false;
        }

        channelKey = $"{region}/{channelName}";
        channelLabel = channelKey;
        return true;
    }

    private static bool TryGetSenderNodeId(DecryptedMessageEnvelope message, out string nodeId)
    {
        nodeId = ProjectionDetailsSupport.FormatNodeId(message.SourceNodeNumber ?? message.FromNodeNumber) ?? string.Empty;
        return !string.IsNullOrWhiteSpace(nodeId);
    }

    private static bool TryGetDestinationNodeId(DecryptedMessageEnvelope message, out string nodeId)
    {
        nodeId = ProjectionDetailsSupport.FormatNodeId(message.DestinationNodeNumber) ?? string.Empty;
        return !string.IsNullOrWhiteSpace(nodeId);
    }

    private void OpenMessagePreview(DecryptedMessageEnvelope message)
    {
        _previewMessage = message;
    }

    private void CloseMessagePreview()
    {
        _previewMessage = null;
    }

    private void OpenNodeDetails(string nodeId)
    {
        CloseMessagePreview();
        _selectedChannelKey = null;
        _selectedNodeId = nodeId;
    }

    private Task OpenNodeDetailsAsync(string nodeId)
    {
        OpenNodeDetails(nodeId);
        return Task.CompletedTask;
    }

    private void OpenNodeDetailsFromPreview(string nodeId)
    {
        OpenNodeDetails(nodeId);
    }

    private void CloseNodeDetails()
    {
        _selectedNodeId = null;
    }

    private void OpenChannelDetails(string channelKey)
    {
        CloseMessagePreview();
        _selectedNodeId = null;
        _selectedChannelKey = channelKey;
    }

    private Task OpenChannelDetailsAsync(string channelKey)
    {
        OpenChannelDetails(channelKey);
        return Task.CompletedTask;
    }

    private void OpenChannelDetailsFromPreview(string channelKey)
    {
        OpenChannelDetails(channelKey);
    }

    private void CloseChannelDetails()
    {
        _selectedChannelKey = null;
    }
}
