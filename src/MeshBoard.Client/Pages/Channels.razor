@page "/channels"
@attribute [Authorize]
@using MeshBoard.Client.Channels
@implements IDisposable
@inject ChannelPreferenceApiClient ChannelPreferenceApiClient
@inject ChannelProjectionStore ChannelProjectionStore

<PageTitle>Channels</PageTitle>

<div class="grid gap-6 xl:grid-cols-[0.95fr_1.2fr]">
    <section class="shell-panel rounded-[2rem] p-8">
        <div class="space-y-3">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Preferences</p>
            <h1 class="font-display text-4xl text-cinder-950">Saved channels</h1>
            <p class="text-sm leading-7 text-cinder-800/82">
                Saved channel filters are API-backed receive preferences for the active server. The bridge combines them
                with saved topic presets to decide which upstream topics feed the live stream, while the browser tracks
                observed channels locally from that stream.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_commandError))
        {
            <p class="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_commandError</p>
        }

        @if (!string.IsNullOrWhiteSpace(_commandSuccess))
        {
            <p class="mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@_commandSuccess</p>
        }

        <EditForm class="mt-6 grid gap-4" Model="_form" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <label class="block space-y-2">
                <span class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800/68">Topic filter</span>
                <InputText class="shell-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                           @bind-Value="_form.TopicFilter" />
                <ValidationMessage For="() => _form.TopicFilter" />
            </label>

            <button type="submit"
                    class="shell-button shell-button-accent mt-2 rounded-full px-5 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                    disabled="@_isSaving">
                @(_isSaving ? "Saving..." : "Save channel")
            </button>
        </EditForm>

        <div class="mt-8 flex items-center justify-between gap-4">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Saved filters</p>
                <h2 class="mt-2 font-display text-3xl text-cinder-950">Persisted receive filters</h2>
            </div>

            <button class="shell-button rounded-full px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                    @onclick="ReloadSavedChannelsAsync"
                    disabled="@_isLoadingSavedChannels">
                Refresh
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <p class="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_loadError</p>
        }
        else if (_isLoadingSavedChannels)
        {
            <p class="mt-6 text-sm text-cinder-800/72">Loading saved channels...</p>
        }
        else if (_savedChannels.Count == 0)
        {
            <div class="shell-subpanel mt-6 rounded-[1.7rem] p-5 text-sm leading-7 text-cinder-800/78">
                No saved channel filters are stored for the active server yet.
            </div>
        }
        else
        {
            <div class="mt-6 grid gap-4">
                @foreach (var channel in _savedChannels)
                {
                    <article class="shell-subpanel flex flex-col gap-4 rounded-[1.7rem] p-5 sm:flex-row sm:items-start sm:justify-between">
                        <div class="space-y-1">
                            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-signal-600">@channel.BrokerServerProfileId</p>
                            <h3 class="font-display text-2xl text-cinder-950">@channel.TopicFilter</h3>
                            <p class="text-sm text-cinder-800/80">
                                Saved @channel.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </p>
                        </div>

                        <button class="shell-button rounded-full px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                                @onclick="() => RemoveAsync(channel.TopicFilter)"
                                disabled="@_isDeleting">
                            Remove
                        </button>
                    </article>
                }
            </div>
        }
    </section>

    <section class="shell-panel rounded-[2rem] p-8">
        <div class="flex flex-wrap items-center justify-between gap-4">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Live projections</p>
                <h2 class="mt-2 font-display text-3xl text-cinder-950">Observed channels</h2>
                <p class="mt-3 text-sm leading-7 text-cinder-800/82">
                    These summaries are built locally from the browser realtime stream and reset on logout or explicit clear.
                </p>
            </div>

            <div class="flex flex-wrap gap-3">
                <button class="shell-button rounded-full px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                        @onclick="ClearLiveChannels"
                        disabled="@(_liveSnapshot.Channels.Count == 0)">
                    Clear live cache
                </button>
            </div>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
            <article class="shell-subpanel rounded-[1.6rem] p-5">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Projected channels</p>
                <p class="mt-3 text-2xl font-semibold text-cinder-950">@FilteredChannels.Count</p>
                <p class="mt-2 text-sm text-cinder-800/72">Total live projection events: @_liveSnapshot.TotalProjected</p>
            </article>

            <article class="shell-subpanel rounded-[1.6rem] p-5">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Saved filter matches</p>
                <p class="mt-3 text-2xl font-semibold text-cinder-950">@FilteredChannels.Count(channel => CountMatchingSavedFilters(channel) > 0)</p>
                <p class="mt-2 text-sm text-cinder-800/72">Matched against the latest observed source topic per channel.</p>
            </article>

            <article class="shell-subpanel rounded-[1.6rem] p-5">
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Last projection</p>
                <p class="mt-3 text-2xl font-semibold text-cinder-950">@FormatTimestamp(_liveSnapshot.LastProjectedAtUtc)</p>
                <p class="mt-2 text-sm text-cinder-800/72">Memory only in wave 1.</p>
            </article>
        </div>

        <section class="mt-6 shell-subpanel rounded-[1.7rem] p-5">
            <label class="space-y-2">
                <span class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Search live channels</span>
                <input class="w-full rounded-2xl border border-sand-200 bg-white px-4 py-3 text-sm text-cinder-950 shadow-sm"
                       @bind="_searchText"
                       @bind:event="oninput"
                       placeholder="Region, channel, topic, packet type" />
            </label>
        </section>

        @if (FilteredChannels.Count == 0)
        {
            <div class="shell-subpanel mt-6 rounded-[1.7rem] p-5 text-sm leading-7 text-cinder-800/78">
                No live channel summaries match the current view yet. Keep the realtime connection open and wait for
                Meshtastic traffic to arrive.
            </div>
        }
        else
        {
            <div class="mt-6 grid gap-4">
                @foreach (var channel in FilteredChannels)
                {
                    var matchingSavedFilterCount = CountMatchingSavedFilters(channel);

                    <article class="shell-subpanel rounded-[1.7rem] p-5">
                        <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                            <div class="space-y-2">
                                <div class="flex flex-wrap items-center gap-2">
                                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-signal-600">@channel.Region</p>
                                    @if (matchingSavedFilterCount > 0)
                                    {
                                        <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">
                                            @matchingSavedFilterCount saved filter@(matchingSavedFilterCount == 1 ? string.Empty : "s")
                                        </span>
                                    }
                                </div>
                                <h3 class="font-display text-3xl text-cinder-950">@channel.ChannelName</h3>
                                <p class="text-sm text-cinder-800/80">@channel.ChannelKey</p>
                            </div>

                            <div class="grid gap-2 text-sm text-cinder-800/78 sm:text-right">
                                <span>Observed @channel.ObservedPacketCount packets</span>
                                <span>@channel.DistinctNodeCount distinct nodes</span>
                                <span>@FormatTimestamp(channel.LastObservedAtUtc)</span>
                            </div>
                        </div>

                        <div class="mt-5 grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
                            <div class="space-y-3">
                                <div>
                                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Last packet</p>
                                    <p class="mt-2 text-sm text-cinder-900">@channel.LastPacketType</p>
                                </div>

                                <div>
                                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Latest topic</p>
                                    <code class="mt-2 block break-all rounded-2xl border border-slate-200 bg-slate-50/90 px-4 py-3 text-xs leading-6 text-cinder-900">
                                        @channel.LatestSourceTopic
                                    </code>
                                </div>
                            </div>

                            <div>
                                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Latest payload preview</p>
                                <div class="mt-2 rounded-2xl border border-slate-200 bg-slate-50/90 px-4 py-3 text-sm leading-7 text-cinder-900">
                                    @(string.IsNullOrWhiteSpace(channel.LastPayloadPreview) ? "No decoded payload preview captured for the latest packet." : channel.LastPayloadPreview)
                                </div>
                            </div>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@code {
    private readonly List<SavedChannelFilter> _savedChannels = [];
    private ChannelFilterFormModel _form = new();
    private ChannelProjectionSnapshot _liveSnapshot = new();
    private bool _isDeleting;
    private bool _isLoadingSavedChannels = true;
    private bool _isSaving;
    private string _searchText = string.Empty;
    private string? _commandError;
    private string? _commandSuccess;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        _liveSnapshot = ChannelProjectionStore.Current;
        ChannelProjectionStore.Changed += HandleLiveChannelsChanged;
        await LoadSavedChannelsAsync();
    }

    public void Dispose()
    {
        ChannelProjectionStore.Changed -= HandleLiveChannelsChanged;
    }

    private IReadOnlyList<ChannelProjectionEnvelope> FilteredChannels =>
        _liveSnapshot.Channels
            .Where(MatchesSearchText)
            .ToArray();

    private async Task LoadSavedChannelsAsync()
    {
        _isLoadingSavedChannels = true;
        _loadError = null;

        try
        {
            var channels = await ChannelPreferenceApiClient.GetAllAsync();
            _savedChannels.Clear();
            _savedChannels.AddRange(channels.OrderBy(item => item.TopicFilter, StringComparer.OrdinalIgnoreCase));
        }
        catch (Exception exception)
        {
            _loadError = exception.Message;
        }
        finally
        {
            _isLoadingSavedChannels = false;
        }
    }

    private async Task ReloadSavedChannelsAsync()
    {
        await LoadSavedChannelsAsync();
    }

    private async Task SaveAsync()
    {
        _commandError = null;
        _commandSuccess = null;
        _isSaving = true;

        try
        {
            await ChannelPreferenceApiClient.SaveAsync(
                new SaveChannelFilterRequest
                {
                    TopicFilter = _form.TopicFilter.Trim()
                });

            _form = new ChannelFilterFormModel();
            _commandSuccess = "Saved channel filter.";
            await LoadSavedChannelsAsync();
        }
        catch (Exception exception)
        {
            _commandError = exception.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RemoveAsync(string topicFilter)
    {
        _commandError = null;
        _commandSuccess = null;
        _isDeleting = true;

        try
        {
            await ChannelPreferenceApiClient.DeleteAsync(topicFilter);
            _commandSuccess = "Removed channel filter.";
            await LoadSavedChannelsAsync();
        }
        catch (Exception exception)
        {
            _commandError = exception.Message;
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private void ClearLiveChannels()
    {
        ChannelProjectionStore.Clear();
        _commandError = null;
        _commandSuccess = "Cleared the local live channel cache.";
    }

    private void HandleLiveChannelsChanged()
    {
        _liveSnapshot = ChannelProjectionStore.Current;
        InvokeAsync(StateHasChanged);
    }

    private bool MatchesSearchText(ChannelProjectionEnvelope channel)
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            return true;
        }

        var filter = _searchText.Trim();
        return channel.ChannelKey.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            channel.ChannelName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            channel.Region.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            channel.LatestSourceTopic.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
            channel.LastPacketType.Contains(filter, StringComparison.OrdinalIgnoreCase);
    }

    private int CountMatchingSavedFilters(ChannelProjectionEnvelope channel)
    {
        return _savedChannels.Count(savedChannel => IsPatternMatch(channel.LatestSourceTopic, savedChannel.TopicFilter));
    }

    private static bool IsPatternMatch(string topic, string topicFilter)
    {
        if (string.IsNullOrWhiteSpace(topic) || string.IsNullOrWhiteSpace(topicFilter))
        {
            return false;
        }

        var topicSegments = topic
            .Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var patternSegments = topicFilter
            .Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        for (var index = 0; index < patternSegments.Length; index += 1)
        {
            var patternSegment = patternSegments[index];

            if (patternSegment == "#")
            {
                return true;
            }

            if (index >= topicSegments.Length)
            {
                return false;
            }

            if (patternSegment == "+")
            {
                continue;
            }

            if (!string.Equals(patternSegment, topicSegments[index], StringComparison.OrdinalIgnoreCase))
            {
                return false;
            }
        }

        return topicSegments.Length == patternSegments.Length;
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
            : "No packets yet";
    }

    private sealed class ChannelFilterFormModel
    {
        [Required]
        [MaxLength(255)]
        public string TopicFilter { get; set; } = string.Empty;
    }
}
