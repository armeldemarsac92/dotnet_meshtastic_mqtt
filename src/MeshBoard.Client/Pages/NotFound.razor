@page "/not-found"
@layout MainLayout

<PageTitle>Not Found</PageTitle>

<section class="shell-panel rounded-[2rem] p-8 text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Routing</p>
    <h1 class="mt-4 font-display text-4xl text-cinder-950">Not found</h1>
    <p class="mt-4 text-sm leading-7 text-cinder-800/82">
        The client route you requested does not exist.
    </p>
    <a class="shell-button shell-button-accent mt-6 inline-flex rounded-full px-5 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
       href="/">
        Back to overview
    </a>
</section>
