@page "/topology"
@using MeshBoard.Client.Services
@using System.Globalization
@using MeshBoard.Contracts.Collector
@attribute [Authorize]
@implements IAsyncDisposable
@inject PublicCollectorApiClient PublicCollectorApiClient
@inject IJSRuntime JS

<PageTitle>Topology</PageTitle>

<div class="space-y-6">
    <header class="shell-panel space-y-5 rounded-[2rem] p-6 sm:p-8">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Network topology</p>
                <h1 class="mt-2 font-display text-3xl text-cinder-950 sm:text-4xl">Radio network graph</h1>
                <p class="mt-3 max-w-4xl text-sm leading-7 text-cinder-800/82">
                    Force-directed graph of all observed radio links from the last 24 hours.
                    Edge thickness represents the number of observations between two nodes.
                    Nodes with higher SNR are pulled closer together.
                    Click any node to view its details.
                </p>
            </div>

            <button type="button"
                    class="shell-button shell-button-accent shrink-0 rounded-full px-5 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                    @onclick="RefreshAsync"
                    disabled="@_isLoading">
                @(_isLoading ? "Loading..." : "Refresh")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_errorMessage</p>
        }

        @if (_topology is not null)
        {
            <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                <article class="shell-subpanel rounded-[1.4rem] p-4">
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Nodes</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@_topology.NodeCount</p>
                </article>
                <article class="shell-subpanel rounded-[1.4rem] p-4">
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Links</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@_topology.LinkCount</p>
                </article>
                <article class="shell-subpanel rounded-[1.4rem] p-4">
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Components</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@_topology.ConnectedComponentCount</p>
                </article>
                <article class="shell-subpanel rounded-[1.4rem] p-4">
                     <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Bridge nodes</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@_topology.BridgeNodeCount</p>
                </article>
            </section>
        }
    </header>

    <section class="shell-panel rounded-[2rem] p-6">
        <div class="mb-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">
                Radio link graph
                @if (_graphNodeCount > 0)
                {
                    <span class="ml-2 normal-case font-normal text-cinder-800/40">— @_graphNodeCount nodes, @_graphLinkCount links shown</span>
                }
            </p>
            
            <div class="flex items-center gap-3 w-full sm:w-auto">
                <input type="search" 
                       placeholder="Search node..." 
                       class="w-full sm:w-64 rounded-xl border border-sand-200 bg-sand-50/50 px-4 py-2 text-sm text-cinder-900 focus:border-signal-500 focus:outline-none focus:ring-1 focus:ring-signal-500"
                       @oninput="HandleSearchInput" />

                @if (_graphDataLoaded)
                {
                    <span class="shrink-0 rounded-full bg-sand-100 px-3 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-cinder-900">24 hours</span>
                }
            </div>
         </div>

        @if (_isLoading)
        {
            <div class="flex h-[600px] items-center justify-center">
                <p class="text-sm text-cinder-800/72">Loading topology graph...</p>
            </div>
        }
        else if (!_graphDataLoaded)
        {
             <div class="flex h-[600px] items-center justify-center">
                <p class="text-sm text-cinder-800/72">No topology data loaded yet. Click Refresh to load.</p>
            </div>
        }
        else
        {
            <div class="mb-4 rounded-2xl bg-sand-50/50 p-4 border border-sand-100">
                <div class="flex flex-wrap justify-between items-start gap-4 mb-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cinder-800">Layout tuning</p>
                    <div class="flex flex-wrap gap-2">
                        <button type="button"
                                class="shell-button shell-button-accent rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.12em]"
                                @onclick="SpreadLayoutAsync"
                                disabled="@_isLayoutRunning">
                            @(_isLayoutRunning ? "Spreading..." : "Spread layout")
                        </button>
                        <button type="button"
                                class="shell-button rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.12em]"
                                @onclick="ApplyNoverlapAsync"
                                disabled="@_isLayoutRunning">
                            Fix overlaps
                        </button>
                    </div>
                </div>

                <div class="grid gap-5 md:grid-cols-3">
                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-[0.68rem] font-semibold text-cinder-800/80">Gravity</label>
                            <span class="text-xs font-mono">@_layoutGravity.ToString("0.00", CultureInfo.InvariantCulture)</span>
                        </div>
                        <input type="range" min="0" max="1" step="0.01" value="@_layoutGravity.ToString(CultureInfo.InvariantCulture)"
                               @onchange="@(async e => { _layoutGravity = Convert.ToDouble(e.Value, CultureInfo.InvariantCulture); await ApplyLayoutSettingsAsync(); })"
                               class="w-full accent-signal-600" />
                        <p class="text-[0.65rem] text-cinder-800/60 mt-1">Pulls nodes toward the center.</p>
                    </div>

                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-[0.68rem] font-semibold text-cinder-800/80">Edge weight pull</label>
                            <span class="text-xs font-mono">@_layoutEdgeWeight.ToString("0.0", CultureInfo.InvariantCulture)</span>
                        </div>
                        <input type="range" min="0" max="10" step="0.1" value="@_layoutEdgeWeight.ToString(CultureInfo.InvariantCulture)"
                               @onchange="@(async e => { _layoutEdgeWeight = Convert.ToDouble(e.Value, CultureInfo.InvariantCulture); await ApplyLayoutSettingsAsync(); })"
                               class="w-full accent-signal-600" />
                        <p class="text-[0.65rem] text-cinder-800/60 mt-1">Strong SNR links pull their nodes closer.</p>
                    </div>

                    <div>
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-[0.68rem] font-semibold text-cinder-800/80">Iterations</label>
                            <span class="text-xs font-mono">@_layoutIterations.ToString("0", CultureInfo.InvariantCulture)</span>
                        </div>
                        <input type="range" min="100" max="5000" step="100" value="@_layoutIterations.ToString(CultureInfo.InvariantCulture)"
                               @onchange="@(async e => { _layoutIterations = Convert.ToInt32(e.Value, CultureInfo.InvariantCulture); await ApplyLayoutSettingsAsync(); })"
                               class="w-full accent-signal-600" />
                        <p class="text-[0.65rem] text-cinder-800/60 mt-1">More iterations = more time to untangle.</p>
                    </div>
                </div>

                <details class="mt-4">
                    <summary class="cursor-pointer text-[0.68rem] font-semibold uppercase tracking-[0.12em] text-cinder-800/50 select-none">Advanced</summary>
                    <div class="mt-3">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="checkbox" checked="@_layoutLinLog"
                                   @onchange="@(async e => { _layoutLinLog = (bool)(e.Value ?? false); await ApplyLayoutSettingsAsync(); })"
                                   class="accent-signal-600 h-4 w-4 rounded border-gray-300" />
                            <span class="text-[0.68rem] font-semibold text-cinder-800/80">LinLog mode — strengthens cluster separation</span>
                        </label>
                    </div>
                </details>
            </div>

            <div id="@GraphElementId"
                 class="w-full overflow-hidden rounded-2xl bg-white border border-sand-100"
                 style="height: clamp(600px, 80vh, 900px);"></div>
        }
    </section>

    @if (_topology is not null && (_topology.BridgeNodes.Count > 0 || _topology.StrongestLinks.Count > 0))
    {
         <div class="grid gap-6 lg:grid-cols-2">
            @if (_topology.BridgeNodes.Count > 0)
            {
                <section class="shell-panel rounded-[2rem] px-6 pt-7 pb-6">
                    <h2 class="font-display text-2xl text-cinder-950">Bridge nodes</h2>
                    <p class="mt-2 text-sm text-cinder-800/72">Nodes whose removal would split the network into disconnected components.</p>
                    <ul class="mt-5 space-y-3 text-sm text-cinder-900">
                        @foreach (var node in _topology.BridgeNodes)
                        {
                           <li class="flex items-center justify-between gap-4 rounded-2xl border border-sand-100/80 bg-white/60 px-4 py-3">
                                <div>
                                    <span class="font-medium">@(node.LongName ?? node.ShortName ?? node.NodeId)</span>
                                    <span class="ml-2 text-xs text-cinder-800/60">@node.NodeId</span>
                                </div>
                                 <span class="shrink-0 rounded-full bg-sand-100 px-2.5 py-1 text-[0.68rem] font-semibold text-cinder-900">@node.Degree links</span>
                            </li>
                        }
                    </ul>
                 </section>
            }

            @if (_topology.StrongestLinks.Count > 0)
            {
                <section class="shell-panel rounded-[2rem] px-6 pt-7 pb-6">
                    <h2 class="font-display text-2xl text-cinder-950">Strongest links</h2>
                     <p class="mt-2 text-sm text-cinder-800/72">Highest average SNR observed radio links.</p>
                    <ul class="mt-5 space-y-3 text-sm text-cinder-900">
                        @foreach (var link in _topology.StrongestLinks)
                        {
                           <li class="rounded-2xl border border-sand-100/80 bg-white/60 px-4 py-3">
                                <div class="flex items-center justify-between gap-4">
                                    <span class="font-medium">@GetLinkLabel(link)</span>
                                     @if (link.AverageSnrDb.HasValue)
                                    {
                                         <span class="shrink-0 rounded-full px-2.5 py-1 text-[0.68rem] font-semibold @GetSnrBadgeClass(link.AverageSnrDb.Value)">
                                            @link.AverageSnrDb.Value.ToString("F1") dB
                                         </span>
                                    }
                                </div>
                                 <div class="mt-1.5 text-xs text-cinder-800/60">
                                    @link.SourceNodeId → @link.TargetNodeId
                                    <span class="ml-3">@link.ObservationCount obs.</span>
                                 </div>
                            </li>
                        }
                    </ul>
                 </section>
            }
        </div>
    }
</div>

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                 NodeId="@(_selectedNodeId ?? string.Empty)"
                 OnClose="CloseNodeDetails"
                 OnOpenChannel="@(_ => Task.CompletedTask)"
                 OnOpenNode="@(id => { _selectedNodeId = id; StateHasChanged(); return Task.CompletedTask; })" />

@code {
    private const string GraphElementId = "meshboard-topology-graph";

    private CollectorTopologySnapshot? _topology;
    private bool _isLoading;
    private bool _graphDataLoaded;
    private string? _errorMessage;
    private bool _graphRendered;
    private int _graphNodeCount;
    private int _graphLinkCount;

    // PHYSICS STATE — defaults tuned for spread-out sparse graphs
    private double _layoutGravity = 0.0;
    private double _layoutEdgeWeight = 0.5;
    private int _layoutIterations = 600;
    private bool _layoutLinLog = true;
    private bool _isLayoutRunning = false;

    private string? _selectedNodeId;

    private Lazy<Task<IJSObjectReference>>? _moduleTask;
    private DotNetObjectReference<Topology>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_graphDataLoaded || _isLoading) return;
        if (_graphRendered) return;

        await RenderGraphAsync();
    }

    public async ValueTask DisposeAsync()
    {
        _dotNetRef?.Dispose();
        if (_moduleTask?.IsValueCreated == true)
        {
            try
            {
                var module = await _moduleTask.Value;
                await module.InvokeVoidAsync("disposeTopologyGraph", GraphElementId);
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

    private async Task RefreshAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _graphRendered = false;
        _graphDataLoaded = false;
        StateHasChanged();
        try
        {
            _topology = await PublicCollectorApiClient.GetTopologyAsync(new CollectorTopologyQuery
            {
                ActiveWithinHours = 24,
                MaxNodes = 10_000,
                MaxLinks = 20_000,
                TopCount = 5_000
            });
            BuildGraphData(_topology);
            _graphDataLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _topology = null;
            _graphDataLoaded = false;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        var query = e.Value?.ToString() ?? string.Empty;
        if (_moduleTask?.IsValueCreated == true && _graphRendered)
        {
            var module = await _moduleTask.Value;
            await module.InvokeVoidAsync("searchTopologyNode", GraphElementId, query);
        }
    }

    private GraphNode[] _graphNodes = [];
    private GraphLink[] _graphLinks = [];
    private void BuildGraphData(CollectorTopologySnapshot topology)
    {
        var bridgeIds = topology.BridgeNodes.Select(n => n.NodeId).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var degreeMap = topology.TopDegreeNodes
            .DistinctBy(n => n.NodeId, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(n => n.NodeId, n => n.Degree, StringComparer.OrdinalIgnoreCase);

        var nodeDict = new Dictionary<string, GraphNode>(StringComparer.OrdinalIgnoreCase);
        GraphNode GetOrAddNode(string nodeId, string? shortName, string? longName)
        {
            if (nodeDict.TryGetValue(nodeId, out var existing)) return existing;
            var label = shortName ?? longName ?? GetShortId(nodeId);
            var node = new GraphNode(
                Id: nodeId,
                Label: label,
                IsBridge: bridgeIds.Contains(nodeId),
                Degree: degreeMap.TryGetValue(nodeId, out var deg) ? deg : 1);
            nodeDict[nodeId] = node;
            return node;
        }

        var linkList = new List<GraphLink>(topology.StrongestLinks.Count);
        foreach (var link in topology.StrongestLinks)
        {
            GetOrAddNode(link.SourceNodeId, link.SourceShortName, link.SourceLongName);
            GetOrAddNode(link.TargetNodeId, link.TargetShortName, link.TargetLongName);
            linkList.Add(new GraphLink(
                Source: link.SourceNodeId,
                Target: link.TargetNodeId,
                SnrDb: link.AverageSnrDb,
                Observations: link.ObservationCount));
        }

        _graphNodes = [.. nodeDict.Values];
        _graphLinks = [.. linkList];
        _graphNodeCount = _graphNodes.Length;
        _graphLinkCount = _graphLinks.Length;
    }

    private async Task RenderGraphAsync()
    {
        try
        {
            var module = await GetModuleAsync();
            _dotNetRef ??= DotNetObjectReference.Create(this);
            await module.InvokeVoidAsync("renderTopologyGraph", GraphElementId, _graphNodes, _graphLinks, _dotNetRef, LayoutParams());
            _graphRendered = true;
            await module.InvokeVoidAsync("scrollToGraph", GraphElementId);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private object LayoutParams() => new
    {
        gravity = _layoutGravity,
        edgeWeightInfluence = _layoutEdgeWeight,
        iterations = _layoutIterations,
        linLogMode = _layoutLinLog,
    };

    private async Task ApplyLayoutSettingsAsync()
    {
        if (!_graphRendered || _moduleTask == null) return;
        var module = await _moduleTask.Value;
        await module.InvokeVoidAsync("updateTopologyLayout", GraphElementId, LayoutParams());
    }

    private async Task SpreadLayoutAsync()
    {
        if (!_graphRendered || _moduleTask == null) return;
        _isLayoutRunning = true;
        StateHasChanged();
        try
        {
            var module = await _moduleTask.Value;
            await module.InvokeVoidAsync("spreadTopologyLayout", GraphElementId, LayoutParams());
        }
        finally
        {
            _isLayoutRunning = false;
        }
    }

    private async Task ApplyNoverlapAsync()
    {
        if (!_graphRendered || _moduleTask == null) return;
        _isLayoutRunning = true;
        StateHasChanged();
        try
        {
            var module = await _moduleTask.Value;
            await module.InvokeVoidAsync("applyNoverlapPass", GraphElementId);
        }
        finally
        {
            _isLayoutRunning = false;
        }
    }

    [JSInvokable]
    public void OnTopologyNodeClicked(string nodeId)
    {
        _selectedNodeId = nodeId;
        _ = InvokeAsync(StateHasChanged);
    }

    private Task<IJSObjectReference> GetModuleAsync()
    {
        _moduleTask ??= new Lazy<Task<IJSObjectReference>>(
            () => JS.InvokeAsync<IJSObjectReference>("import", "./js/topology-graph.js?v=40").AsTask());
        return _moduleTask.Value;
    }

    private void CloseNodeDetails()
    {
        _selectedNodeId = null;
    }

    private static string GetShortId(string nodeId)
    {
        var trimmed = nodeId.TrimStart('!');
        return trimmed.Length >= 4 ? trimmed[^4..] : trimmed;
    }

    private static string GetLinkLabel(CollectorTopologyLinkSummary link)
    {
        var src = link.SourceLongName ?? link.SourceShortName ?? GetShortId(link.SourceNodeId);
        var tgt = link.TargetLongName ?? link.TargetShortName ?? GetShortId(link.TargetNodeId);
        return $"{src} ↔ {tgt}";
    }

    private static string GetSnrBadgeClass(float snr) => snr switch
    {
        > 0 => "bg-emerald-100 text-emerald-800",
        >= -10 => "bg-amber-100 text-amber-800",
        _ => "bg-rose-100 text-rose-800"
    };
    
    private sealed record GraphNode(
        string Id,
        string Label,
        bool IsBridge,
        int Degree);
        
    private sealed record GraphLink(
        string Source,
        string Target,
        float? SnrDb,
        int Observations);
}