@page "/map"
@attribute [Authorize]
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject MapProjectionStore ProjectionStore

<PageTitle>Map</PageTitle>

<div class="grid gap-6 xl:grid-cols-[0.94fr_1.26fr]">
    <section class="space-y-6">
        <header class="shell-panel rounded-[2rem] p-8">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Geospatial view</p>
                    <h1 class="mt-2 font-display text-4xl text-cinder-950">Live node map</h1>
                    <p class="mt-3 max-w-3xl text-sm leading-7 text-cinder-800/82">
                        This globe is driven entirely by local map projections in the browser. It reuses the Cesium map
                        protocol from the previous implementation, but it no longer depends on server-owned node tables.
                    </p>
                </div>

                <div class="flex flex-wrap gap-3">
                    <button class="shell-button rounded-full px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                            @onclick="ResetViewAsync"
                            disabled="@(!_visibleNodes.Any() && string.IsNullOrWhiteSpace(_searchText) && string.IsNullOrWhiteSpace(_focusedChannel))">
                        Reset view
                    </button>

                    <button class="shell-button rounded-full px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                            @onclick="ClearMapCache"
                            disabled="@(_snapshot.Nodes.Count == 0)">
                        Clear map cache
                    </button>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(_mapError))
            {
                <p class="mt-5 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_mapError</p>
            }

            <div class="mt-6 grid gap-4 md:grid-cols-4">
                <article class="shell-subpanel rounded-[1.6rem] p-5">
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Located nodes</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@_snapshot.Nodes.Count</p>
                    <p class="mt-2 text-sm text-cinder-800/72">Bounded in-memory map state only.</p>
                </article>

                <article class="shell-subpanel rounded-[1.6rem] p-5">
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Visible on globe</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@_visibleNodes.Count</p>
                    <p class="mt-2 text-sm text-cinder-800/72">@GetMapSummaryText()</p>
                </article>

                <article class="shell-subpanel rounded-[1.6rem] p-5">
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Channel cohorts</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@(_channelLegendEntries.Count + _hiddenChannelLegendCount)</p>
                    <p class="mt-2 text-sm text-cinder-800/72">Computed from the current local map view.</p>
                </article>

                <article class="shell-subpanel rounded-[1.6rem] p-5">
                    <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Last projection</p>
                    <p class="mt-3 text-2xl font-semibold text-cinder-950">@FormatTimestamp(_snapshot.LastProjectedAtUtc)</p>
                    <p class="mt-2 text-sm text-cinder-800/72">Projection events: @_snapshot.TotalProjected</p>
                </article>
            </div>
        </header>

        <section class="shell-panel rounded-[2rem] p-6">
            <div class="grid gap-4">
                <label class="space-y-2">
                    <span class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Search map nodes</span>
                    <input class="shell-input w-full rounded-2xl px-4 py-3 text-sm text-cinder-950"
                           @bind="_searchText"
                           @bind:event="oninput"
                           @bind:after="HandleSearchChangedAsync"
                           placeholder="Node id, name, channel, packet type" />
                </label>

                @if (!string.IsNullOrWhiteSpace(_focusedChannel))
                {
                    <div class="shell-subpanel flex flex-wrap items-center justify-between gap-3 rounded-[1.6rem] p-4">
                        <div>
                            <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Channel focus</p>
                            <p class="mt-2 break-words text-sm font-semibold text-cinder-950">@_focusedChannel</p>
                        </div>

                        <button class="shell-button rounded-full px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                                @onclick="ClearFocusedChannelAsync">
                            Clear focus
                        </button>
                    </div>
                }

                <div class="space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Channel cohorts</p>
                        <p class="text-xs text-cinder-800/62">Tap a cohort to isolate it on the globe.</p>
                    </div>

                    @if (_channelLegendEntries.Count == 0)
                    {
                        <div class="shell-subpanel rounded-[1.6rem] p-4 text-sm leading-7 text-cinder-800/76">
                            No mapped channel cohorts match the current search yet.
                        </div>
                    }
                    else
                    {
                        <div class="flex flex-wrap gap-2">
                            @foreach (var entry in _channelLegendEntries)
                            {
                                var isFocused = string.Equals(_focusedChannel, entry.Channel, StringComparison.Ordinal);

                                <button type="button"
                                        class="@GetChannelChipClass(isFocused)"
                                        @onclick="() => ToggleFocusedChannelAsync(entry.Channel)">
                                    <span class="h-2.5 w-2.5 rounded-full ring-1 ring-cinder-950/20"
                                          style="background-color:@entry.ColorCss"></span>
                                    <span>@entry.Channel</span>
                                    <span class="text-cinder-800/62">@entry.NodeCount</span>
                                </button>
                            }
                        </div>

                        @if (_hiddenChannelLegendCount > 0)
                        {
                            <p class="text-xs text-cinder-800/62">+ @_hiddenChannelLegendCount more channel cohorts in the current search result.</p>
                        }
                    }
                </div>
            </div>
        </section>

        <aside class="shell-panel rounded-[2rem] p-8">
            @if (FocusedNode is null)
            {
                <div class="space-y-3">
                    <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Focused node</p>
                    <h2 class="font-display text-3xl text-cinder-950">No node selected</h2>
                    <p class="text-sm leading-7 text-cinder-800/82">
                        Hover a node to inspect its current local state or click a marker to pin it while you pan the globe.
                    </p>
                </div>
            }
            else
            {
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Focused node</p>
                        <h2 class="mt-2 font-display text-3xl text-cinder-950">@FocusedNode.DisplayName</h2>
                        <p class="mt-2 text-sm text-cinder-800/72">@FocusedNode.NodeId</p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_pinnedNodeId))
                    {
                        <button class="shell-button rounded-full px-4 py-3 text-xs font-semibold uppercase tracking-[0.14em]"
                                @onclick="ReleasePinnedNodeAsync">
                            Release pin
                        </button>
                    }
                </div>

                <div class="mt-6 grid gap-4 md:grid-cols-2">
                    <article class="shell-subpanel rounded-[1.6rem] p-5">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Live state</p>
                        <dl class="mt-4 space-y-3 text-sm text-cinder-900">
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Last heard</dt>
                                <dd>@FormatTimestamp(FocusedNode.LastHeardAtUtc)</dd>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Last packet</dt>
                                <dd>@(FocusedNode.LastPacketType ?? "Unknown")</dd>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Observed packets</dt>
                                <dd>@FocusedNode.ObservedPacketCount</dd>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Visible peers</dt>
                                <dd>@FocusedNodePeerCount</dd>
                            </div>
                        </dl>
                    </article>

                    <article class="shell-subpanel rounded-[1.6rem] p-5">
                        <p class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-cinder-800/60">Location</p>
                        <dl class="mt-4 space-y-3 text-sm text-cinder-900">
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Channel</dt>
                                <dd>@(FocusedNode.Channel ?? "Unknown")</dd>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Battery</dt>
                                <dd>@FormatBattery(FocusedNode.BatteryLevelPercent)</dd>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Coordinates</dt>
                                <dd>@FormatCoordinates(FocusedNode)</dd>
                            </div>
                            <div class="flex items-center justify-between gap-4">
                                <dt class="text-cinder-800/68">Broker</dt>
                                <dd class="truncate text-right">@FocusedNode.BrokerServer</dd>
                            </div>
                        </dl>
                    </article>
                </div>
            }
        </aside>
    </section>

    <section class="shell-panel relative overflow-hidden rounded-[2rem] p-4">
        <div id="@MapElementId"
             class="meshboard-node-map h-[42rem] w-full overflow-hidden rounded-[1.6rem] border border-sand-200/80 bg-slate-50/60"></div>

        @if (_visibleNodes.Count == 0)
        {
            <div class="pointer-events-none absolute inset-0 flex items-center justify-center p-8">
                <div class="max-w-md rounded-[1.8rem] border border-white/70 bg-white/90 px-6 py-5 text-center shadow-lg shadow-cinder-950/15">
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-signal-600">Awaiting located nodes</p>
                    <p class="mt-3 text-sm leading-7 text-cinder-800/80">
                        Keep the realtime connection open and wait for local node projections with coordinates to arrive.
                    </p>
                </div>
            </div>
        }
    </section>
</div>

@code {
    private const string MapElementId = "meshboard-client-node-map";
    private const int MaxVisibleLegendEntries = 10;
    private IReadOnlyList<ChannelLegendEntry> _channelLegendEntries = Array.Empty<ChannelLegendEntry>();
    private IReadOnlyList<MapNodeActivity> _pendingActivityPulses = MapProjectionSnapshot.EmptyActivityPulses;
    private MapProjectionSnapshot _snapshot = new();
    private IReadOnlyList<MapProjectionEnvelope> _searchMatchedNodes = MapProjectionSnapshot.EmptyNodes;
    private IReadOnlyList<MapProjectionEnvelope> _visibleNodes = MapProjectionSnapshot.EmptyNodes;
    private IReadOnlyList<MapNodePoint> _visibleMapNodes = Array.Empty<MapNodePoint>();
    private DotNetObjectReference<Map>? _mapCallbackReference;
    private Lazy<Task<IJSObjectReference>>? _moduleTask;
    private bool _isDisposed;
    private bool _isMapRenderPending;
    private bool _shouldFitMapToNodes = true;
    private int _hiddenChannelLegendCount;
    private string _searchText = string.Empty;
    private string? _focusedChannel;
    private string? _hoveredNodeId;
    private string? _mapError;
    private string? _pinnedNodeId;

    private MapProjectionEnvelope? FocusedNode =>
        ResolveNode(_pinnedNodeId) ??
        ResolveNode(_hoveredNodeId);

    private int FocusedNodePeerCount =>
        FocusedNode is null || string.IsNullOrWhiteSpace(FocusedNode.Channel)
            ? 0
            : _visibleNodes.Count(node =>
                !string.Equals(node.NodeId, FocusedNode.NodeId, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(node.Channel, FocusedNode.Channel, StringComparison.Ordinal));

    protected override void OnInitialized()
    {
        ProjectionStore.Changed += HandleProjectionStoreChanged;
        RefreshView(mergeActivityPulses: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _isMapRenderPending)
        {
            _isMapRenderPending = false;
            await RenderMapAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        ProjectionStore.Changed -= HandleProjectionStoreChanged;
        _mapCallbackReference?.Dispose();

        if (_moduleTask is null || !_moduleTask.IsValueCreated)
        {
            return;
        }

        try
        {
            var module = await _moduleTask.Value;
            await module.InvokeVoidAsync("disposeNodeMap", MapElementId);
            await module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
    }

    [JSInvokable]
    public async Task OnNodeSelectedFromMap(string? nodeId)
    {
        _pinnedNodeId = string.IsNullOrWhiteSpace(nodeId)
            ? null
            : string.Equals(_pinnedNodeId, nodeId, StringComparison.Ordinal)
                ? null
                : nodeId.Trim();
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnNodeHoveredFromMap(string? nodeId)
    {
        _hoveredNodeId = string.IsNullOrWhiteSpace(nodeId) ? null : nodeId.Trim();
        await InvokeAsync(StateHasChanged);
    }

    private void HandleProjectionStoreChanged()
    {
        if (_isDisposed)
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            if (_isDisposed)
            {
                return Task.CompletedTask;
            }

            RefreshView(mergeActivityPulses: true);
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    private async Task HandleSearchChangedAsync()
    {
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFocusedChannelAsync(string channel)
    {
        _focusedChannel = string.Equals(_focusedChannel, channel, StringComparison.Ordinal)
            ? null
            : channel;
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearFocusedChannelAsync()
    {
        _focusedChannel = null;
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetViewAsync()
    {
        _searchText = string.Empty;
        _focusedChannel = null;
        _hoveredNodeId = null;
        _pinnedNodeId = null;
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReleasePinnedNodeAsync()
    {
        _pinnedNodeId = null;
        _isMapRenderPending = true;
        await InvokeAsync(StateHasChanged);
    }

    private void ClearMapCache()
    {
        _focusedChannel = null;
        _hoveredNodeId = null;
        _pinnedNodeId = null;
        _shouldFitMapToNodes = true;
        ProjectionStore.Clear();
    }

    private void RefreshView(bool mergeActivityPulses)
    {
        _snapshot = ProjectionStore.Current;
        _searchMatchedNodes = MapProjectionStore.ApplyQuery(_snapshot, _searchText, focusedChannel: null);

        if (!string.IsNullOrWhiteSpace(_focusedChannel) &&
            !_searchMatchedNodes.Any(node => string.Equals(node.Channel, _focusedChannel, StringComparison.Ordinal)))
        {
            _focusedChannel = null;
        }

        _visibleNodes = string.IsNullOrWhiteSpace(_focusedChannel)
            ? _searchMatchedNodes
            : _searchMatchedNodes
                .Where(node => string.Equals(node.Channel, _focusedChannel, StringComparison.Ordinal))
                .ToArray();
        _visibleMapNodes = MapProjectionStore.ToMapNodePoints(_visibleNodes);

        if (mergeActivityPulses)
        {
            _pendingActivityPulses = MergeActivityPulses(_pendingActivityPulses, ProjectionStore.DrainActivityPulses());
        }

        BuildChannelLegend();
        _isMapRenderPending = true;
    }

    private void BuildChannelLegend()
    {
        var groupedEntries = _searchMatchedNodes
            .GroupBy(node => NormalizeNullableText(node.Channel) ?? "Unknown", StringComparer.Ordinal)
            .Select(group => new { Channel = group.Key, NodeCount = group.Count() })
            .OrderByDescending(entry => entry.NodeCount)
            .ThenBy(entry => entry.Channel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        _hiddenChannelLegendCount = Math.Max(0, groupedEntries.Length - MaxVisibleLegendEntries);
        _channelLegendEntries = groupedEntries
            .Take(MaxVisibleLegendEntries)
            .Select(entry => new ChannelLegendEntry(
                entry.Channel,
                entry.NodeCount,
                ResolveChannelColorCss(entry.Channel)))
            .ToArray();
    }

    private async Task RenderMapAsync()
    {
        try
        {
            var module = await GetMapModuleAsync();
            _mapCallbackReference ??= DotNetObjectReference.Create(this);

            await module.InvokeVoidAsync(
                "renderNodeMap",
                MapElementId,
                _visibleMapNodes,
                _pendingActivityPulses,
                _shouldFitMapToNodes,
                _mapCallbackReference);
            await SynchronizePinnedNodeAsync();

            _pendingActivityPulses = MapProjectionSnapshot.EmptyActivityPulses;
            _shouldFitMapToNodes = false;
            _mapError = null;
        }
        catch (JSDisconnectedException)
        {
        }
        catch (Exception exception)
        {
            _mapError = exception.Message;
        }
    }

    private Task<IJSObjectReference> GetMapModuleAsync()
    {
        _moduleTask ??= new Lazy<Task<IJSObjectReference>>(
            () => JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/node-map.js").AsTask());
        return _moduleTask.Value;
    }

    private async Task SynchronizePinnedNodeAsync()
    {
        if (_moduleTask is null || !_moduleTask.IsValueCreated)
        {
            return;
        }

        try
        {
            var module = await _moduleTask.Value;
            await module.InvokeVoidAsync("setPinnedNode", MapElementId, _pinnedNodeId);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private MapProjectionEnvelope? ResolveNode(string? nodeId)
    {
        return string.IsNullOrWhiteSpace(nodeId)
            ? null
            : _visibleNodes.FirstOrDefault(node => string.Equals(node.NodeId, nodeId, StringComparison.OrdinalIgnoreCase));
    }

    private string GetMapSummaryText()
    {
        if (_snapshot.Nodes.Count == 0)
        {
            return "No located nodes are currently projected in memory.";
        }

        var cohortCount = _searchMatchedNodes
            .Select(node => NormalizeNullableText(node.Channel) ?? "Unknown")
            .Distinct(StringComparer.Ordinal)
            .Count();

        return $"{_searchMatchedNodes.Count} matching located nodes across {cohortCount} channel cohorts.";
    }

    private static IReadOnlyList<MapNodeActivity> MergeActivityPulses(
        IReadOnlyList<MapNodeActivity> existing,
        IReadOnlyList<MapNodeActivity> incoming)
    {
        if (incoming.Count == 0)
        {
            return existing;
        }

        if (existing.Count == 0)
        {
            return incoming;
        }

        return existing
            .Concat(incoming)
            .GroupBy(entry => entry.NodeId, StringComparer.OrdinalIgnoreCase)
            .Select(group => new MapNodeActivity
            {
                NodeId = group.First().NodeId,
                PulseCount = group.Sum(entry => entry.PulseCount)
            })
            .ToArray();
    }

    private static string FormatBattery(int? batteryLevelPercent)
    {
        return batteryLevelPercent.HasValue
            ? $"{batteryLevelPercent.Value}%"
            : "Unknown";
    }

    private static string FormatCoordinates(MapProjectionEnvelope node)
    {
        return $"{node.Latitude:F5}, {node.Longitude:F5}";
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
            : "No packets yet";
    }

    private static string? NormalizeNullableText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string GetChannelChipClass(bool isFocused)
    {
        return isFocused
            ? "shell-button shell-button-accent inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
            : "shell-button inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]";
    }

    private static string ResolveChannelColorCss(string channel)
    {
        var hash = 0;

        foreach (var character in channel)
        {
            hash = ((hash << 5) - hash) + character;
        }

        var hue = (uint)hash % 360;
        return $"hsl({hue} 72% 58%)";
    }

    private sealed record ChannelLegendEntry(string Channel, int NodeCount, string ColorCss);
}
