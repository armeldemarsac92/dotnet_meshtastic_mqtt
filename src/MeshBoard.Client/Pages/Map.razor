@page "/map"
@using MeshBoard.Client.Components.Details
@using MeshBoard.Client.Maps
@attribute [Authorize]
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject MapProjectionStore ProjectionStore

<PageTitle>Map</PageTitle>

<div class="flex h-[calc(100dvh-3rem)] min-h-0 flex-col gap-4 sm:h-[calc(100dvh-4rem)] lg:h-[calc(100dvh-5rem)]">
    <header class="space-y-2">
        <div>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-signal-600">Geospatial view</p>
            <h1 class="font-display text-4xl text-cinder-950 sm:text-5xl">Node map</h1>
        </div>
        <p class="max-w-5xl text-sm leading-7 text-cinder-800 sm:text-base">
            Browse all locally projected nodes on a 3D globe. Click a node to pin focus, click the globe again to release it,
            hover to reveal its shared-channel cohort, and open node or channel details in the restored popup flow.
        </p>
    </header>

    <section class="shell-panel shrink-0 space-y-3 overflow-hidden rounded-[1.6rem] p-4">
        <div class="flex flex-wrap items-start justify-between gap-3 text-sm text-cinder-800/82">
            <div class="space-y-1">
                <p>@GetMapSummaryText()</p>
                <p class="text-[0.72rem] text-cinder-800/62">
                    Hover links show shared-channel cohorts, not proven radio paths.
                </p>
            </div>

            <div class="space-y-1 text-right text-xs text-cinder-800/72">
                <p>Projected nodes: @_snapshot.Nodes.Count</p>
                <p>Unique map positions: @_visiblePositionCount</p>
                <p title="@FormatTimestamp(_snapshot.LastProjectedAtUtc)">Last projection: @FormatRelativeTime(_snapshot.LastProjectedAtUtc)</p>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_mapError))
        {
            <p class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">@_mapError</p>
        }

        @if (!string.IsNullOrWhiteSpace(_focusedChannel))
        {
            <div class="shell-subpanel flex flex-wrap items-center justify-between gap-3 rounded-2xl p-3">
                <div class="space-y-1">
                    <p class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-cinder-800/62">Channel focus</p>
                    <p class="break-words text-sm font-semibold text-cinder-950">@_focusedChannel</p>
                </div>

                <div class="flex flex-wrap gap-2">
                    <button type="button"
                            class="shell-button shell-button-accent rounded-full px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.14em]"
                            @onclick="() => OpenChannelDetails(_focusedChannel!)">
                        Open channel
                    </button>
                    <button type="button"
                            class="shell-button rounded-full px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.14em]"
                            @onclick="ClearFocusedChannelAsync">
                        Clear focus
                    </button>
                </div>
            </div>
        }

        <div class="space-y-2 text-sm text-cinder-800/82">
            <div class="flex flex-wrap items-center justify-between gap-2">
                <p class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-cinder-800/62">Channel cohorts</p>
                <p class="text-[0.72rem] text-cinder-800/66">Click a chip to isolate that cohort on the globe.</p>
            </div>

            @if (_channelLegendEntries.Count == 0)
            {
                <p class="text-xs text-cinder-800/70">No channel cohort matched the current search.</p>
            }
            else
            {
                <div class="flex gap-2 overflow-x-auto pb-1 sm:flex-wrap sm:overflow-x-visible sm:pb-0">
                    @foreach (var entry in _channelLegendEntries)
                    {
                        var isFocused = string.Equals(_focusedChannel, entry.Channel, StringComparison.Ordinal);

                        <button type="button"
                                class="@GetChannelChipClass(isFocused)"
                                @onclick="() => ToggleFocusedChannelAsync(entry.Channel)">
                            <span class="h-2.5 w-2.5 rounded-full ring-1 ring-cinder-950/20"
                                  style="background-color:@entry.ColorCss"></span>
                            <span>@entry.Channel</span>
                            <span class="text-cinder-800/62">@entry.NodeCount</span>
                        </button>
                    }
                </div>

                @if (_hiddenChannelLegendCount > 0)
                {
                    <p class="text-[0.72rem] text-cinder-800/68">+ @_hiddenChannelLegendCount more channel cohorts in view.</p>
                }
            }
        </div>
    </section>

    <section class="shell-panel relative min-h-0 flex-1 overflow-hidden rounded-[1.6rem] p-4">
        <div id="@MapElementId"
             class="meshboard-node-map h-full w-full overflow-hidden rounded-[1.25rem] border border-sand-200/80 bg-slate-50/60"></div>

        <div class="pointer-events-none absolute inset-x-7 top-7 z-10 flex items-start justify-between gap-3">
            <div class="pointer-events-auto w-full max-w-md">
                <label class="relative block">
                    <span class="sr-only">Search on map</span>
                    <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-cinder-800/68">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4">
                            <path fill-rule="evenodd" d="M9 3.75a5.25 5.25 0 1 0 3.285 9.347l3.809 3.809a.75.75 0 1 0 1.06-1.06l-3.808-3.81A5.25 5.25 0 0 0 9 3.75ZM5.25 9a3.75 3.75 0 1 1 7.5 0 3.75 3.75 0 0 1-7.5 0Z" clip-rule="evenodd" />
                        </svg>
                    </span>
                    <input class="shell-input w-full rounded-full px-4 py-3 pl-10 text-sm text-cinder-950 shadow-lg shadow-cinder-950/35"
                           @bind="_searchText"
                           @bind:event="oninput"
                           @bind:after="HandleSearchChangedAsync"
                           placeholder="Search node id, name, or channel" />
                </label>
            </div>

            <div class="pointer-events-auto flex shrink-0 flex-wrap gap-2">
                <button type="button"
                        class="shell-button shell-button-accent rounded-full px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.14em] shadow-lg shadow-cinder-950/35"
                        @onclick="RefreshMapAsync">
                    Refresh map
                </button>
                <button type="button"
                        class="shell-button rounded-full px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.14em] shadow-lg shadow-cinder-950/35"
                        @onclick="ResetViewAsync"
                        disabled="@(!_visibleNodes.Any() && string.IsNullOrWhiteSpace(_searchText) && string.IsNullOrWhiteSpace(_focusedChannel))">
                    Reset view
                </button>
                <button type="button"
                        class="shell-button rounded-full px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.14em] shadow-lg shadow-cinder-950/35"
                        @onclick="ClearMapCache"
                        disabled="@(_snapshot.Nodes.Count == 0)">
                    Clear cache
                </button>
            </div>
        </div>

        <div class="pointer-events-none absolute bottom-7 right-7 z-10 w-full max-w-sm">
            <div class="pointer-events-auto shell-subpanel space-y-3 rounded-[1.35rem] border border-white/70 bg-white/90 p-4 shadow-lg shadow-cinder-950/15">
                <div class="space-y-1">
                    <p class="text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-cinder-800/62">Focused node</p>

                    @if (FocusedNode is null)
                    {
                        <p class="text-xs leading-6 text-cinder-800/72">
                            Hover a node on the globe to inspect its active channel cohort, or click one to pin this panel.
                        </p>
                    }
                    else
                    {
                        <div class="space-y-1">
                            <p class="text-sm font-semibold text-cinder-950">@FocusedNode.DisplayName</p>
                            <p class="break-words text-[0.72rem] text-cinder-800/72">@FocusedNode.NodeId</p>
                        </div>

                        <dl class="grid gap-2 text-[0.72rem] text-cinder-800/78 sm:grid-cols-2">
                            <div class="rounded-2xl border border-sand-200/80 bg-white/75 px-3 py-2">
                                <dt class="font-semibold uppercase tracking-[0.14em] text-cinder-800/62">Channel</dt>
                                <dd class="mt-1 break-words text-cinder-950">@(FocusedNode.Channel ?? "Unknown")</dd>
                            </div>
                            <div class="rounded-2xl border border-sand-200/80 bg-white/75 px-3 py-2">
                                <dt class="font-semibold uppercase tracking-[0.14em] text-cinder-800/62">Visible peers</dt>
                                <dd class="mt-1 text-cinder-950">@FocusedNodePeerCount</dd>
                            </div>
                            <div class="rounded-2xl border border-sand-200/80 bg-white/75 px-3 py-2">
                                <dt class="font-semibold uppercase tracking-[0.14em] text-cinder-800/62">Battery</dt>
                                <dd class="mt-1 text-cinder-950">@FormatBattery(FocusedNode.BatteryLevelPercent)</dd>
                            </div>
                            <div class="rounded-2xl border border-sand-200/80 bg-white/75 px-3 py-2">
                                <dt class="font-semibold uppercase tracking-[0.14em] text-cinder-800/62">Coordinates</dt>
                                <dd class="mt-1 text-cinder-950">@FormatCoordinates(FocusedNode)</dd>
                            </div>
                        </dl>

                        <div class="flex flex-wrap gap-2">
                            <button type="button"
                                    class="shell-button shell-button-accent rounded-full px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.14em]"
                                    @onclick="() => OpenNodeDetails(FocusedNode.NodeId)">
                                Open node
                            </button>

                            @if (!string.IsNullOrWhiteSpace(FocusedNode.Channel))
                            {
                                <button type="button"
                                        class="shell-button rounded-full px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.14em]"
                                        @onclick="() => OpenChannelDetails(FocusedNode.Channel!)">
                                    Open channel
                                </button>
                            }

                            @if (!string.IsNullOrWhiteSpace(_pinnedNodeId))
                            {
                                <button type="button"
                                        class="shell-button rounded-full px-3 py-1.5 text-[0.72rem] font-semibold uppercase tracking-[0.14em]"
                                        @onclick="ReleasePinnedNodeAsync">
                                    Release pin
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (_visibleNodes.Count == 0)
        {
            <div class="pointer-events-none absolute inset-0 flex items-center justify-center p-8">
                <div class="max-w-md rounded-[1.8rem] border border-white/70 bg-white/90 px-6 py-5 text-center shadow-lg shadow-cinder-950/15">
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-signal-600">Awaiting located nodes</p>
                    <p class="mt-3 text-sm leading-7 text-cinder-800/80">
                        Keep the realtime connection open and wait for local node projections with coordinates to arrive.
                    </p>
                </div>
            </div>
        }
        else if (_visiblePositionCount < _visibleNodes.Count)
        {
            <div class="pointer-events-none absolute bottom-6 left-6 max-w-md rounded-[1.3rem] border border-white/70 bg-white/90 px-4 py-3 text-sm leading-6 text-cinder-800/82 shadow-lg shadow-cinder-950/10">
                @_visibleNodes.Count nodes match the current filters, but @_visiblePositionCount unique positions are represented on the globe.
                Overlapping coordinates are spread slightly so you can still select them.
            </div>
        }
    </section>
</div>

<NodeDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedNodeId))"
                  NodeId="@(_selectedNodeId ?? string.Empty)"
                  OnClose="CloseNodeDetails"
                  OnOpenChannel="OpenChannelDetailsAsync" />

<ChannelDetailsModal IsOpen="@(!string.IsNullOrWhiteSpace(_selectedChannelKey))"
                     ChannelKey="@(_selectedChannelKey ?? string.Empty)"
                     OnClose="CloseChannelDetails"
                     OnOpenNode="OpenNodeDetailsAsync" />

@code {
    private const string MapElementId = "meshboard-client-node-map";
    private const int MaxVisibleLegendEntries = 10;
    private IReadOnlyList<ChannelLegendEntry> _channelLegendEntries = Array.Empty<ChannelLegendEntry>();
    private IReadOnlyList<MapNodeActivity> _pendingActivityPulses = MapProjectionSnapshot.EmptyActivityPulses;
    private MapProjectionSnapshot _snapshot = new();
    private IReadOnlyList<MapProjectionEnvelope> _searchMatchedNodes = MapProjectionSnapshot.EmptyNodes;
    private IReadOnlyList<MapProjectionEnvelope> _visibleNodes = MapProjectionSnapshot.EmptyNodes;
    private IReadOnlyList<MapNodePoint> _visibleMapNodes = Array.Empty<MapNodePoint>();
    private int _visiblePositionCount;
    private DotNetObjectReference<Map>? _mapCallbackReference;
    private Lazy<Task<IJSObjectReference>>? _moduleTask;
    private bool _isDisposed;
    private bool _isMapRenderPending;
    private bool _shouldFitMapToNodes = true;
    private int _hiddenChannelLegendCount;
    private string _searchText = string.Empty;
    private string? _focusedChannel;
    private string? _hoveredNodeId;
    private string? _mapError;
    private string? _pinnedNodeId;
    private string? _selectedChannelKey;
    private string? _selectedNodeId;

    private MapProjectionEnvelope? FocusedNode =>
        ResolveNode(_pinnedNodeId) ??
        ResolveNode(_hoveredNodeId);

    private int FocusedNodePeerCount =>
        FocusedNode is null || string.IsNullOrWhiteSpace(FocusedNode.Channel)
            ? 0
            : _visibleNodes.Count(node =>
                !string.Equals(node.NodeId, FocusedNode.NodeId, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(node.Channel, FocusedNode.Channel, StringComparison.Ordinal));

    protected override void OnInitialized()
    {
        ProjectionStore.Changed += HandleProjectionStoreChanged;
        RefreshView(mergeActivityPulses: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _isMapRenderPending)
        {
            _isMapRenderPending = false;
            await RenderMapAsync();
        }
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        ProjectionStore.Changed -= HandleProjectionStoreChanged;
        _mapCallbackReference?.Dispose();

        if (_moduleTask is null || !_moduleTask.IsValueCreated)
        {
            return;
        }

        try
        {
            var module = await _moduleTask.Value;
            await module.InvokeVoidAsync("disposeNodeMap", MapElementId);
            await module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
    }

    [JSInvokable]
    public async Task OnNodeSelectedFromMap(string? nodeId)
    {
        _pinnedNodeId = string.IsNullOrWhiteSpace(nodeId)
            ? null
            : string.Equals(_pinnedNodeId, nodeId, StringComparison.Ordinal)
                ? null
                : nodeId.Trim();
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnNodeHoveredFromMap(string? nodeId)
    {
        _hoveredNodeId = string.IsNullOrWhiteSpace(nodeId) ? null : nodeId.Trim();
        await InvokeAsync(StateHasChanged);
    }

    private void HandleProjectionStoreChanged()
    {
        if (_isDisposed)
        {
            return;
        }

        _ = InvokeAsync(() =>
        {
            if (_isDisposed)
            {
                return Task.CompletedTask;
            }

            RefreshView(mergeActivityPulses: true);
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    private async Task HandleSearchChangedAsync()
    {
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFocusedChannelAsync(string channel)
    {
        _focusedChannel = string.Equals(_focusedChannel, channel, StringComparison.Ordinal)
            ? null
            : channel;
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearFocusedChannelAsync()
    {
        _focusedChannel = null;
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshMapAsync()
    {
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetViewAsync()
    {
        _searchText = string.Empty;
        _focusedChannel = null;
        _hoveredNodeId = null;
        _pinnedNodeId = null;
        _shouldFitMapToNodes = true;
        RefreshView(mergeActivityPulses: false);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReleasePinnedNodeAsync()
    {
        _pinnedNodeId = null;
        _isMapRenderPending = true;
        await InvokeAsync(StateHasChanged);
    }

    private void ClearMapCache()
    {
        _focusedChannel = null;
        _hoveredNodeId = null;
        _pinnedNodeId = null;
        _selectedNodeId = null;
        _selectedChannelKey = null;
        _shouldFitMapToNodes = true;
        ProjectionStore.Clear();
    }

    private void OpenNodeDetails(string nodeId)
    {
        _selectedChannelKey = null;
        _selectedNodeId = nodeId;
    }

    private Task OpenNodeDetailsAsync(string nodeId)
    {
        OpenNodeDetails(nodeId);
        return Task.CompletedTask;
    }

    private void CloseNodeDetails()
    {
        _selectedNodeId = null;
    }

    private void OpenChannelDetails(string channelKey)
    {
        _selectedNodeId = null;
        _selectedChannelKey = channelKey;
    }

    private Task OpenChannelDetailsAsync(string channelKey)
    {
        OpenChannelDetails(channelKey);
        return Task.CompletedTask;
    }

    private void CloseChannelDetails()
    {
        _selectedChannelKey = null;
    }

    private void RefreshView(bool mergeActivityPulses)
    {
        _snapshot = ProjectionStore.Current;
        _searchMatchedNodes = MapProjectionStore.ApplyQuery(_snapshot, _searchText, focusedChannel: null);

        if (!string.IsNullOrWhiteSpace(_focusedChannel) &&
            !_searchMatchedNodes.Any(node => string.Equals(node.Channel, _focusedChannel, StringComparison.Ordinal)))
        {
            _focusedChannel = null;
        }

        _visibleNodes = string.IsNullOrWhiteSpace(_focusedChannel)
            ? _searchMatchedNodes
            : _searchMatchedNodes
                .Where(node => string.Equals(node.Channel, _focusedChannel, StringComparison.Ordinal))
                .ToArray();
        _visibleMapNodes = MapProjectionStore.ToMapNodePoints(_visibleNodes);
        _visiblePositionCount = MapProjectionStore.CountCoordinateBuckets(_visibleNodes);

        if (mergeActivityPulses)
        {
            _pendingActivityPulses = MergeActivityPulses(_pendingActivityPulses, ProjectionStore.DrainActivityPulses());
        }

        BuildChannelLegend();
        _isMapRenderPending = true;
    }

    private void BuildChannelLegend()
    {
        var groupedEntries = _searchMatchedNodes
            .GroupBy(node => NormalizeNullableText(node.Channel) ?? "Unknown", StringComparer.Ordinal)
            .Select(group => new { Channel = group.Key, NodeCount = group.Count() })
            .OrderByDescending(entry => entry.NodeCount)
            .ThenBy(entry => entry.Channel, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        _hiddenChannelLegendCount = Math.Max(0, groupedEntries.Length - MaxVisibleLegendEntries);
        _channelLegendEntries = groupedEntries
            .Take(MaxVisibleLegendEntries)
            .Select(entry => new ChannelLegendEntry(
                entry.Channel,
                entry.NodeCount,
                ResolveChannelColorCss(entry.Channel)))
            .ToArray();
    }

    private async Task RenderMapAsync()
    {
        try
        {
            var module = await GetMapModuleAsync();
            _mapCallbackReference ??= DotNetObjectReference.Create(this);

            await module.InvokeVoidAsync(
                "renderNodeMap",
                MapElementId,
                _visibleMapNodes,
                _pendingActivityPulses,
                _shouldFitMapToNodes,
                _mapCallbackReference);
            await SynchronizePinnedNodeAsync();

            _pendingActivityPulses = MapProjectionSnapshot.EmptyActivityPulses;
            _shouldFitMapToNodes = false;
            _mapError = null;
        }
        catch (JSDisconnectedException)
        {
        }
        catch (Exception exception)
        {
            _mapError = exception.Message;
        }
    }

    private Task<IJSObjectReference> GetMapModuleAsync()
    {
        _moduleTask ??= new Lazy<Task<IJSObjectReference>>(
            () => JSRuntime.InvokeAsync<IJSObjectReference>("import", "./js/node-map.js").AsTask());
        return _moduleTask.Value;
    }

    private async Task SynchronizePinnedNodeAsync()
    {
        if (_moduleTask is null || !_moduleTask.IsValueCreated)
        {
            return;
        }

        try
        {
            var module = await _moduleTask.Value;
            await module.InvokeVoidAsync("setPinnedNode", MapElementId, _pinnedNodeId);
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private MapProjectionEnvelope? ResolveNode(string? nodeId)
    {
        return string.IsNullOrWhiteSpace(nodeId)
            ? null
            : _visibleNodes.FirstOrDefault(node => string.Equals(node.NodeId, nodeId, StringComparison.OrdinalIgnoreCase));
    }

    private string GetMapSummaryText()
    {
        if (_snapshot.Nodes.Count == 0)
        {
            return "No projected nodes with coordinates are currently held in memory.";
        }

        var cohortCount = _searchMatchedNodes
            .Select(node => NormalizeNullableText(node.Channel) ?? "Unknown")
            .Distinct(StringComparer.Ordinal)
            .Count();

        return $"{_searchMatchedNodes.Count} matching nodes across {cohortCount} channel cohorts. Some may be hidden on the far side of the globe.";
    }

    private static IReadOnlyList<MapNodeActivity> MergeActivityPulses(
        IReadOnlyList<MapNodeActivity> existing,
        IReadOnlyList<MapNodeActivity> incoming)
    {
        if (incoming.Count == 0)
        {
            return existing;
        }

        if (existing.Count == 0)
        {
            return incoming;
        }

        return existing
            .Concat(incoming)
            .GroupBy(entry => entry.NodeId, StringComparer.OrdinalIgnoreCase)
            .Select(group => new MapNodeActivity
            {
                NodeId = group.First().NodeId,
                PulseCount = group.Sum(entry => entry.PulseCount)
            })
            .ToArray();
    }

    private static string FormatBattery(int? batteryLevelPercent)
    {
        return batteryLevelPercent.HasValue
            ? $"{batteryLevelPercent.Value}%"
            : "Unknown";
    }

    private static string FormatCoordinates(MapProjectionEnvelope node)
    {
        return $"{node.Latitude:F5}, {node.Longitude:F5}";
    }

    private static string FormatTimestamp(DateTimeOffset? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
            : "No packets yet";
    }

    private static string FormatRelativeTime(DateTimeOffset? value)
    {
        if (!value.HasValue) return "No packets yet";
        var diff = DateTimeOffset.UtcNow - value.Value;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return value.Value.ToLocalTime().ToString("MMM d");
    }

    private static string? NormalizeNullableText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string GetChannelChipClass(bool isFocused)
    {
        return isFocused
            ? "shell-button shell-button-accent inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]"
            : "shell-button inline-flex items-center gap-2 rounded-full px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em]";
    }

    private static string ResolveChannelColorCss(string channel)
    {
        var hash = 0;

        foreach (var character in channel)
        {
            hash = ((hash << 5) - hash) + character;
        }

        var hue = (uint)hash % 360;
        return $"hsl({hue} 72% 58%)";
    }

    private sealed record ChannelLegendEntry(string Channel, int NodeCount, string ColorCss);
}
