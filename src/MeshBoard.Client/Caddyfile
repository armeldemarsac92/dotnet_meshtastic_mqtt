:80 {
    encode zstd br gzip

    handle /api/* {
        reverse_proxy meshboard-api:8080
    }

    handle /.well-known/* {
        reverse_proxy meshboard-api:8080
    }

    handle {
        root * /srv

        route {
            try_files {path} /index.html
            header /index.html Cache-Control "public, max-age=0, must-revalidate"
        }

        file_server
    }
}
